\ttab.mu.Unlock()\\n239:\\t\\tif ev.notifyCopy && text != \\\"\\\" && m.msgSink != nil {\\n240:\\t\\t\\tm.msgSink(tabSelectionResult{workspaceID: ev.workspaceID, tabID: ev.tabID, clipboard: text})\\n241:\\t\\t}\\n242:\\tcase tabEventSelectionStart:\\n243:\\t\\ttab.mu.Lock()\\n244:\\t\\tif tab.Terminal != nil {\\n245:\\t\\t\\ttab.Terminal.ClearSelection()\\n246:\\t\\t}\\n247:\\t\\ttab.Selection = common.SelectionState{}\\n248:\\t\\ttab.selectionScroll.Reset()\\n249:\\t\\tif ev.inBounds && tab.Terminal != nil {\\n250:\\t\\t\\tabsLine := tab.Terminal.ScreenYToAbsoluteLine(ev.termY)\\n251:\\t\\t\\ttab.Selection = common.SelectionState{\\n252:\\t\\t\\t\\tActive:    true,\\n253:\\t\\t\\t\\tStartX:    ev.termX,\\n254:\\t\\t\\t\\tStartLine: absLine,\\n255:\\t\\t\\t\\tEndX:      ev.termX,\\n256:\\t\\t\\t\\tEndLine:   absLine,\\n257:\\t\\t\\t}\\n258:\\t\\t\\ttab.Terminal.SetSelection(ev.termX, absLine, ev.termX, absLine, true, false)\\n259:\\t\\t}\\n260:\\t\\ttab.mu.Unlock()\\n261:\\tcase tabEventSelectionUpdate:\\n262:\\t\\ttab.mu.Lock()\\n263:\\t\\tdefer tab.mu.Unlock()\\n264:\\t\\tif !tab.Selection.Active || tab.Terminal == nil {\\n265:\\t\\t\\treturn\\n266:\\t\\t}\\n267:\\t\\ttermWidth := tab.Terminal.Width\\n268:\\t\\ttermHeight := tab.Terminal.Height\\n269:\\t\\ttermX := ev.termX\\n270:\\t\\ttermY := ev.termY\\n271:\\n272:\\t\\tif termX < 0 {\\n273:\\t\\t\\ttermX = 0\\n274:\\t\\t}\\n275:\\t\\tif termX >= termWidth {\\n276:\\t\\t\\ttermX = termWidth - 1\\n277:\\t\\t}\\n278:\\n279:\\t\\t// Set scroll direction from unclamped Y before clamping\\n280:\\t\\ttab.selectionScroll.SetDirection(termY, termHeight)\\n281:\\n282:\\t\\tif termY < 0 {\\n283:\\t\\t\\ttab.Terminal.ScrollView(1)\\n284:\\t\\t\\ttermY = 0\\n285:\\t\\t} else if termY >= termHeight {\\n286:\\t\\t\\ttab.Terminal.ScrollView(-1)\\n287:\\t\\t\\ttermY = termHeight - 1\\n288:\\t\\t}\\n289:\\n290:\\t\\tabsLine := tab.Terminal.ScreenYToAbsoluteLine(termY)\\n291:\\t\\tstartX := tab.Terminal.SelStartX()\\n292:\\t\\tst