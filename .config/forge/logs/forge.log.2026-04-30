e\\n120:}\\n121:\\n122:func shouldDropTabEvent(ch chan tabEvent, kind tabEventKind) bool {\\n123:\\tif ch == nil {\\n124:\\t\\treturn true\\n125:\\t}\\n126:\\tswitch kind {\\n127:\\tcase tabEventSelectionUpdate, tabEventSelectionScrollTick, tabEventScrollBy, tabEventScrollPage:\\n128:\\tdefault:\\n129:\\t\\treturn false\\n130:\\t}\\n131:\\tcapacity := cap(ch)\\n132:\\tif capacity == 0 {\\n133:\\t\\treturn false\\n134:\\t}\\n135:\\treturn len(ch) >= (capacity*3)/4\\n136:}\\n137:\\n138:func shouldPostTabActorRedraw(kind tabEventKind) bool {\\n139:\\tswitch kind {\\n140:\\tcase tabEventSelectionStart,\\n141:\\t\\ttabEventSelectionUpdate,\\n142:\\t\\ttabEventSelectionFinish,\\n143:\\t\\ttabEventScrollBy,\\n144:\\t\\ttabEventSelectionClearAndNotify,\\n145:\\t\\ttabEventSelectionScrollTick,\\n146:\\t\\ttabEventScrollToBottom,\\n147:\\t\\ttabEventScrollPage,\\n148:\\t\\ttabEventScrollToTop,\\n149:\\t\\ttabEventDiffInput:\\n150:\\t\\treturn true\\n151:\\tdefault:\\n152:\\t\\treturn false\\n153:\\t}\\n154:}\\n155:\\n156:func (m *Model) RunTabActor(ctx context.Context) error {\\n157:\\tif m == nil || m.tabEvents == nil {\\n158:\\t\\treturn nil\\n159:\\t}\\n160:\\t// Signal readiness via TEA message loop.\\n161:\\tif m.msgSink != nil {\\n162:\\t\\tm.msgSink(tabActorStarted{})\\n163:\\t} else if m.msgSinkTry != nil {\\n164:\\t\\tm.msgSinkTry(tabActorStarted{})\\n165:\\t}\\n166:\\tticker := time.NewTicker(2 * time.Second)\\n167:\\tdefer ticker.Stop()\\n168:\\tfor {\\n169:\\t\\tselect {\\n170:\\t\\tcase <-ctx.Done():\\n171:\\t\\t\\treturn nil\\n172:\\t\\tcase ev := <-m.tabEvents:\\n173:\\t\\t\\t// Send heartbeat via TEA message loop.\\n174:\\t\\t\\tif m.msgSink != nil {\\n175:\\t\\t\\t\\tm.msgSink(tabActorHeartbeatMsg{})\\n176:\\t\\t\\t} else if m.msgSinkTry != nil {\\n177:\\t\\t\\t\\tm.msgSinkTry(tabActorHeartbeatMsg{})\\n178:\\t\\t\\t}\\n179:\\t\\t\\tm.handleTabEvent(ev)\\n180:\\t\\t\\tif shouldPostTabActorRedraw(ev.kind) {\\n181:\\t\\t\\t\\tm.requestTabActorRedraw()\\n182:\\t\