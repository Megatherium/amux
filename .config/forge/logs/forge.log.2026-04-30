w := h.app.ui.toast.View(); view != \\\"\\\" {\\n 45:\\t\\tt.Fatalf(\\\"expected no toast on successful close save, got %q\\\", view)\\n 46:\\t}\\n 47:\\n 48:\\tdata, err := os.ReadFile(configPath)\\n 49:\\tif err != nil {\\n 50:\\t\\tt.Fatalf(\\\"expected config file to be written: %v\\\", err)\\n 51:\\t}\\n 52:\\tif !strings.Contains(string(data), `\\\"theme\\\": \\\"tokyo-night\\\"`) {\\n 53:\\t\\tt.Fatalf(\\\"expected persisted theme in config, got %q\\\", string(data))\\n 54:\\t}\\n 55:}\\n 56:\\n 57:func TestHandleSettingsResult_SaveFailureShowsWarningToast(t *testing.T) {\\n 58:\\tprevTheme := common.GetCurrentTheme().ID\\n 59:\\tdefer common.SetCurrentTheme(prevTheme)\\n 60:\\n 61:\\th, err := NewHarness(HarnessOptions{\\n 62:\\t\\tMode:   HarnessCenter,\\n 63:\\t\\tWidth:  120,\\n 64:\\t\\tHeight: 40,\\n 65:\\t})\\n 66:\\tif err != nil {\\n 67:\\t\\tt.Fatalf(\\\"NewHarness returned error: %v\\\", err)\\n 68:\\t}\\n 69:\\n 70:\\t// Point to a directory path so os.WriteFile fails with \\\"is a directory\\\".\\n 71:\\th.app.config.Paths.ConfigPath = t.TempDir()\\n 72:\\th.app.handleShowSettingsDialog()\\n 73:\\tsession := h.app.ui.settingsDialogSession\\n 74:\\t_ = h.app.handleThemePreview(common.ThemePreview{Theme: common.ThemeTokyoNight, Session: session})\\n 75:\\n 76:\\tcmd := h.app.handleSettingsResult(common.SettingsResult{})\\n 77:\\tif cmd == nil {\\n 78:\\t\\tt.Fatal(\\\"expected warning toast cmd when close save fails\\\")\\n 79:\\t}\\n 80:\\n 81:\\tif view := h.app.ui.toast.View(); !strings.Contains(view, \\\"Failed to save theme setting\\\") {\\n 82:\\t\\tt.Fatalf(\\\"expected warning toast for save failure, got %q\\\", view)\\n 83:\\t}\\n 84:}\\n 85:\\n 86:func TestHandleSettingsResult_UnchangedThemeSkipsSave(t *testing.T) {\\n 87:\\tprevTheme := common.GetCurrentTheme().ID\\n 88:\\tdefer common.SetCurrentTheme(prevTheme)\\n 89:\\n 90:\\th, err := NewHarness(HarnessOptions{\\n 91:\\t\\tMode:   HarnessCenter,\\n 92:\\t\\tWidth:  120,\\n 93:\\t\\tHeight: 40,\\n 94:\\t})\\n 95:\\tif err != nil {\\n 96:\\t\\tt.Fatalf(\\\"NewHarness returned error: %v\\\", err)\\n 97:\\t}\\n 98:\\n 99:\\tconfigPath := filepath.Join(t.TempDir(), \\\"amux-config.json\\\")\\n100:\\th.app.config.Paths.ConfigPath = configPath\\n101:\\tif err := h.app.config.SaveUISettings(); err != nil {\\n102:\\t\\tt.Fatalf(\\\"SaveUISettings returned error: %v\\\", err)\\n103:\\t}\\n104:\\th.app.handleShowSettingsDialog()\\n105:\\n106:\\tcmd := h.app.handleSettingsResult(common.SettingsResult{})\\n107:\\tif cmd != nil {\\n108:\\t\\tt.Fatal(\\\"expected no cmd when closing settings without theme change\\\")\\n109:\\t}\\n110:\\tif h.app.ui.settingsThemeDirty {\\n111:\\t\\tt.Fatal(\\\"expected dirty flag to remain false when theme unchanged\\\")\\n112:\\t}\\n113:}\\n114:\\n115:func TestHandleTriggerUpgrade_PersistsThemeChange(t *testing.T) {\\n116:\\tprevTheme := common.GetCurrentTheme().ID\\n117:\\tdefer common.SetCurrentTheme(prevTheme)\\n118:\\n119:\\th, err := NewHarness(HarnessOptions{\\n120:\\t\\tMode:   HarnessCenter,\\n121:\\t\\tWidth:  120,\\n122:\\t\\tHeight: 40,\\n123:\\t})\\n124:\\tif err != nil {\\n125:\\t\\tt.Fatalf(\\\"NewHarness returned error: %v\\\", err)\\n126:\\t}\\n127:\\n128:\\tconfigPath := filepath.Join(t.TempDir(), \\\"amux-config.json\\\")\\n129:\\th.app.config.Paths.ConfigPath = configPath\\n130:\\th.app.updateAvailable = &update.CheckResult{\\n131:\\t\\tCurrentVersion:  \\\"v0.0.1\\\",\\n132:\\t\\tLatestVersion:   \\\"v0.0.2\\\",\\n133:\\t\\tUpdateAvailable: true,\\n134:\\t}\\n135:\\th.app.handleShowSettingsDialog()\\n136:\\tsession := h.app.ui.settingsDialogSession\\n137:\\t_ = h.app.handleThemePreview(common.ThemePreview{Theme: common.ThemeTokyoNight, Session: session})\\n138:\\n139:\\tcmd := h.app.handleTriggerUpgrade()\\n140:\\tif cmd == nil {\\n141:\\t\\tt.Fatal(\\\"expected upgrade command when update is available\\\")\\n142:\\t}\\n143:\\tif h.app.ui.settingsThemeDirty {\\n144:\\t\\tt.Fatal(\\\"expected theme dirty flag to clear after successful save on upgrade trigger\\\")\\n145:\\t}\\n146:\\n147:\\tdata, err := os.ReadFile(configPath)\\n148:\\tif err != nil {\\n149:\\t\\tt.Fatalf(\\\"expected config file to be written: %v\\\", err)\\n150:\\t}\\n151:\\tif !strings.Contains(string(data), `\\\"theme\\\": \\\"tokyo-night\\\"`) {\\n152:\\t\\tt.Fatalf(\\\"expected persisted theme in config, got %q\\\", string(data))\\n153:\\t}\\n154:}\\n155:\\n156:func TestHandleTriggerUpgrade_SaveFailureShowsWarningToast(t *testing.T) {\\n157:\\tprevTheme := common.GetCurrentTheme().ID\\n158:\\tdefer common.SetCurrentTheme(prevTheme)\\n159:\\n160:\\th, err := NewHarness(HarnessOptions{\\n161:\\t\\tMode:   HarnessCenter,\\n162:\\t\\tWidth:  120,\\n163:\\t\\tHeight: 40,\\n164:\\t})\\n165:\\tif err != nil {\\n166:\\t\\tt.Fatalf(\\\"NewHarness returned error: %v\\\", err)\\n167:\\t}\\n168:\\n169:\\t// Point to a directory path so os.WriteFile fails with \\\"is a directory\\\".\\n170:\\th.app.config.Paths.ConfigPath = t.TempDir()\\n171:\\th.app.updateAvailable = &update.CheckResult{\\n172:\\t\\tCurrentVersion:  \\\"v0.0.1\\\",\\n173:\\t\\tLatestVersion:   \\\"v0.0.2\\\",\\n174:\\t\\tUpdateAvailable: true,\\n175:\\t}\\n176:\\th.app.handleShowSettingsDialog()\\n177:\\tsession := h.app.ui.settingsDialogSession\\n178:\\t_ = h.app.handleThemePreview(common.ThemePreview{Theme: common.ThemeTokyoNight, Session: session})\\n179:\\n180:\\tcmd := h.app.handleTriggerUpgrade()\\n181:\\tif cmd == nil {\\n182:\\t\\tt.Fatal(\\\"expected command batch for upgrade trigger\\\")\\n183:\\t}\\n184:\\tif !h.app.ui.settingsThemeDirty {\\n185:\\t\\tt.Fatal(\\\"expected dirty flag to remain set after failed save\\\")\\n186:\\t}\\n187:\\tif view := h.app.ui.toast.View(); !strings.Contains(view, \\\"Failed to save theme setting\\\") {\\n188:\\t\\tt.Fatalf(\\\"expected warning toast for save failure, got %q\\\", view)\\n189:\\t}\\n190:}\\n191:\\n192:func TestHandleShowSettingsDialog_RefreshesPersistedThemeBaseline(t *testing.T) {\\n193:\\tprevTheme := common.GetCurrentTheme().ID\\n194:\\tdefer common.SetCurrentTheme(prevTheme)\\n195:\\n196:\\th, err := NewHarness(HarnessOptions{\\n197:\\t\\tMode:   HarnessCenter,\\n198:\\t\\tWidth:  120,\\n199:\\t\\tHeight: 40,\\n200:\\t})\\n201:\\tif err != nil {\\n202:\\t\\tt.Fatalf(\\\"NewHarness returned error: %v\\\", err)\\n203:\\t}\\n204:\\n205:\\t// First close fails to persist, leaving dirty state true.\\n206:\\th.app.config.Paths.ConfigPath = t.TempDir()\\n207:\\th.app.handleShowSettingsDialog()\\n208:\\tsession := h.app.ui.settingsDialogSession\\n209:\\t_ = h.app.handleThemePreview(common.ThemePreview{Theme: common.ThemeTokyoNight, Session: session})\\n210:\\t_ = h.app.handleSettingsResult(common.SettingsResult{})\\n211:\\tif !h.app.ui.settingsThemeDirty {\\n212:\\t\\tt.Fatal(\\\"expected dirty state after failed close save\\\")\\n213:\\t}\\n214:\\n215:\\t// Persist the same in-memory theme via another save path.\\n216:\\tconfigPath := filepath.Join(t.TempDir(), \\\"amux-config.json\\\")\\n217:\\th.app.config.Paths.ConfigPath = configPath\\n218:\\tif err := h.app.config.SaveUISettings(); err != nil {\\n219:\\t\\tt.Fatalf(\\\"SaveUISettings returned error: %v\\\", err)\\n220:\\t}\\n221:\\n222:\\t// Re-open settings should refresh baseline from disk (tokyo-night).\\n223:\\th.app.handleShowSettingsDialog()\\n224:\\tif h.app.ui.settingsThemeDirty {\\n225:\\t\\tt.Fatal(\\\"expected dirty state to reset after baseline refresh\\\")\\n226:\\t}\\n227:\\n228:\\t// Switching to gruvbox must be treated as dirty and persisted on close.\\n229:\\t_ = h.app.handleThemePreview(common.ThemePreview{Theme: common.ThemeGruvbox, Session: h.app.ui.settingsDialogSession})\\n230:\\tif !h.app.ui.settingsThemeDirty {\\n231:\\t\\tt.Fatal(\\\"expected dirty state for theme change away from persisted value\\\")\\n232:\\t}\\n233:\\t_ = h.app.handleSettingsResult(common.SettingsResult{})\\n234:\\n235:\\tdata, err := os.ReadFile(configPath)\\n236:\\tif err != nil {\\n237:\\t\\tt.Fatalf(\\\"expected config file to be written: %v\\\", err)\\n238:\\t}\\n239:\\tif !strings.Contains(string(data), `\\\"theme\\\": \\\"gruvbox\\\"`) {\\n240:\\t\\tt.Fatalf(\\\"expected persisted gruvbox theme in config, got %q\\\", string(data))\\n241:\\t}\\n242:}\\n243:\\n244:func TestHandleThemePreview_DropsStaleSessionAfterClose(t *testing.T) {\\n245:\\tprevTheme := common.GetCurrentTheme().ID\\n246:\\tdefer common.SetCurrentTheme(prevTheme)\\n247:\\n248:\\th, err := NewHarness(HarnessOptions{\\n249:\\t\\tMode:   HarnessCenter,\\n250:\\t\\tWidth:  120,\\n251:\\t\\tHeight: 40,\\n252:\\t})\\n253:\\tif err != nil {\\n254:\\t\\tt.Fatalf(\\\"NewHarness returned error: %v\\\", err)\\n255:\\t}\\n256:\\n257:\\tconfigPath := filepath.Join(t.TempDir(), \\\"amux-config.json\\\")\\n258:\\th.app.config.Paths.ConfigPath = configPath\\n259:\\tstartTheme := common.ThemeID(h.app.config.UI.Theme)\\n260:\\th.app.handleShowSettingsDialog()\\n261:\\tsession := h.app.ui.settingsDialogSession\\n262:\\n263:\\t// Close immediately without preview.\\n264:\\t_ = h.app.handleSettingsResult(common.SettingsResult{})\\n265:\\tif h.app.ui.settingsDialogSession == session {\\n266:\\t\\tt.Fatal(\\\"expected settings session to advance on close\\\")\\n267:\\t}\\n268:\\n269:\\t// Late preview from old session must be ignored.\\n270:\\t_ = h.app.handleThemePreview(common.ThemePreview{Theme: common.ThemeTokyoNight, Session: session})\\n271:\\tif common.ThemeID(h.app.config.UI.Theme) != startTheme {\\n272:\\t\\tt.Fatalf(\\\"expected stale preview to be ignored, got %q\\\", h.app.config.UI.Theme)\\n273:\\t}\\n274:\\tif h.app.ui.settingsThemeDirty {\\n275:\\t\\tt.Fatal(\\\"expected stale preview to not dirty settings theme state\\\")\\n276:\\t}\\n277:}]]>\\n</file>\")] } }, ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_01_qloCvT2MOfj3pIF1Lyvdf7q4\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/Documents/projects/amux/polecats/rust/badmux/i