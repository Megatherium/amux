e center pane is focused.\\n 51:func (m *Model) Focused() bool {\\n 52:\\treturn m.focused\\n 53:}\\n 54:\\n 55:// StartDraft begins a draft flow for the given ticket.\\n 56:func (m *Model) StartDraft(ticket *tickets.Ticket, ws *data.Workspace) {\\n 57:\\tm.draft = NewDraft(ticket, ws, m.config, m.styles)\\n 58:\\tm.draft.SetSize(m.contentWidth(), m.height-4)\\n 59:\\tm.draft.Focus()\\n 60:}\\n 61:\\n 62:// CancelDraft removes the active draft.\\n 63:func (m *Model) CancelDraft() {\\n 64:\\tm.draft = nil\\n 65:}\\n 66:\\n 67:// HasDraft returns whether a draft is in progress.\\n 68:func (m *Model) HasDraft() bool {\\n 69:\\treturn m.draft != nil\\n 70:}\\n 71:\\n 72:// SetWorkspace sets the active workspace.\\n 73:func (m *Model) SetWorkspace(ws *data.Workspace) {\\n 74:\\tm.setWorkspace(ws)\\n 75:\\tm.syncPostWriteVisibility()\\n 76:\\tif ws == nil {\\n 77:\\t\\treturn\\n 78:\\t}\\n 79:\\tm.markTabFocused(m.workspaceID(), m.getActiveTabIdx())\\n 80:}\\n 81:\\n 82:// HasTabs returns whether there are any tabs for the current workspace.\\n 83:func (m *Model) HasTabs() bool {\\n 84:\\treturn len(m.getTabs()) > 0\\n 85:}\\n 86:\\n 87:// SetCanFocusRight controls whether focus-right hints should be shown.\\n 88:func (m *Model) SetCanFocusRight(can bool) {\\n 89:\\tm.canFocusRight = can\\n 90:}\\n 91:\\n 92:// SetShowKeymapHints controls whether helper text is rendered.\\n 93:func (m *Model) SetShowKeymapHints(show bool) {\\n 94:\\tm.showKeymapHints = show\\n 95:}\\n 96:\\n 97:// SetStyles updates the component's styles (for theme changes).\\n 98:func (m *Model) SetStyles(styles common.Styles) {\\n 99:\\tm.styles = styles\\n100:\\t// Propagate to all viewers in tabs\\n101:\\tfor _, tabs := range m.tabsByWorkspace {\\n102:\\t\\tfor _, tab := range tabs {\\n103:\\t\\t\\tif tab == nil {\\n104:\\t\\t\\t\\tcontinue\\n105:\\t\\t\\t}\\n106:\\t\\t\\ttab.mu.Lock()\\n107:\\t\\t\\tif tab.DiffViewer != nil {\\n108:\\t\\t\\t\\ttab.DiffViewer.SetStyles(styles)\\n109:\\t\\t\\t}\\n110:\\t\\t\\ttab.mu.Unlock()\\n111:\\t\\t}\\n112:\\t}\\n113:}\\n114:\\n115:// SetMsgSink sets a callback for PTY messages.\\n116:func (m *Model) SetMsgSink(sink func(tea.Msg)) {\\n117:\\tm.msgSink = sink\\n118:\\tm.msgSinkTry = nil\\n119:}\\n120:\\n121:// SetMsgSinkTry sets a callback for PTY messages that reports whether enqueue succeeded.\\n122:func (m *Model) SetMsgSinkTry(sink func(tea.Msg) bool) {\\n123:\\tm.msgSinkTry = sink\\n124:\\tif sink == nil {\\n125:\\t\\tm.msgSink = nil\\n126:\\t\\treturn\\n127:\\t}\\n128:\\tm.msgSink = func(msg tea.Msg) {\\n129:\\t\\t_ = sink(msg)\\n130:\\t}\\n131:}\\n132:\\n133:// SetSize sets the center pane size.\\n134:func (m *Model) SetSize(width, height int) {\\n135:\\tm.width = width\\n136:\\tm.height = height\\n137:\\n138:\\tif m.draft != nil {\\n139:\\t\\tm.draft.SetSize(m.contentWidth(), m.height-4)\\n140:\\t}\\n141:\\n142:\\t// Use centralized metrics for terminal sizing\\n143:\\ttm := m.terminalMetrics()\\n144:\\ttermWidth := tm.Width\\n145:\\ttermHeight := tm.Height\\n146:\\n147:\\t// CommitViewer uses the same dimensions\\n148:\\tviewerWidth := termWidth\\n149:\\tviewerHeight := termHeight\\n150:\\n151:\\t// Update all terminals across all workspaces\\n152:\\tfor _, tabs := range m.tabsByWorkspace {\\n153:\\t\\tfor _, tab := range tabs {\\n154:\\t\\t\\ttab.mu.Lock()\\n155:\\t\\t\\tif tab.Terminal != nil {\\n156:\\t\\t\\t\\tif tab.Terminal.Width != termWidth || tab.Terminal.Height != termHeight {\\n157:\\t\\t\\t\\t\\ttab.Terminal.Resize(termWidth, termHeight)\\n158:\\t\\t\\t\\t}\\n159:\\t\\t\\t}\\n160:\\t\\t\\tif tab.DiffViewer != nil {\\n161:\\t\\t\\t\\ttab.DiffViewer.SetSize(viewerWidth, viewerHeight)\\n162:\\t\\t\\t}\\n163:\\t\\t\\ttab.mu.Unlock()\\n164:\\t\\t\\tm.resizePTY(tab, termHeight, termWidth)\\n165:\\t\\t}\\n166:\\t}\\n167:}\\n168:\\n169:// SetOffset sets the X offset of the pane from screen left (for mouse coordinate conversion).\\n170:func (m *Model) SetOffset(x int) {\\n171:\\tm.offsetX = x\\n172:}\\n173:\\n174:func (m *Model) setActiveTerminalCursorVisibility(visible bool) {\\n175:\\ttabs := m.getTabs()\\n176:\\tactiveIdx := m.getActiveTabIdx()\\n177:\\tif activeIdx < 0 || activeIdx >= len(tabs) {\\n178:\\t\\treturn\\n179:\\t}\\n180:\\ttab := tabs[activeIdx]\\n181:\\tif tab == nil || tab.isClosed() {\\n182:\\t\\treturn\\n183:\\t}\\n184:\\ttab.mu.Lock()\\n185:\\tdefer tab.mu.Unlock()\\n186:\\tif tab.Terminal != nil {\\n187:\\t\\ttab.Terminal.ShowCursor = visible\\n188:\\t}\\n189:\\t// Invalidate cached snapshot so focus transitions cannot reuse stale\\n190:\\t// cursor-painted frames.\\n191:\\ttab.cachedSnap = nil\\n192:\\ttab.cachedVersion = 0\\n193:\\ttab.cachedShowCursor = false\\n194:\\ttab.cachedRecentLocalInput = false\\n195:\\ttab.cachedRestrictCursor = false\\n196:}\\n197:\\n198:func (m *Model) syncActiveDiffViewerFocus(focused bool) {\\n199:\\ttabs := m.getTabs()\\n200:\\tactiveIdx := m.getActiveTabIdx()\\n201:\\tif activeIdx < 0 || activeIdx >= len(tabs) {\\n202:\\t\\treturn\\n203:\\t}\\n204:\\ttab := tabs[activeIdx]\\n205:\\tif tab == nil || tab.isClosed() {\\n206:\\t\\treturn\\n207:\\t}\\n208:\\ttab.mu.Lock()\\n209:\\tdefer tab.mu.Unlock()\\n210:\\tif tab.DiffViewer != nil {\\n211:\\t\\ttab.DiffViewer.SetFocused(focused)\\n212:\\t}\\n213:}\\n214:\\n215:// Close cleans up all resources.\\n216:func (m *Model) Close() {\\n217:\\tfor _, tabs := range m.tabsByWorkspace {\\n218:\\t\\tfor _, tab := range tabs {\\n219:\\t\\t\\ttab.markClosing()\\n220:\\t\\t\\tm.stopPTYReader(tab)\\n221:\\t\\t\\ttab.mu.Lock()\\n222:\\t\\t\\tif tab.ptyTraceFile != nil {\\n223:\\t\\t\\t\\t_ = tab.ptyTraceFile.Close()\\n224:\\t\\t\\t\\ttab.ptyTraceFile = nil\\n225:\\t\\t\\t\\ttab.ptyTraceClosed = true\\n226:\\t\\t\\t}\\n227:\\t\\t\\ttab.resetPTYStateLocked()\\n228:\\t\\t\\ttab.DiffViewer = nil\\n229:\\t\\t\\ttab.Terminal = nil\\n230:\\t\\t\\ttab.cachedSnap = nil\\n231:\\t\\t\\ttab.Workspace = nil\\n232:\\t\\t\\ttab.Running = false\\n233:\\t\\t\\ttab.mu.Unlock()\\n234:\\t\\t\\ttab.markClosed()\\n235:\\t\\t}\\n236:\\t}\\n237:\\tif m.agentManager != nil {\\n238:\\t\\tm.agentManager.CloseAll()\\n239:\\t}\\n240:}\\n241:\\n242:// TickSpinner advances the spinner animation frame.\\n243:func (m *Model) TickSpinner() {\\n244:\\tm.spinnerFrame++\\n245:}\\n246:\\n247:// screenToTerminal converts screen coordinates to terminal coordinates\\n248:// Returns the terminal X, Y and whether the coordinates are within the terminal content area.\\n249:func (m *Model) screenToTerminal(screenX, screenY int) (termX, termY int, inBounds bool) {\\n250:\\t// Use centralized metrics for consistent geometry\\n251:\\ttm := m.terminalMetrics()\\n252:\\n253:\\t// X offset includes pane position + border + padding\\n254:\\tcontentStartX := m.offsetX + tm.ContentStartX\\n255:\\t// Y offset is just border + tab bar (pane Y starts at 0)\\n256:\\tcontentStartY := tm.ContentStartY\\n257:\\n258:\\t// Convert screen coordinates to terminal coordinates\\n259:\\ttermX = screenX - contentStartX\\n260:\\ttermY = screenY - contentStartY\\n261:\\n262:\\t// Check bounds\\n263:\\tinBounds = termX >= 0 && termX < tm.Width && termY >= 0 && termY < tm.Height\\n264:\\treturn termX, termY, inBounds\\n265:}]]>\\n</file>\")] } }, ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_01_EzxkHCC3p0AnGKcfQMywLWVP\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/gt/badmux/polecats/rust/badmux/internal/ui/center/model_pty_config.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"85\\\"\\n><![CDATA[ 1:package center\\n 2:\\n 3:import \\\"time\\\"\\n 4:\\n 5:// PTY constants\\n 6:const (\\n 7:\\tptyFlushQuiet       = 12 * time.Millisecond\\n 8:\\tptyFlushMaxInterval = 48 * time.Millisecond\\n 9:\\tptyFlushQuietAlt    = 24 * time.Millisecond\\n10:\\tptyFlushMaxAlt      = 96 * time.Millisecond\\n11:\\t// Inactive tabs still need to advance their terminal state, but can flush less frequently.\\n12:\\tptyFlushInactiveMultiplier          = 4\\n13:\\tptyFlushInactiveHeavyMultiplier     = 8\\n14:\\tptyFlushInactiveVeryHeavyMultiplier = 12\\n15:\\tptyFlushInactiveMaxIntervalCap      = 250 * time.Millisecond\\n16:\\tptyHeavyLoadTabThreshold            = 4\\n17:\\tptyVeryHeavyLoadTabThreshold        = 8\\n18:\\tptyLoadSampleInterval               = 100 * time.Millisecond\\n19:\\tptyFlushChunkSize                   = 32 * 1024\\n20:\\t// Active tab catch-up should drain backlog quickly to avoid visible replay.\\n21:\\tptyFlushChunkSizeActive = 256 * 1024\\n22:\\t// Catch-up can exceed the steady-state active cap, but it still needs a\\n23:\\t// ceiling so a single actor write cannot monopolize input/scroll handling.\\n24:\\tptyFlushChunkSizeCatchUp = 1024 * 1024\\n25:\\tptyReadBufferSize        = 32 * 1024\\n26:\\tptyReadQueueSize         = 64\\n27:\\tptyFrameInterval         = time.Second / 24\\n28:\\tptyMaxPendingBytes       = 512 * 1024\\n29:\\tptyMaxBufferedBytes      = 8 * 1024 * 1024\\n30:\\tptyReaderStallTimeout    = 10 * time.Second\\n31:\\ttabActorStallTimeout     = 10 * time.Second\\n32:\\tptyRestartMax            = 5\\n33:\\tptyRestartWindow         = time.Minute\\n34:\\n35:\\t// Backpressure thresholds (inspired by tmux's TTY_BLOCK_START/STOP)\\n36:\\t// When pending output exceeds this, we throttle rendering frequency\\n37:\\tptyBackpressureMultiplier = 8 // threshold = multiplier * width * height\\n38:\\tptyBackpressureFlushFloor = 32 * time.Millisecond\\n39:)\\n40:\\n41:// PTYOutput is a message containing PTY output data\\n42:type PTYOutput struct {\\n43:\\tWorkspaceID string\\n44:\\tTabID       TabID\\n45:\\tData        []byte\\n46:}\\n47:\\n48:// PTYTick triggers a PTY read\\n49:type PTYTick struct {\\n50:\\tWorkspaceID string\\n51:\\tTabID       TabID\\n52:}\\n53:\\n54:// PTYFlush applies buffered PTY output for a tab.\\n55:type PTYFlush struct {\\n56:\\tWorkspaceID string\\n57:\\tTabID       TabID\\n58:\\tCatchUp     bool\\n59:}\\n60:\\n61:// PTYCursorRefresh re-renders chat cursor policy when time-based windows expire.\\n62:type PTYCursorRefresh struct {\\n63:\\tWorkspaceID string\\n64:\\tTabID       TabID\\n65:\\tGen         uint64\\n66:}\\n67:\\n68:// PTYStopped signals that the PTY read loop has stopped (terminal closed or error)\\n69:type PTYStopped struct {\\n70:\\tWorkspaceID string\\n71:\\tTabID       TabID\\n72:\\tErr         error\\n73:}\\n74:\\n75:// PTYRestart requests restarting a PTY reader for a tab.\\n76:type PTYRestart struct {\\n77:\\tWorkspaceID string\\n78:\\tTabID       TabID\\n79:}\\n80:\\n81:type selectionScrollTick struct {\\n82:\\tWorkspaceID string\\n83:\\tTabID       TabID\\n84:\\tGen         uint64\\n85:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
