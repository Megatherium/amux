 cmd tea.Cmd }\\n 84:\\n 85:type TabInputFailed struct {\\n 86:\\tTabID       TabID\\n 87:\\tWorkspaceID string\\n 88:\\tErr         error\\n 89:}\\n 90:\\n 91:func (m *Model) shouldPostWriteRedraw(tab *Tab) bool {\\n 92:\\treturn tab != nil && (m.isChatTab(tab) || tab.postWriteVisible())\\n 93:}\\n 94:\\n 95:func (m *Model) sendTabEvent(ev tabEvent) bool {\\n 96:\\tif m == nil || m.tabEvents == nil {\\n 97:\\t\\treturn false\\n 98:\\t}\\n 99:\\tif ev.tab == nil {\\n100:\\t\\tperf.Count(\\\"tab_event_drop_missing\\\", 1)\\n101:\\t\\treturn false\\n102:\\t}\\n103:\\tif ev.tab != nil && ev.tab.isClosed() {\\n104:\\t\\tperf.Count(\\\"tab_event_drop_closed\\\", 1)\\n105:\\t\\treturn ev.kind != tabEventWriteOutput\\n106:\\t}\\n107:\\tif shouldDropTabEvent(m.tabEvents, ev.kind) {\\n108:\\t\\tperf.Count(\\\"tab_event_drop_backpressure\\\", 1)\\n109:\\t\\treturn false\\n110:\\t}\\n111:\\tselect {\\n112:\\tcase m.tabEvents <- ev:\\n113:\\t\\treturn true\\n114:\\tdefault:\\n115:\\t\\tperf.Count(\\\"tab_event_drop\\\", 1)\\n116:\\t}\\n117:\\treturn false\\n118:}\\n119:\\n120:func shouldDropTabEvent(ch chan tabEvent, kind tabEventKind) bool {\\n121:\\tif ch == nil {\\n122:\\t\\treturn true\\n123:\\t}\\n124:\\tswitch kind {\\n125:\\tcase tabEventSelectionUpdate, tabEventSelectionScrollTick, tabEventScrollBy, tabEventScrollPage:\\n126:\\tdefault:\\n127:\\t\\treturn false\\n128:\\t}\\n129:\\tcapacity := cap(ch)\\n130:\\tif capacity == 0 {\\n131:\\t\\treturn false\\n132:\\t}\\n133:\\treturn len(ch) >= (capacity*3)/4\\n134:}\\n135:\\n136:func shouldPostTabActorRedraw(kind tabEventKind) bool {\\n137:\\tswitch kind {\\n138:\\tcase tabEventSelectionStart,\\n139:\\t\\ttabEventSelectionUpdate,\\n140:\\t\\ttabEventSelectionFinish,\\n141:\\t\\ttabEventScrollBy,\\n142:\\t\\ttabEventSelectionClearAndNotify,\\n143:\\t\\ttabEventSelectionScrollTick,\\n144:\\t\\ttabEventScrollToBottom,\\n145:\\t\\ttabEventScrollPage,\\n146:\\t\\ttabEventScrollToTop,\\n147:\\t\\ttabEventDiffInput:\\n148:\\t\\tre