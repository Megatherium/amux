{"timestamp":"2264.611644346s","level":"DEBUG","fields":{"message":"Adding tool results to context","results":"[ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_00_z4AB7wmiu72dMXyHjzjRIxcR\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/gt/badmux/polecats/rust/badmux/internal/app/app_input_messages_dialogs.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"119\\\"\\n><![CDATA[  1:package app\\n  2:\\n  3:import (\\n  4:\\t\\\"sort\\\"\\n  5:\\n  6:\\ttea \\\"charm.land/bubbletea/v2\\\"\\n  7:\\n  8:\\t\\\"github.com/andyrewlee/amux/internal/data\\\"\\n  9:\\t\\\"github.com/andyrewlee/amux/internal/messages\\\"\\n 10:\\t\\\"github.com/andyrewlee/amux/internal/tickets\\\"\\n 11:)\\n 12:\\n 13:// handleTicketSelected handles a ticket selection from the dashboard,\\n 14:// starting the draft flow in the center pane.\\n 15:func (a *App) handleTicketSelected(msg messages.TicketSelectedMsg) []tea.Cmd {\\n 16:\\tif msg.Ticket == nil {\\n 17:\\t\\treturn nil\\n 18:\\t}\\n 19:\\n 20:\\tproject := msg.Project\\n 21:\\tif project == nil {\\n 22:\\t\\treturn []tea.Cmd{a.ui.toast.ShowError(\\\"No project associated with this ticket\\\")}\\n 23:\\t}\\n 24:\\n 25:\\tvar mainWS *data.Workspace\\n 26:\\tfor i := range project.Workspaces {\\n 27:\\t\\tws := &project.Workspaces[i]\\n 28:\\t\\tif ws.IsMainBranch() || ws.IsPrimaryCheckout() {\\n 29:\\t\\t\\tmainWS = ws\\n 30:\\t\\t\\tbreak\\n 31:\\t\\t}\\n 32:\\t}\\n 33:\\tif mainWS == nil {\\n 34:\\t\\treturn []tea.Cmd{a.ui.toast.ShowError(\\\"No workspace found for project \\\" + project.Name)}\\n 35:\\t}\\n 36:\\n 37:\\tvar cmds []tea.Cmd\\n 38:\\tif a.activeWorkspace == nil || string(a.activeWorkspace.ID()) != string(mainWS.ID()) {\\n 39:\\t\\tcmds = append(cmds, a.handleWorkspaceActivated(messages.WorkspaceActivated{\\n 40:\\t\\t\\tProject:   project,\\n 41:\\t\\t\\tWorkspace: mainWS,\\n 42:\\t\\t})...)\\n 43:\\t}\\n 44:\\n 45:\\ta.ui.center.StartDraft(msg.Ticket, mainWS)\\n 46:\\tcmds = append(cmds, a.focusPane(messages.PaneCenter))\\n 47:\\treturn cmds\\n 48:}\\n 49:\\n 50:// handleTicketPreview updates the preview state when the cursor hovers over\\n 51:// a ticket row in the dashboard. When no agent tabs are open, the ticket info\\n 52:// is shown in the center pane. When agent tabs exist, the info is shown in the\\n 53:// sidebar's ticket tab (without auto-focusing the sidebar).\\n 54:func (a *App) handleTicketPreview(msg messages.TicketPreviewMsg) {\\n 55:\\ta.ui.previewTicket = msg.Ticket\\n 56:\\ta.ui.previewProject = msg.Project\\n 57:\\n 58:\\t// Forward the preview to the sidebar for the ticket tab\\n 59:\\tif a.ui.sidebar != nil {\\n 60:\\t\\ta.ui.sidebar.SetPreviewTicket(msg.Ticket)\\n 61:\\t}\\n 62:}\\n 63:\\n 64:// sortTicketsHierarchically reorders tickets so that child tickets\\n 65:// (tickets with a non-empty ParentID) appear immediately after\\n 66:// their parent.\\n 67:func sortTicketsHierarchically(ts []tickets.Ticket) []tickets.Ticket {\\n 68:\\tif len(ts) == 0 {\\n 69:\\t\\treturn ts\\n 70:\\t}\\n 71:\\n 72:\\t// Build parent index map: ticket ID → position\\n 73:\\tparentPos := make(map[string]int, len(ts))\\n 74:\\tfor i, t := range ts {\\n 75:\\t\\tparentPos[t.ID] = i\\n 76:\\t}\\n 77:\\n 78:\\t// Separate children from parents\\n 79:\\tvar ordered []tickets.Ticket\\n 80:\\tchildrenOf := make(map[int][]tickets.Ticket) // parent position → children\\n 81:\\n 82:\\tfor _, t := range ts {\\n 83:\\t\\tif t.ParentID == \\\"\\\" {\\n 84:\\t\\t\\t// Parent or root ticket\\n 85:\\t\\t\\tordered = append(ordered, t)\\n 86:\\t\\t} else {\\n 87:\\t\\t\\t// Child ticket - defer placement\\n 88:\\t\\t\\tpidx, ok := parentPos[t.ParentID]\\n 89:\\t\\t\\tif ok {\\n 90:\\t\\t\\t\\tchildrenOf[pidx] = append(childrenOf[pidx], t)\\n 91:\\t\\t\\t} else {\\n 92:\\t\\t\\t\\t// Parent not in this batch, treat as root\\n 93:\\t\\t\\t\\tordered = append(ordered, t)\\n 94:\\t\\t\\t}\\n 95:\\t\\t}\\n 96:\\t}\\n 97:\\n 98:\\t// Insert children after their parents (iterate in reverse to preserve order)\\n 99:\\tfor i := len(ordered) - 1; i >= 0; i-- {\\n100:\\t\\t// Find the original position of this parent to look up children\\n101:\\t\\tfor pidx, children := range childrenOf {\\n102:\\t\\t\\tif pidx < 0 || pidx >= len(ts) {\\n103:\\t\\t\\t\\tcontinue\\n104:\\t\\t\\t}\\n105:\\t\\t\\tif ts[pidx].ID == ordered[i].ID {\\n106:\\t\\t\\t\\t// Insert children directly after this parent\\n107:\\t\\t\\t\\tsort.Slice(children, func(a, b int) bool {\\n108:\\t\\t\\t\\t\\treturn children[a].CreatedAt.Before(children[b].CreatedAt)\\n109:\\t\\t\\t\\t})\\n110:\\t\\t\\t\\tinsertAt := i + 1\\n111:\\t\\t\\t\\tordered = append(ordered[:insertAt], append(children, ordered[insertAt:]...)...)\\n112:\\t\\t\\t\\tdelete(childrenOf, pidx)\\n113:\\t\\t\\t\\tbreak\\n114:\\t\\t\\t}\\n115:\\t\\t}\\n116:\\t}\\n117:\\n118:\\treturn ordered\\n119:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
