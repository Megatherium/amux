\\n  9:)\\n 10:\\n 11:func TestUpdatePTYFlush_UsesLargerChunkForActiveTab(t *testing.T) {\\n 12:\\tm := newTestModel()\\n 13:\\tws := newTestWorkspace(\\\"ws\\\", \\\"/repo/ws\\\")\\n 14:\\twsID := string(ws.ID())\\n 15:\\ttab := &Tab{\\n 16:\\t\\tID:                TabID(\\\"tab-active\\\"),\\n 17:\\t\\tWorkspace:         ws,\\n 18:\\t\\tTerminal:          vterm.New(80, 24),\\n 19:\\t\\tRunning:           true,\\n 20:\\t\\tlastOutputAt:      time.Now().Add(-time.Second),\\n 21:\\t\\tflushPendingSince: time.Now().Add(-time.Second),\\n 22:\\t\\tpendingOutput:     bytes.Repeat([]byte(\\\"x\\\"), ptyFlushChunkSizeActive+17),\\n 23:\\t}\\n 24:\\tm.tabsByWorkspace[wsID] = []*Tab{tab}\\n 25:\\tm.activeTabByWorkspace[wsID] = 0\\n 26:\\tm.workspace = ws\\n 27:\\n 28:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: tab.ID})\\n 29:\\n 30:\\tif got, want := len(tab.pendingOutput), 17; got != want {\\n 31:\\t\\tt.Fatalf(\\\"pending output = %d, want %d\\\", got, want)\\n 32:\\t}\\n 33:}\\n 34:\\n 35:func TestUpdatePTYFlush_CatchUpWithoutActorKeepsActiveChunkCap(t *testing.T) {\\n 36:\\tm := newTestModel()\\n 37:\\tws := newTestWorkspace(\\\"ws\\\", \\\"/repo/ws\\\")\\n 38:\\twsID := string(ws.ID())\\n 39:\\ttab := &Tab{\\n 40:\\t\\tID:                   TabID(\\\"tab-active-catch-up\\\"),\\n 41:\\t\\tWorkspace:            ws,\\n 42:\\t\\tTerminal:             vterm.New(80, 24),\\n 43:\\t\\tRunning:              true,\\n 44:\\t\\tlastOutputAt:         time.Now().Add(-time.Second),\\n 45:\\t\\tflushPendingSince:    time.Now().Add(-time.Second),\\n 46:\\t\\tpendingOutput:        bytes.Repeat([]byte(\\\"x\\\"), ptyFlushChunkSizeActive+17),\\n 47:\\t\\tcatchUpPendingOutput: true,\\n 48:\\t\\tcatchUpTargetBytes:   ptyFlushChunkSizeActive + 17,\\n 49:\\t\\tptyBytesReceived:     ptyFlushChunkSizeActive + 17,\\n 50:\\t}\\n 51:\\tm.tabsByWorkspace[wsID] = []*Tab{tab}\\n 52:\\tm.activeTabByWorkspace[wsID] = 0\\n 53:\\tm.workspace = ws\\n 54:\\n 55:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: tab.ID, CatchUp: true})\\n 56:\\n 57:\\tif got, want := len(tab.pendingOutput), 17; got != want {\\n 58:\\t\\tt.Fatalf(\\\"pending output = %d, want %d after synchronous catch-up flush\\\", got, want)\\n 59:\\t}\\n 60:}\\n 61:\\n 62:func TestUpdatePTYFlush_FastForwardsCatchUpActiveTabViaActor(t *testing.T) {\\n 63:\\tm := newTestModel()\\n 64:\\tm.setTabActorReady()\\n 65:\\tm.tabEvents = make(chan tabEvent, 1)\\n 66:\\n 67:\\tws := newTestWorkspace(\\\"ws\\\", \\\"/repo/ws\\\")\\n 68:\\twsID := string(ws.ID())\\n 69:\\tpayload := bytes.Repeat([]byte(\\\"x\\\"), ptyFlushChunkSizeActive+17)\\n 70:\\ttab := &Tab{\\n 71:\\t\\tID:                   TabID(\\\"tab-active-catch-up-actor\\\"),\\n 72:\\t\\tWorkspace:            ws,\\n 73:\\t\\tTerminal:             vterm.New(80, 24),\\n 74:\\t\\tRunning:              true,\\n 75:\\t\\tlastOutputAt:         time.Now().Add(-time.Second),\\n 76:\\t\\tflushPendingSince:    time.Now().Add(-time.Second),\\n 77:\\t\\tpendingOutput:        append([]byte(nil), payload...),\\n 78:\\t\\tcatchUpPendingOutput: true,\\n 79:\\t\\tcatchUpTargetBytes:   uint64(len(payload)),\\n 80:\\t\\tptyBytesReceived:     uint64(len(payload)),\\n 81:\\t}\\n 82:\\tm.tabsByWorkspace[wsID] = []*Tab{tab}\\n 83:\\tm.activeTabByWorkspace[wsID] = 0\\n 84:\\tm.workspace = ws\\n 85:\\n 86:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: tab.ID, CatchUp: true})\\n 87:\\n 88:\\tselect {\\n 89:\\tcase ev := <-m.tabEvents:\\n 90:\\t\\tif ev.kind != tabEventWriteOutput {\\n 91:\\t\\t\\tt.Fatalf(\\\"expected tabEventWriteOutput, got %v\\\", ev.kind)\\n 92:\\t\\t}\\n 93:\\t\\tif got, want := len(ev.output), len(payload); got != want {\\n 94:\\t\\t\\tt.Fatalf(\\\"queued output len = %d, want %d\\\", got, want)\\n 95:\\t\\t}\\n 96:\\t\\tif ev.hasMoreBuffered {\\n 97:\\t\\t\\tt.Fatalf(\\\"expected catch-up flush to queue the full backlog in one write\\\")\\n 98:\\t\\t}\\n 99:\\tdefault:\\n100:\\t\\tt.Fatalf(\\\"expected actor-backed catch-up flush to queue a write event\\\")\\n101:\\t}\\n102:\\n103:\\tif got := len(tab.pendingOutput); got != 0 {\\n104:\\t\\tt.Fatalf(\\\"pending output = %d, want 0 after actor catch-up flush\\\", got)\\n105:\\t}\\n106:}\\n107:\\n108:func TestUpdatePTYFlush_CatchUpUsesBoundedActorChunk(t *testing.T) {\\n109:\\tm := newTestModel()\\n110:\\tm.setTabActorReady()\\n111:\\tm.tabEvents = make(chan tabEvent, 1)\\n112:\\n113:\\tws := newTestWorkspace(\\\"ws\\\", \\\"/repo/ws\\\")\\n114:\\twsID := string(ws.ID())\\n115:\\tpayload := bytes.Repeat([]byte(\\\"x\\\"), ptyFlushChunkSizeCatchUp+17)\\n116:\\ttab := &Tab{\\n117:\\t\\tID:                   TabID(\\\"tab-active-catch-up-bounded\\\"),\\n118:\\t\\tWorkspace:            ws,\\n119:\\t\\tTerminal:             vterm.New(80, 24),\\n120:\\t\\tRunning:              true,\\n121:\\t\\tlastOutputAt:         time.Now().Add(-time.Second),\\n122:\\t\\tflushPendingSince:    time.Now().Add(-time.Second),\\n123:\\t\\tpendingOutput:        append([]byte(nil), payload...),\\n124:\\t\\tcatchUpPendingOutput: true,\\n125:\\t\\tcatchUpTargetBytes:   uint64(len(payload)),\\n126:\\t\\tptyBytesReceived:     uint64(len(payload)),\\n127:\\t}\\n128:\\tm.tabsByWorkspace[wsID] = []*Tab{tab}\\n129:\\tm.activeTabByWorkspace[wsID] = 0\\n130:\\tm.workspace = ws\\n131:\\n132:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: tab.ID, CatchUp: true})\\n133:\\n134:\\tselect {\\n135:\\tcase ev := <-m.tabEvents:\\n136:\\t\\tif ev.kind != tabEventWriteOutput {\\n137:\\t\\t\\tt.Fatalf(\\\"expected tabEventWriteOutput, got %v\\\", ev.kind)\\n138:\\t\\t}\\n139:\\t\\tif got, want := len(ev.output), ptyFlushChunkSizeCatchUp; got != want {\\n140:\\t\\t\\tt.Fatalf(\\\"queued output len = %d, want %d\\\", got, want)\\n141:\\t\\t}\\n142:\\t\\tif !ev.hasMoreBuffered {\\n143:\\t\\t\\tt.Fatalf(\\\"expected bounded catch-up write to leave buffered output behind\\\")\\n144:\\t\\t}\\n145:\\tdefault:\\n146:\\t\\tt.Fatalf(\\\"expected bounded catch-up flush to queue a write event\\\")\\n147:\\t}\\n148:\\n149:\\tif got, want := len(tab.pendingOutput), 17; got != want {\\n150:\\t\\tt.Fatalf(\\\"pending output = %d, want %d after bounded actor catch-up flush\\\", got, want)\\n151:\\t}\\n152:}\\n153:\\n154:func TestUpdatePTYFlush_PendingCatchUpOverridesStaleFlushMessage(t *testing.T) {\\n155:\\tm := newTestModel()\\n156:\\tm.setTabActorReady()\\n157:\\tm.tabEvents = make(chan tabEvent, 1)\\n158:\\n159:\\tws := newTestWorkspace(\\\"ws\\\", \\\"/repo/ws\\\")\\n160:\\twsID := string(ws.ID())\\n161:\\tpayload := bytes.Repeat([]byte(\\\"x\\\"), ptyFlushChunkSizeCatchUp+17)\\n162:\\ttab := &Tab{\\n163:\\t\\tID:                   TabID(\\\"tab-active-catch-up-stale-flush\\\"),\\n164:\\t\\tWorkspace:            ws,\\n165:\\t\\tTerminal:             vterm.New(80, 24),\\n166:\\t\\tRunning:              true,\\n167:\\t\\tlastOutputAt:         time.Now().Add(-time.Second),\\n168:\\t\\tflushPendingSince:    time.Now().Add(-time.Second),\\n169:\\t\\tpendingOutput:        append([]byte(nil), payload...),\\n170:\\t\\tcatchUpPendingOutput: true,\\n171:\\t\\tcatchUpTargetBytes:   uint64(len(payload)),\\n172:\\t\\tptyBytesReceived:     uint64(len(payload)),\\n173:\\t}\\n174:\\tm.tabsByWorkspace[wsID] = []*Tab{tab}\\n175:\\tm.activeTabByWorkspace[wsID] = 0\\n176:\\tm.workspace = ws\\n177:\\n178:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: tab.ID})\\n179:\\n180:\\tselect {\\n181:\\tcase ev := <-m.tabEvents:\\n182:\\t\\tif ev.kind != tabEventWriteOutput {\\n183:\\t\\t\\tt.Fatalf(\\\"expected tabEventWriteOutput, got %v\\\", ev.kind)\\n184:\\t\\t}\\n185:\\t\\tif got, want := len(ev.output), ptyFlushChunkSizeCatchUp; got != want {\\n186:\\t\\t\\tt.Fatalf(\\\"queued output len = %d, want %d\\\", got, want)\\n187:\\t\\t}\\n188:\\tdefault:\\n189:\\t\\tt.Fatalf(\\\"expected stale flush message to honor latched catch-up state\\\")\\n190:\\t}\\n191:\\n192:\\tif got, want := len(tab.pendingOutput), 17; got != want {\\n193:\\t\\tt.Fatalf(\\\"pending output = %d, want %d after latched catch-up flush\\\", got, want)\\n194:\\t}\\n195:}\\n196:\\n197:func TestUpdatePTYFlush_StaleCatchUpMessageDoesNotRelatchAfterBacklogDrains(t *testing.T) {\\n198:\\tm := newTestModel()\\n199:\\tm.setTabActorReady()\\n200:\\tm.tabEvents = make(chan tabEvent, 1)\\n201:\\n202:\\tws := newTestWorkspace(\\\"ws\\\", \\\"/repo/ws\\\")\\n203:\\twsID := string(ws.ID())\\n204:\\ttab := &Tab{\\n205:\\t\\tID:                TabID(\\\"tab-active-catch-up-stale-relatch\\\"),\\n206:\\t\\tWorkspace:         ws,\\n207:\\t\\tTerminal:          vterm.New(80, 24),\\n208:\\t\\tRunning:           true,\\n209:\\t\\tlastOutputAt:      time.Now().Add(-time.Second),\\n210:\\t\\tflushPendingSince: time.Now().Add(-time.Second),\\n211:\\t}\\n212:\\tm.tabsByWorkspace[wsID] = []*Tab{tab}\\n213:\\tm.activeTabByWorkspace[wsID] = 0\\n214:\\tm.workspace = ws\\n215:\\n216:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: tab.ID, CatchUp: true})\\n217:\\tif tab.catchUpPendingOutput {\\n218:\\t\\tt.Fatalf(\\\"expected stale catch-up message with empty backlog not to relatch catch-up state\\\")\\n219:\\t}\\n220:\\n221:\\ttab.pendingOutput = bytes.Repeat([]byte(\\\"x\\\"), ptyFlushChunkSizeActive+17)\\n222:\\ttab.lastOutputAt = time.Now().Add(-time.Second)\\n223:\\ttab.flushPendingSince = time.Now().Add(-time.Second)\\n224:\\n225:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: tab.ID})\\n226:\\n227:\\tselect {\\n228:\\tcase ev := <-m.tabEvents:\\n229:\\t\\tif got, want := len(ev.output), ptyFlushChunkSizeActive; got != want {\\n230:\\t\\t\\tt.Fatalf(\\\"queued output len = %d, want normal active cap %d after stale catch-up\\\", got, want)\\n231:\\t\\t}\\n232:\\tdefault:\\n233:\\t\\tt.Fatalf(\\\"expected active flush after new backlog\\\")\\n234:\\t}\\n235:}\\n236:\\n237:func TestUpdatePTYFlush_UsesBaseChunkForInactiveTab(t *testing.T) {\\n238:\\tm := newTestModel()\\n239:\\tws := newTestWorkspace(\\\"ws\\\", \\\"/repo/ws\\\")\\n240:\\twsID := string(ws.ID())\\n241:\\tactive := &Tab{\\n242:\\t\\tID:        TabID(\\\"tab-active\\\"),\\n243:\\t\\tWorkspace: ws,\\n244:\\t\\tTerminal:  vterm.New(80, 24),\\n245:\\t\\tRunning:   true,\\n246:\\t}\\n247:\\tinactive := &Tab{\\n248:\\t\\tID:                TabID(\\\"tab-inactive\\\"),\\n249:\\t\\tWorkspace:         ws,\\n250:\\t\\tTerminal:          vterm.New(80, 24),\\n251:\\t\\tRunning:           true,\\n252:\\t\\tlastOutputAt:      time.Now().Add(-time.Second),\\n253:\\t\\tflushPendingSince: time.Now().Add(-time.Second),\\n254:\\t\\tpendingOutput:     bytes.Repeat([]byte(\\\"x\\\"), ptyFlushChunkSize+17),\\n255:\\t}\\n256:\\tm.tabsByWorkspace[wsID] = []*Tab{active, inactive}\\n257:\\tm.activeTabByWorkspace[wsID] = 0\\n258:\\tm.workspace = ws\\n259:\\n260:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: inactive.ID})\\n261:\\n262:\\tif got, want := len(inactive.pendingOutput), 17; got != want {\\n263:\\t\\tt.Fatalf(\\\"pending output = %d, want %d\\\", got, want)\\n264:\\t}\\n265:}\\n266:\\n267:func TestUpdatePTYFlush_CatchUpHintIgnoredWhenTabIsNoLongerActive(t *testing.T) {\\n268:\\tm := newTestModel()\\n269:\\tws := newTestWorkspace(\\\"ws\\\", \\\"/repo/ws\\\")\\n270:\\twsID := string(ws.ID())\\n271:\\tactive := &Tab{\\n272:\\t\\tID:        TabID(\\\"tab-active\\\"),\\n273:\\t\\tWorkspace: ws,\\n274:\\t\\tTerminal:  vterm.New(80, 24),\\n275:\\t\\tRunning:   true,\\n276:\\t}\\n277:\\tinactive := &Tab{\\n278:\\t\\tID:                   TabID(\\\"tab-inactive-catch-up\\\"),\\n279:\\t\\tWorkspace:            ws,\\n280:\\t\\tTerminal:             vterm.New(80, 24),\\n281:\\t\\tRunning:              true,\\n282:\\t\\tlastOutputAt:         time.Now().Add(-time.Second),\\n283:\\t\\tflushPendingSince:    time.Now().Add(-time.Second),\\n284:\\t\\tpendingOutput:        bytes.Repeat([]byte(\\\"x\\\"), ptyFlushChunkSize+17),\\n285:\\t\\tcatchUpPendingOutput: true,\\n286:\\t\\tcatchUpTargetBytes:   ptyFlushChunkSize + 17,\\n287:\\t\\tptyBytesReceived:     ptyFlushChunkSize + 17,\\n288:\\t}\\n289:\\tm.tabsByWorkspace[wsID] = []*Tab{active, inactive}\\n290:\\tm.activeTabByWorkspace[wsID] = 0\\n291:\\tm.workspace = ws\\n292:\\n293:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: inactive.ID})\\n294:\\n295:\\tif got, want := len(inactive.pendingOutput), 17; got != want {\\n296:\\t\\tt.Fatalf(\\\"pending output = %d, want %d when catch-up tab is inactive\\\", got, want)\\n297:\\t}\\n298:\\tif inactive.catchUpPendingOutput {\\n299:\\t\\tt.Fatalf(\\\"expected inactive flush to clear latched catch-up state\\\")\\n300:\\t}\\n301:}\\n302:\\n303:func TestUpdatePTYFlush_CatchUpFallsBackToActiveChunkWhenActorQueueIsFull(t *testing.T) {\\n304:\\tm := newTestModel()\\n305:\\tm.setTabActorReady()\\n306:\\tm.tabEvents = make(chan tabEvent, 1)\\n307:\\tm.tabEvents <- tabEvent{kind: tabEventWriteOutput}\\n308:\\n309:\\tws := newTestWorkspace(\\\"ws\\\", \\\"/repo/ws\\\")\\n310:\\twsID := string(ws.ID())\\n311:\\tpayload := bytes.Repeat([]byte(\\\"x\\\"), ptyFlushChunkSizeActive+17)\\n312:\\ttab := &Tab{\\n313:\\t\\tID:                   TabID(\\\"tab-active-catch-up-queue-full\\\"),\\n314:\\t\\tWorkspace:            ws,\\n315:\\t\\tTerminal:             vterm.New(80, 24),\\n316:\\t\\tRunning:              true,\\n317:\\t\\tlastOutputAt:         time.Now().Add(-time.Second),\\n318:\\t\\tflushPendingSince:    time.Now().Add(-time.Second),\\n319:\\t\\tpendingOutput:        append([]byte(nil), payload...),\\n320:\\t\\tcatchUpPendingOutput: true,\\n321:\\t\\tcatchUpTargetBytes:   uint64(len(payload)),\\n322:\\t\\tptyBytesReceived:     uint64(len(payload)),\\n323:\\t}\\n324:\\tm.tabsByWorkspace[wsID] = []*Tab{tab}\\n325:\\tm.activeTabByWorkspace[wsID] = 0\\n326:\\tm.workspace = ws\\n327:\\n328:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: tab.ID, CatchUp: true})\\n329:\\n330:\\tif got, want := len(tab.pendingOutput), 17; got != want {\\n331:\\t\\tt.Fatalf(\\\"pending output = %d, want %d after queue-full catch-up fallback\\\", got, want)\\n332:\\t}\\n333:\\tif tab.actorWritesPending != 0 {\\n334:\\t\\tt.Fatalf(\\\"expected no actor writes pending after queue-full catch-up fallback, got %d\\\", tab.actorWritesPending)\\n335:\\t}\\n336:\\tif !tab.flushScheduled {\\n337:\\t\\tt.Fatalf(\\\"expected queue-full catch-up fallback to schedule another flush\\\")\\n338:\\t}\\n339:\\tif !tab.catchUpPendingOutput {\\n340:\\t\\tt.Fatalf(\\\"expected queue-full catch-up fallback to keep catch-up latched for the remainder\\\")\\n341:\\t}\\n342:\\tif tab.Terminal.Render() == vterm.New(80, 24).Render() {\\n343:\\t\\tt.Fatalf(\\\"expected queue-full catch-up fallback to advance the visible terminal synchronously\\\")\\n344:\\t}\\n345:}\\n346:\\n347:func TestUpdatePTYFlush_CatchUpClearsAfterInitialBacklogPass(t *testing.T) {\\n348:\\tm := newTestModel()\\n349:\\tm.setTabActorReady()\\n350:\\tm.tabEvents = make(chan tabEvent, 2)\\n351:\\n352:\\tws := newTestWorkspace(\\\"ws\\\", \\\"/repo/ws\\\")\\n353:\\twsID := string(ws.ID())\\n354:\\tinitialBacklog := bytes.Repeat([]byte(\\\"x\\\"), ptyFlushChunkSizeCatchUp)\\n355:\\tsteadyState := bytes.Repeat([]byte(\\\"y\\\"), ptyFlushChunkSizeActive+17)\\n356:\\ttab := &Tab{\\n357:\\t\\tID:                   TabID(\\\"tab-active-catch-up-clears\\\"),\\n358:\\t\\tWorkspace:            ws,\\n359:\\t\\tTerminal:             vterm.New(80, 24),\\n360:\\t\\tRunning:              true,\\n361:\\t\\tlastOutputAt:         time.Now().Add(-time.Second),\\n362:\\t\\tflushPendingSince:    time.Now().Add(-time.Second),\\n363:\\t\\tpendingOutput:        append(append([]byte(nil), initialBacklog...), steadyState...),\\n364:\\t\\tcatchUpPendingOutput: true,\\n365:\\t\\tcatchUpTargetBytes:   uint64(len(initialBacklog)),\\n366:\\t\\tptyBytesReceived:     uint64(len(initialBacklog) + len(steadyState)),\\n367:\\t}\\n368:\\tm.tabsByWorkspace[wsID] = []*Tab{tab}\\n369:\\tm.activeTabByWorkspace[wsID] = 0\\n370:\\tm.workspace = ws\\n371:\\n372:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: tab.ID, CatchUp: true})\\n373:\\n374:\\tvar first tabEvent\\n375:\\tselect {\\n376:\\tcase first = <-m.tabEvents:\\n377:\\t\\tif got, want := len(first.output), len(initialBacklog); got != want {\\n378:\\t\\t\\tt.Fatalf(\\\"first catch-up output len = %d, want %d\\\", got, want)\\n379:\\t\\t}\\n380:\\tdefault:\\n381:\\t\\tt.Fatalf(\\\"expected first actor-backed catch-up flush\\\")\\n382:\\t}\\n383:\\n384:\\tm.handleTabEvent(first)\\n385:\\n386:\\tif tab.catchUpPendingOutput {\\n387:\\t\\tt.Fatalf(\\\"expected catch-up latch to clear once the selected backlog target is settled\\\")\\n388:\\t}\\n389:\\n390:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: tab.ID})\\n391:\\n392:\\tselect {\\n393:\\tcase second := <-m.tabEvents:\\n394:\\t\\tif got, want := len(second.output), ptyFlushChunkSizeActive; got != want {\\n395:\\t\\t\\tt.Fatalf(\\\"steady-state output len = %d, want active cap %d after catch-up clears\\\", got, want)\\n396:\\t\\t}\\n397:\\tdefault:\\n398:\\t\\tt.Fatalf(\\\"expected steady-state flush after catch-up target settles\\\")\\n399:\\t}\\n400:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
