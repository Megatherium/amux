         `json:\\\"command\\\"`\\n 43:\\tCommandTemplate  string            `json:\\\"command_template,omitempty\\\"`\\n 44:\\tPromptTemplate   string            `json:\\\"prompt_template,omitempty\\\"`\\n 45:\\tSupportedModels  []string          `json:\\\"supported_models,omitempty\\\"`\\n 46:\\tSupportedAgents  []string          `json:\\\"supported_agents,omitempty\\\"`\\n 47:\\tEnv              map[string]string `json:\\\"env,omitempty\\\"`\\n 48:\\tInterruptCount   *int              `json:\\\"interrupt_count,omitempty\\\"`\\n 49:\\tInterruptDelayMs *int              `json:\\\"interrupt_delay_ms,omitempty\\\"`\\n 50:}\\n 51:\\n 52:const fallbackDefaultAssistant = \\\"claude\\\"\\n 53:\\n 54:var preferredAssistantOrder = []string{\\n 55:\\t\\\"claude\\\",\\n 56:\\t\\\"codex\\\",\\n 57:\\t\\\"gemini\\\",\\n 58:\\t\\\"amp\\\",\\n 59:\\t\\\"opencode\\\",\\n 60:\\t\\\"droid\\\",\\n 61:\\t\\\"cline\\\",\\n 62:\\t\\\"cursor\\\",\\n 63:\\t\\\"pi\\\",\\n 64:}\\n 65:\\n 66:// DefaultConfig returns the default configuration\\n 67:func DefaultConfig() (*Config, error) {\\n 68:\\tpaths, err := DefaultPaths()\\n 69:\\tif err != nil {\\n 70:\\t\\treturn nil, err\\n 71:\\t}\\n 72:\\n 73:\\tassistants := defaultAssistants()\\n 74:\\tloadYAMLConfig(paths.ConfigYAMLPath, assistants)\\n 75:\\tloadAssistantOverrides(paths.ConfigPath, assistants)\\n 76:\\n 77:\\tcfg := &Config{\\n 78:\\t\\tPaths:         paths,\\n 79:\\t\\tPortStart:     6200,\\n 80:\\t\\tPortRangeSize: 10,\\n 81:\\t\\tUI:            loadUISettings(paths.ConfigPath),\\n 82:\\t\\tAssistants:    assistants,\\n 83:\\t}\\n 84:\\treturn cfg, nil\\n 85:}\\n 86:\\n 87:// AssistantNames returns assistant IDs in deterministic display order.\\n 88:func (c *Config) AssistantNames() []string {\\n 89:\\tif c == nil {\\n 90:\\t\\treturn nil\\n 91:\\t}\\n 92:\\treturn orderedAssistantNames(c.Assistants)\\n 93:}\\n 94:\\n 95:// IsAssistantKnown reports whether assistant exists in loaded config.\\n 96:func (c *Config) IsAssistantKnown(assistant string) bool {\\n 97:\\tif c == nil || len(c.Assistants) == 0 {\\n 98:\\t\\treturn false\\n 99:\\t}\\n100:\\t_, ok := c.Assistants[normalizeAssistantName(assistant)]\\n101:\\treturn ok\\n102:}\\n103:\\n104:// ResolvedDefaultAssistant returns a valid default assistant name.\\n105:func (c *Config) ResolvedDefaultAssistant() string {\\n106:\\tif c == nil {\\n107:\\t\\treturn fallbackDefaultAssistant\\n108:\\t}\\n109:\\treturn canonicalDefaultAssistant(fallbackDefaultAssistant, c.Assistants)\\n110:}\\n111:\\n112:func defaultAssistants() map[string]AssistantConfig {\\n113:\\treturn map[string]AssistantConfig{\\n114:\\t\\t\\\"claude\\\": {\\n115:\\t\\t\\tCommand:          \\\"claude\\\",\\n116:\\t\\t\\tInterruptCount:   2,\\n117:\\t\\t\\tInterruptDelayMs: 200,\\n118:\\t\\t},\\n119:\\t\\t\\\"codex\\\": {\\n120:\\t\\t\\tCommand:          \\\"codex\\\",\\n121:\\t\\t\\tInterruptCount:   1,\\n122:\\t\\t\\tInterruptDelayMs: 0,\\n123:\\t\\t},\\n124:\\t\\t\\\"gemini\\\": {\\n125:\\t\\t\\tCommand:          \\\"gemini\\\",\\n126:\\t\\t\\tInterruptCount:   1,\\n127:\\t\\t\\tInterruptDelayMs: 0,\\n128:\\t\\t},\\n129:\\t\\t\\\"amp\\\": {\\n130:\\t\\t\\tCommand:          \\\"amp\\\",\\n131:\\t\\t\\tInterruptCount:   1,\\n132:\\t\\t\\tInterruptDelayMs: 0,\\n133:\\t\\t},\\n134:\\t\\t\\\"opencode\\\": {\\n135:\\t\\t\\tCommand:          \\\"opencode\\\",\\n136:\\t\\t\\tInterruptCount:   1,\\n137:\\t\\t\\tInterruptDelayMs: 0,\\n138:\\t\\t},\\n139:\\t\\t\\\"droid\\\": {\\n140:\\t\\t\\tCommand:          \\\"droid\\\",\\n141:\\t\\t\\tInterruptCount:   1,\\n142:\\t\\t\\tInterruptDelayMs: 0,\\n143:\\t\\t},\\n144:\\t\\t\\\"cline\\\": {\\n145:\\t\\t\\tCommand:          \\\"cline\\\",\\n146:\\t\\t\\tInterruptCount:   1,\\n147:\\t\\t\\tInterruptDelayMs: 0,\\n148:\\t\\t},\\n149:\\t\\t\\\"cursor\\\": {\\n150:\\t\\t\\tCommand:          \\\"agent\\\",\\n151:\\t\\t\\tInterruptCount:   1,\\n152:\\t\\t\\tInterruptDelayMs: 0,\\n153:\\t\\t},\\n154:\\t\\t\\\"pi\\\": {\\n155:\\t\\t\\tCommand:          \\\"pi\\\",\\n156:\\t\\t\\tInterruptCount:   1,\\n157:\\t\\t\\tInterruptDelayMs: 0,\\n158:\\t\\t},\\n159:\\t}\\n160:}\\n161:\\n162:func loadAssistantOverrides(path string, assistants map[string]AssistantConfig) {\\n163:\\tdata, err := os.ReadFile(path)\\n164:\\tif err != nil {\\n165:\\t\\treturn\\n166:\\t}\\n167:\\n168:\\tvar raw struct {\\n169:\\t\\tAssistants map[string]assistantConfigRaw `json:\\\"assistants\\\"`\\n170:\\t}\\n171:\\tif err := json.Unmarshal(data, &raw); err != nil {\\n172:\\t\\treturn\\n173:\\t}\\n174:\\n175:\\tfor name, override := range raw.Assistants {\\n176:\\t\\tnormalized := normalizeAssistantName(name)\\n177:\\t\\tif normalized == \\\"\\\" {\\n178:\\t\\t\\tcontinue\\n179:\\t\\t}\\n180:\\t\\tif err := validation.ValidateAssistant(normalized); err != nil {\\n181:\\t\\t\\tcontinue\\n182:\\t\\t}\\n183:\\n184:\\t\\tcfg := assistants[normalized]\\n185:\\t\\tif cmd := strings.TrimSpace(override.Command); cmd != \\\"\\\" {\\n186:\\t\\t\\tcfg.Command = cmd\\n187:\\t\\t}\\n188:\\t\\tif cmdTemplate := strings.TrimSpace(override.CommandTemplate); cmdTemplate != \\\"\\\" {\\n189:\\t\\t\\tcfg.CommandTemplate = cmdTemplate\\n190:\\t\\t}\\n191:\\t\\tif promptTemplate := strings.TrimSpace(override.PromptTemplate); promptTemplate != \\\"\\\" {\\n192:\\t\\t\\tcfg.PromptTemplate = promptTemplate\\n193:\\t\\t}\\n194:\\t\\tif override.SupportedModels != nil {\\n195:\\t\\t\\tcfg.SupportedModels = override.SupportedModels\\n196:\\t\\t}\\n197:\\t\\tif override.SupportedAgents != nil {\\n198:\\t\\t\\tcfg.SupportedAgents = override.SupportedAgents\\n199:\\t\\t}\\n200:\\t\\tif override.Env != nil {\\n201:\\t\\t\\tcfg.Env = override.Env\\n202:\\t\\t}\\n203:\\t\\tif override.InterruptCount != nil {\\n204:\\t\\t\\tcfg.InterruptCount = *override.InterruptCount\\n205:\\t\\t}\\n206:\\t\\tif override.InterruptDelayMs != nil {\\n207:\\t\\t\\tcfg.InterruptDelayMs = *override.InterruptDelayMs\\n208:\\t\\t}\\n209:\\n210:\\t\\tif cfg.Command == \\\"\\\" {\\n211:\\t\\t\\tcontinue\\n212:\\t\\t}\\n213:\\t\\tif cfg.InterruptCount <= 0 {\\n214:\\t\\t\\tcfg.InterruptCount = 1\\n215:\\t\\t}\\n216:\\t\\tif cfg.InterruptDelayMs < 0 {\\n217:\\t\\t\\tcfg.InterruptDelayMs = 0\\n218:\\t\\t}\\n219:\\n220:\\t\\tassistants[normalized] = cfg\\n221:\\t}\\n222:}\\n223:\\n224:func loadYAMLConfig(path string, assistants map[string]AssistantConfig) {\\n225:\\tloader := NewYAMLLoader()\\n226:\\tyamlCfg, err := loader.Load(path)\\n227:\\tif err != nil {\\n228:\\t\\treturn\\n229:\\t}\\n230:\\n231:\\tfor name, override := range yamlCfg.Assistants {\\n232:\\t\\tnormalized := normalizeAssistantName(name)\\n233:\\t\\tif normalized == \\\"\\\" {\\n234:\\t\\t\\tcontinue\\n235:\\t\\t}\\n236:\\t\\tif err := validation.ValidateAssistant(normalized); err != nil {\\n237:\\t\\t\\tcontinue\\n238:\\t\\t}\\n239:\\n240:\\t\\tcfg := assistants[normalized]\\n241:\\t\\tif cmdTemplate := strings.TrimSpace(override.CommandTemplate); cmdTemplate != \\\"\\\" {\\n242:\\t\\t\\tcfg.CommandTemplate = cmdTemplate\\n243:\\t\\t}\\n244:\\t\\tif promptTemplate := strings.TrimSpace(override.PromptTemplate); promptTemplate != \\\"\\\" {\\n245:\\t\\t\\tcfg.PromptTemplate = promptTemplate\\n246:\\t\\t}\\n247:\\t\\tif override.SupportedModels != nil {\\n248:\\t\\t\\tcfg.SupportedModels = override.SupportedModels\\n249:\\t\\t}\\n250:\\t\\tif override.SupportedAgents != nil {\\n251:\\t\\t\\tcfg.SupportedAgents = override.SupportedAgents\\n252:\\t\\t}\\n253:\\t\\tif override.Env != nil {\\n254:\\t\\t\\tcfg.Env = override.Env\\n255:\\t\\t}\\n256:\\n257:\\t\\tassistants[normalized] = cfg\\n258:\\t}\\n259:}\\n260:\\n261:func orderedAssistantNames(assistants map[string]AssistantConfig) []string {\\n262:\\tif len(assistants) == 0 {\\n263:\\t\\treturn nil\\n264:\\t}\\n265:\\tseen := make(map[string]struct{}, len(assistants))\\n266:\\tnames := make([]string, 0, len(assistants))\\n267:\\n268:\\tfor _, name := range preferredAssistantOrder {\\n269:\\t\\tif _, ok := assistants[name]; ok {\\n270:\\t\\t\\tnames = append(names, name)\\n271:\\t\\t\\tseen[name] = struct{}{}\\n272:\\t\\t}\\n273:\\t}\\n274:\\n275:\\tvar extras []string\\n276:\\tfor name := range assistants {\\n277:\\t\\tif _, ok := seen[name]; ok {\\n278:\\t\\t\\tcontinue\\n279:\\t\\t}\\n280:\\t\\textras = append(extras, name)\\n281:\\t}\\n282:\\tsort.Strings(extras)\\n283:\\tnames = append(names, extras...)\\n284:\\n285:\\treturn names\\n286:}\\n287:\\n288:func canonicalDefaultAssistant(candidate string, assistants map[string]AssistantConfig) string {\\n289:\\tname := normalizeAssistantName(candidate)\\n290:\\tif name != \\\"\\\" {\\n291:\\t\\tif _, ok := assistants[name]; ok {\\n292:\\t\\t\\treturn name\\n293:\\t\\t}\\n294:\\t}\\n295:\\tif _, ok := assistants[fallbackDefaultAssistant]; ok {\\n296:\\t\\treturn fallbackDefaultAssistant\\n297:\\t}\\n298:\\tnames := orderedAssistantNames(assistants)\\n299:\\tif len(names) > 0 {\\n300:\\t\\treturn names[0]\\n301:\\t}\\n302:\\treturn fallbackDefaultAssistant\\n303:}\\n304:\\n305:func normalizeAssistantName(name string) string {\\n306:\\treturn strings.ToLower(strings.TrimSpace(name))\\n307:}]]>\\n</file>\")] } }, ToolResult { name: ToolName(\"fs_search\"), call_id: Some(ToolCallId(\"call_01_hVoN2vIDTP2VvbUPuG8DIOCj\")), output: ToolOutput { is_error: false, values: [Text(\"<search_results\\n  path=\\\"/home/sloth/gt/badmux/polecats/rust/badmux/internal/app\\\"\\n  max_bytes_allowed=\\\"10240\\\"\\n  total_lines=\\\"2\\\"\\n  display_lines=\\\"1-2\\\"\\n  pattern=\\\"assistantNames\\\"\\n><![CDATA[app_input_messages_dialogs.go\\napp_assistants.go]]>\\n</search_results>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
