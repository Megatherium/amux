{"timestamp":"2168.026637727s","level":"DEBUG","fields":{"message":"Adding tool results to context","results":"[ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_00_v9xLKtXwUEKkdNURnVxo1UcT\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/gt/badmux/polecats/rust/badmux/internal/app/app_input_messages_dialogs.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"120\\\"\\n><![CDATA[  1:package app\\n  2:\\n  3:import (\\n  4:\\t\\\"sort\\\"\\n  5:\\n  6:\\ttea \\\"charm.land/bubbletea/v2\\\"\\n  7:\\n  8:\\t\\\"github.com/andyrewlee/amux/internal/data\\\"\\n  9:\\t\\\"github.com/andyrewlee/amux/internal/messages\\\"\\n 10:\\t\\\"github.com/andyrewlee/amux/internal/tickets\\\"\\n 11:\\t\\\"github.com/andyrewlee/amux/internal/ui/common\\\"\\n 12:)\\n 13:\\n 14:// handleTicketSelected handles a ticket selection from the dashboard,\\n 15:// starting the draft flow in the center pane.\\n 16:func (a *App) handleTicketSelected(msg messages.TicketSelectedMsg) []tea.Cmd {\\n 17:\\tif msg.Ticket == nil {\\n 18:\\t\\treturn nil\\n 19:\\t}\\n 20:\\n 21:\\tproject := msg.Project\\n 22:\\tif project == nil {\\n 23:\\t\\treturn []tea.Cmd{a.ui.toast.ShowError(\\\"No project associated with this ticket\\\")}\\n 24:\\t}\\n 25:\\n 26:\\tvar mainWS *data.Workspace\\n 27:\\tfor i := range project.Workspaces {\\n 28:\\t\\tws := &project.Workspaces[i]\\n 29:\\t\\tif ws.IsMainBranch() || ws.IsPrimaryCheckout() {\\n 30:\\t\\t\\tmainWS = ws\\n 31:\\t\\t\\tbreak\\n 32:\\t\\t}\\n 33:\\t}\\n 34:\\tif mainWS == nil {\\n 35:\\t\\treturn []tea.Cmd{a.ui.toast.ShowError(\\\"No workspace found for project \\\" + project.Name)}\\n 36:\\t}\\n 37:\\n 38:\\tvar cmds []tea.Cmd\\n 39:\\tif a.activeWorkspace == nil || string(a.activeWorkspace.ID()) != string(mainWS.ID()) {\\n 40:\\t\\tcmds = append(cmds, a.handleWorkspaceActivated(messages.WorkspaceActivated{\\n 41:\\t\\t\\tProject:   project,\\n 42:\\t\\t\\tWorkspace: mainWS,\\n 43:\\t\\t})...)\\n 44:\\t}\\n 45:\\n 46:\\ta.ui.center.StartDraft(msg.Ticket, mainWS)\\n 47:\\tcmds = append(cmds, a.focusPane(messages.PaneCenter))\\n 48:\\treturn cmds\\n 49:}\\n 50:\\n 51:// handleTicketPreview updates the preview state when the cursor hovers over\\n 52:// a ticket row in the dashboard. When no agent tabs are open, the ticket info\\n 53:// is shown in the center pane. When agent tabs exist, the info is shown in the\\n 54:// sidebar's ticket tab (without auto-focusing the sidebar).\\n 55:func (a *App) handleTicketPreview(msg messages.TicketPreviewMsg) {\\n 56:\\ta.ui.previewTicket = msg.Ticket\\n 57:\\ta.ui.previewProject = msg.Project\\n 58:\\n 59:\\t// Forward the preview to the sidebar for the ticket tab\\n 60:\\tif a.ui.sidebar != nil {\\n 61:\\t\\ta.ui.sidebar.SetPreviewTicket(msg.Ticket)\\n 62:\\t}\\n 63:}\\n 64:\\n 65:// sortTicketsHierarchically reorders tickets so that child tickets\\n 66:// (tickets with a non-empty ParentID) appear immediately after\\n 67:// their parent.\\n 68:func sortTicketsHierarchically(ts []tickets.Ticket) []tickets.Ticket {\\n 69:\\tif len(ts) == 0 {\\n 70:\\t\\treturn ts\\n 71:\\t}\\n 72:\\n 73:\\t// Build parent index map: ticket ID → position\\n 74:\\tparentPos := make(map[string]int, len(ts))\\n 75:\\tfor i, t := range ts {\\n 76:\\t\\tparentPos[t.ID] = i\\n 77:\\t}\\n 78:\\n 79:\\t// Separate children from parents\\n 80:\\tvar ordered []tickets.Ticket\\n 81:\\tchildrenOf := make(map[int][]tickets.Ticket) // parent position → children\\n 82:\\n 83:\\tfor _, t := range ts {\\n 84:\\t\\tif t.ParentID == \\\"\\\" {\\n 85:\\t\\t\\t// Parent or root ticket\\n 86:\\t\\t\\tordered = append(ordered, t)\\n 87:\\t\\t} else {\\n 88:\\t\\t\\t// Child ticket - defer placement\\n 89:\\t\\t\\tpidx, ok := parentPos[t.ParentID]\\n 90:\\t\\t\\tif ok {\\n 91:\\t\\t\\t\\tchildrenOf[pidx] = append(childrenOf[pidx], t)\\n 92:\\t\\t\\t} else {\\n 93:\\t\\t\\t\\t// Parent not in this batch, treat as root\\n 94:\\t\\t\\t\\tordered = append(ordered, t)\\n 95:\\t\\t\\t}\\n 96:\\t\\t}\\n 97:\\t}\\n 98:\\n 99:\\t// Insert children after their parents (iterate in reverse to preserve order)\\n100:\\tfor i := len(ordered) - 1; i >= 0; i-- {\\n101:\\t\\t// Find the original position of this parent to look up children\\n102:\\t\\tfor pidx, children := range childrenOf {\\n103:\\t\\t\\tif pidx < 0 || pidx >= len(ts) {\\n104:\\t\\t\\t\\tcontinue\\n105:\\t\\t\\t}\\n106:\\t\\t\\tif ts[pidx].ID == ordered[i].ID {\\n107:\\t\\t\\t\\t// Insert children directly after this parent\\n108:\\t\\t\\t\\tsort.Slice(children, func(a, b int) bool {\\n109:\\t\\t\\t\\t\\treturn children[a].CreatedAt.Before(children[b].CreatedAt)\\n110:\\t\\t\\t\\t})\\n111:\\t\\t\\t\\tinsertAt := i + 1\\n112:\\t\\t\\t\\tordered = append(ordered[:insertAt], append(children, ordered[insertAt:]...)...)\\n113:\\t\\t\\t\\tdelete(childrenOf, pidx)\\n114:\\t\\t\\t\\tbreak\\n115:\\t\\t\\t}\\n116:\\t\\t}\\n117:\\t}\\n118:\\n119:\\treturn ordered\\n120:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
