tab == nil {\\n40:\\t\\treturn nil\\n41:\\t}\\n42:\\trecordLocalInputEchoWindow(tab, data, now)\\n43:\\treturn m.scheduleChatCursorRefresh(tab, workspaceID, now)\\n44:}\\n45:\\n46:// Update handles messages\\n47:func (m *Model) Update(msg tea.Msg) (*Model, tea.Cmd) {\\n48:\\tdefer perf.Time(\\\"center_update\\\")()\\n49:\\tvar cmds []tea.Cmd\\n50:\\n51:\\tswitch msg := msg.(type) {\\n52:\\tcase tea.MouseClickMsg:\\n53:\\t\\tif m.draft != nil {\\n54:\\t\\t\\treturn m, nil\\n55:\\t\\t}\\n56:\\t\\treturn m.updateMouseClick(msg)\\n57:\\n58:\\tcase tea.MouseMotionMsg:\\n59:\\t\\treturn m.updateMouseMotion(msg)]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
