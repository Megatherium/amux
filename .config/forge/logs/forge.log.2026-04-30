eBuffered bool\\n 55:\\tvisibleSeq      uint64\\n 56:}\\n 57:\\n 58:type tabSelectionResult struct {\\n 59:\\tworkspaceID string\\n 60:\\ttabID       TabID\\n 61:\\tclipboard   string\\n 62:}\\n 63:\\n 64:type selectionTickRequest struct {\\n 65:\\tworkspaceID string\\n 66:\\ttabID       TabID\\n 67:\\tgen         uint64\\n 68:}\\n 69:\\n 70:type tabActorRedraw struct{}\\n 71:\\n 72:func (tabActorRedraw) MarkCriticalExternalMsg()            {}\\n 73:func (tabActorRedraw) MarkNonEvictingCriticalExternalMsg() {}\\n 74:\\n 75:type tabDiffCmd struct{ cmd tea.Cmd }\\n 76:\\n 77:type TabInputFailed struct {\\n 78:\\tTabID       TabID\\n 79:\\tWorkspaceID string\\n 80:\\tErr         error\\n 81:}\\n 82:\\n 83:func (m *Model) shouldPostWriteRedraw(tab *Tab) bool {\\n 84:\\treturn tab != nil && (m.isChatTab(tab) || tab.postWriteVisible())\\n 85:}\\n 86:\\n 87:func (m *Model) sendTabEvent(ev tabEvent) bool {\\n 88:\\tif m == nil || m.tabEvents == nil {\\n 89:\\t\\treturn false\\n 90:\\t}\\n 91:\\tif ev.tab == nil {\\n 92:\\t\\tperf.Count(\\\"tab_event_drop_missing\\\", 1)\\n 93:\\t\\treturn false\\n 94:\\t}\\n 95:\\tif ev.tab != nil && ev.tab.isClosed() {\\n 96:\\t\\tperf.Count(\\\"tab_event_drop_closed\\\", 1)\\n 97:\\t\\treturn ev.kind != tabEventWriteOutput\\n 98:\\t}\\n 99:\\tif shouldDropTabEvent(m.tabEvents, ev.kind) {\\n100:\\t\\tperf.Count(\\\"tab_event_drop_backpressure\\\", 1)\\n101:\\t\\treturn false\\n102:\\t}\\n103:\\tselect {\\n104:\\tcase m.tabEvents <- ev:\\n105:\\t\\treturn true\\n106:\\tdefault:\\n107:\\t\\tperf.Count(\\\"tab_event_drop\\\", 1)\\n108:\\t}\\n109:\\treturn false\\n110:}\\n111:\\n112:func shouldDropTabEvent(ch chan tabEvent, kind tabEventKind) bool {\\n113:\\tif ch == nil {\\n114:\\t\\treturn true\\n115:\\t}\\n116:\\tswitch kind {\\n117:\\tcase tabEventSelectionUpdate, tabEventSelectionScrollTick, tabEventScrollBy, tabEventScrollPage:\\n118:\\tdefault:\\n119:\\t\\treturn false\\n120:\\t}\\n121:\\tcapacity := cap(ch)\\n122:\\tif capacity == 0 {\\n123:\\t\\treturn false\\n124:\\t}\\n125:\\treturn len(ch) >= (capacity*3)/4\\n126:}\\n127:\\n128:func shouldPostTabActorRedraw(kind tabEventKind) bool {\\n129:\\tswitch kind {\\n130:\\tcase tabEventSelectionStart,\\n131:\\t\\ttabEventSelectionUpdate,\\n132:\\t\\ttabEventSelectionFinish,\\n133:\\t\\ttabEventScrollBy,\\n134:\\t\\ttabEventSelectionClearAndNotify,\\n135:\\t\\ttabEventSelectionScrollTick,\\n136:\\t\\ttabEventScrollToBottom,\\n137:\\t\\ttabEventScrollPage,\\n138:\\t\\ttabEventScrollToTop,\\n139:\\t\\ttabEventDiffInput:\\n140:\\t\\treturn true\\n141:\\tdefault:\\n142:\\t\\treturn false\\n143:\\t}\\n144:}\\n145:\\n146:func (m *Model) RunTabActor(ctx context.Context) error {\\n147:\\tif m == nil || m.tabEvents == nil {\\n148:\\t\\treturn nil\\n149:\\t}\\n150:\\tm.setTabActorReady()\\n151:\\tticker := time.NewTicker(2 * time.Second)\\n152:\\tdefer ticker.Stop()\\n153:\\tfor {\\n154:\\t\\tselect {\\n155:\\t\\tcase <-ctx.Done():\\n156:\\t\\t\\treturn nil\\n157:\\t\\tcase ev := <-m.tabEvents:\\n158:\\t\\t\\tm.noteTabActorHeartbeat()\\n159:\\t\\t\\tm.handleTabEvent(ev)\\n160:\\t\\t\\tif shouldPostTabActorRedraw(ev.kind) {\\n161:\\t\\t\\t\\tm.requestTabActorRedraw()\\n162:\\t\\t\\t}\\n163:\\t\\tcase <-ticker.C:\\n164:\\t\\t\\tm.noteTabActorHeartbeat()\\n165:\\t\\t}\\n166:\\t}\\n167:}\\n168:\\n169:func (m *Model) handleTabEvent(ev tabEvent) {\\n170:\\tif ev.tab == nil || ev.tab.isClosed() {\\n171:\\t\\tperf.Count(\\\"tab_event_drop_missing\\\", 1)\\n172:\\t\\treturn\\n173:\\t}\\n174:\\ttab := ev.tab\\n175:\\n176:\\tswitch ev.kind {\\n177:\\tcase tabEventSelectionClear:\\n178:\\t\\thadSelection := false\\n179:\\t\\ttab.mu.Lock()\\n180:\\t\\tif tab.Selection.Active {\\n181:\\t\\t\\thadSelection = true\\n182:\\t\\t}\\n183:\\t\\tif tab.Terminal != nil {\\n184:\\t\\t\\thadSelection = hadSelection || tab.Terminal.HasSelection()\\n185:\\t\\t\\ttab.Terminal.ClearSelection()\\n186:\\t\\t}\\n187:\\t\\ttab.Selection = common.SelectionState{}\\n188:\\t\\ttab.selectionScroll.Reset()\\n189:\\t\\ttab.mu.Unlock()\\n190:\\t\\tif hadSelection {\\n191:\\t\\t\\tm.requestTabActorRedraw()\\n192:\\t\\t}\\n193:\\tcase tabEventSelectionClearAndNotify:\\n194:\\t\\ttab.mu.Lock()\\n195:\\t\\ttext := \\\"\\\"\\n196:\\t\\tif ev.notifyCopy && tab.Terminal != nil && tab.Terminal.HasSelection() {\\n197:\\t\\t\\ttext = tab.Terminal.SelectedText()\\n198:\\t\\t}\\n199:\\t\\tif tab.Terminal != nil {\\n200:\\t\\t\\ttab.Terminal.ClearSelection()\\n201:\\t\\t}\\n202:\\t\\ttab.Selection = common.SelectionState{}\\n203:\\t\\ttab.selectionScroll.Reset()\\n204:\\t\\ttab.mu.Unlock()\\n205:\\t\\tif ev.notifyCopy && text != \\\"\\\" && m.msgSink != nil {\\n206:\\t\\t\\tm.msgSink(tabSelectionResult{workspaceID: ev.workspaceID, tabID: ev.tabID, clipboard: text})\\n207:\\t\\t}\\n208:\\tcase tabEventSelectionCopy:\\n209:\\t\\ttab.mu.Lock()\\n210:\\t\\ttext := \\\"\\\"\\n211:\\t\\tif ev.notifyCopy && tab.Terminal != nil && tab.Terminal.HasSelection() {\\n212:\\t\\t\\ttext = tab.Terminal.SelectedText()\\n213:\\t\\t}\\n214:\\t\\ttab.mu.Unlock()\\n215:\\t\\tif ev.notifyCopy && text != \\\"\\\" && m.msgSink != nil {\\n216:\\t\\t\\tm.msgSink(tabSelectionResult{workspaceID: ev.workspaceID, tabID: ev.tabID, clipboard: text})\\n217:\\t\\t}\\n218:\\tcase tabEventSelectionStart:\\n219:\\t\\ttab.mu.Lock()\\n220:\\t\\tif tab.Terminal != nil {\\n221:\\t\\t\\ttab.Terminal.ClearSelection()\\n222:\\t\\t}\\n223:\\t\\ttab.Selection = common.SelectionState{}\\n224:\\t\\ttab.selectionScroll.Reset()\\n225:\\t\\tif ev.inBounds && tab.Terminal != nil {\\n226:\\t\\t\\tabsLine := tab.Terminal.ScreenYToAbsoluteLine(ev.termY)\\n227:\\t\\t\\ttab.Selection = common.SelectionState{\\n228:\\t\\t\\t\\tActive:    true,\\n229:\\t\\t\\t\\tStartX:    ev.termX,\\n230:\\t\\t\\t\\tStartLine: absLine,\\n231:\\t\\t\\t\\tEndX:      ev.termX,\\n232:\\t\\t\\t\\tEndLine:   absLine,\\n233:\\t\\t\\t}\\n234:\\t\\t\\ttab.Terminal.SetSelection(ev.termX, absLine, ev.termX, absLine, true, false)\\n235:\\t\\t}\\n236:\\t\\ttab.mu.Unlock()\\n237:\\tcase tabEventSelectionUpdate:\\n238:\\t\\ttab.mu.Lock()\\n239:\\t\\tdefer tab.mu.Unlock()\\n240:\\t\\tif !tab.Selection.Active || tab.Terminal == nil {\\n241:\\t\\t\\treturn\\n242:\\t\\t}\\n243:\\t\\ttermWidth := tab.Terminal.Width\\n244:\\t\\ttermHeight := tab.Terminal.Height\\n245:\\t\\ttermX := ev.termX\\n246:\\t\\ttermY := ev.termY\\n247:\\n248:\\t\\tif termX < 0 {\\n249:\\t\\t\\ttermX = 0\\n250:\\t\\t}\\n251:\\t\\tif termX >= termWidth {\\n252:\\t\\t\\ttermX = termWidth - 1\\n253:\\t\\t}\\n254:\\n255:\\t\\t// Set scroll direction from unclamped Y before clamping\\n256:\\t\\ttab.selectionScroll.SetDirection(termY, termHeight)\\n257:\\n258:\\t\\tif termY < 0 {\\n259:\\t\\t\\ttab.Terminal.ScrollView(1)\\n260:\\t\\t\\ttermY = 0\\n261:\\t\\t} else if termY >= termHeight {\\n262:\\t\\t\\ttab.Terminal.ScrollView(-1)\\n263:\\t\\t\\ttermY = termHeight - 1\\n264:\\t\\t}\\n265:\\n266:\\t\\tabsLine := tab.Terminal.ScreenYToAbsoluteLine(termY)\\n267:\\t\\tstartX := tab.Terminal.SelStartX()\\n268:\\t\\tstartLine := tab.Terminal.SelStartLine()\\n269:\\t\\tif !tab.Terminal.HasSelection() {\\n270:\\t\\t\\tstartX = tab.Selection.StartX\\n271:\\t\\t\\tstartLine = tab.Selection.StartLine\\n272:\\t\\t}\\n273:\\t\\ttab.Selection.EndX = termX\\n274:\\t\\ttab.Selection.EndLine = absLine\\n275:\\t\\ttab.Terminal.SetSelection(startX, startLine, termX, absLine, true, false)\\n276:\\t\\ttab.Selection.StartX = startX\\n277:\\t\\ttab.Selection.StartLine = startLine\\n278:\\n279:\\t\\ttab.selectionLastTermX = termX\\n280:\\t\\tif needTick, gen := tab.selectionScroll.NeedsTick(); needTick && m.msgSink != nil {\\n281:\\t\\t\\tm.msgSink(selectionTickRequest{\\n282:\\t\\t\\t\\tworkspaceID: ev.workspaceID,\\n283:\\t\\t\\t\\ttabID:       ev.tabID,\\n284:\\t\\t\\t\\tgen:         gen,\\n285:\\t\\t\\t})\\n286:\\t\\t}\\n287:\\tcase tabEventSelectionFinish:\\n288:\\t\\ttab.mu.Lock()\\n289:\\t\\tif !tab.Selection.Active {\\n290:\\t\\t\\ttab.mu.Unlock()\\n291:\\t\\t\\treturn\\n292:\\t\\t}\\n293:\\t\\ttext := \\\"\\\"\\n294:\\t\\ttab.Selection.Active = false\\n295:\\t\\ttab.selectionScroll.Reset()\\n296:\\t\\tif tab.Terminal != nil &&\\n297:\\t\\t\\t(tab.Selection.StartX != tab.Selection.EndX ||\\n298:\\t\\t\\t\\ttab.Selection.StartLine != tab.Selection.EndLine) {\\n299:\\t\\t\\ttext = tab.Terminal.SelectedText()\\n300:\\t\\t}\\n301:\\t\\ttab.mu.Unlock()\\n302:\\t\\tif text != \\\"\\\" && m.msgSink != nil {\\n303:\\t\\t\\tm.msgSink(tabSelectionResult{workspaceID: ev.workspaceID, tabID: ev.tabID, clipboard: text})\\n304:\\t\\t}\\n305:\\tcase tabEventScrollBy:\\n306:\\t\\ttab.mu.Lock()\\n307:\\t\\tif tab.Terminal != nil && ev.delta != 0 {\\n308:\\t\\t\\ttab.Terminal.ScrollView(ev.delta)\\n309:\\t\\t}\\n310:\\t\\ttab.mu.Unlock()\\n311:\\tcase tabEventSelectionScrollTick:\\n312:\\t\\ttab.mu.Lock()\\n313:\\t\\tif !tab.Selection.Active || tab.Terminal == nil || !tab.selectionScroll.HandleTick(ev.gen) {\\n314:\\t\\t\\ttab.mu.Unlock()\\n315:\\t\\t\\treturn\\n316:\\t\\t}\\n317:\\t\\ttab.Terminal.ScrollView(tab.selectionScroll.ScrollDir)\\n318:\\n319:\\t\\t// Update selection endpoint to viewport edge\\n320:\\t\\tedgeY := 0\\n321:\\t\\tif tab.selectionScroll.ScrollDir < 0 {\\n322:\\t\\t\\tedgeY = tab.Terminal.Height - 1\\n323:\\t\\t}\\n324:\\t\\tabsLine := tab.Terminal.ScreenYToAbsoluteLine(edgeY)\\n325:\\t\\tendX := tab.selectionLastTermX\\n326:\\t\\tstartX := tab.Terminal.SelStartX()\\n327:\\t\\tstartLine := tab.Terminal.SelStartLine()\\n328:\\t\\tif !tab.Terminal.HasSelection() {\\n329:\\t\\t\\tstartX = tab.Selection.StartX\\n330:\\t\\t\\tstartLine = tab.Selection.StartLine\\n331:\\t\\t}\\n332:\\t\\ttab.Selection.EndX = endX\\n333:\\t\\ttab.Selection.EndLine = absLine\\n334:\\t\\ttab.Terminal.SetSelection(startX, startLine, endX, absLine, true, false)\\n335:\\t\\ttab.Selection.StartX = startX\\n336:\\t\\ttab.Selection.StartLine = startLine\\n337:\\n338:\\t\\ttab.mu.Unlock()\\n339:\\t\\tif m.msgSink != nil {\\n340:\\t\\t\\tm.msgSink(selectionTickRequest{\\n341:\\t\\t\\t\\tworkspaceID: ev.workspaceID,\\n342:\\t\\t\\t\\ttabID:       ev.tabID,\\n343:\\t\\t\\t\\tgen:         ev.gen,\\n344:\\t\\t\\t})\\n345:\\t\\t}\\n346:\\tcase tabEventScrollToBottom:\\n347:\\t\\ttab.mu.Lock()\\n348:\\t\\tif tab.Terminal != nil && tab.Terminal.IsScrolled() {\\n349:\\t\\t\\ttab.Terminal.ScrollViewToBottom()\\n350:\\t\\t}\\n351:\\t\\ttab.mu.Unlock()\\n352:\\tcase tabEventScrollPage:\\n353:\\t\\ttab.mu.Lock()\\n354:\\t\\tif tab.Terminal != nil && ev.scrollPage != 0 {\\n355:\\t\\t\\tdelta := tab.Terminal.Height / 4\\n356:\\t\\t\\tif delta < 1 {\\n357:\\t\\t\\t\\tdelta = 1\\n358:\\t\\t\\t}\\n359:\\t\\t\\ttab.Terminal.ScrollView(delta * ev.scrollPage)\\n360:\\t\\t}\\n361:\\t\\ttab.mu.Unlock()\\n362:\\tcase tabEventScrollToTop:\\n363:\\t\\ttab.mu.Lock()\\n364:\\t\\tif tab.Terminal != nil {\\n365:\\t\\t\\ttab.Terminal.ScrollViewToTop()\\n366:\\t\\t}\\n367:\\t\\ttab.mu.Unlock()\\n368:\\tcase tabEventDiffInput:\\n369:\\t\\ttab.mu.Lock()\\n370:\\t\\tdv := tab.DiffViewer\\n371:\\t\\tif dv == nil {\\n372:\\t\\t\\ttab.mu.Unlock()\\n373:\\t\\t\\treturn\\n374:\\t\\t}\\n375:\\t\\tnewDV, cmd := dv.Update(ev.diffMsg)\\n376:\\t\\ttab.DiffViewer = newDV\\n377:\\t\\ttab.mu.Unlock()\\n378:\\t\\tif cmd != nil && m.msgSink != nil {\\n379:\\t\\t\\tm.msgSink(tabDiffCmd{cmd: cmd})\\n380:\\t\\t}\\n381:\\tcase tabEventSendInput:\\n382:\\t\\tm.sendToTerminal(tab, string(ev.input), ev.tabID, ev.workspaceID, \\\"Input\\\")\\n383:\\tcase tabEventPaste:\\n384:\\t\\tif ev.pasteText != \\\"\\\" {\\n385:\\t\\t\\tm.sendToTerminal(tab, \\\"\\\\x1b[200~\\\"+ev.pasteText+\\\"\\\\x1b[201~\\\", ev.tabID, ev.workspaceID, \\\"Paste\\\")\\n386:\\t\\t}\\n387:\\tcase tabEventWriteOutput:\\n388:\\t\\tprocessedBytes := len(ev.output)\\n389:\\t\\ttagSessionName := \\\"\\\"\\n390:\\t\\tvar tagTimestamp int64\\n391:\\t\\tfilteredLen := 0\\n392:\\t\\tfilterApplied := false\\n393:\\t\\trequestFlush := false\\n394:\\t\\tstaleWrite := false\\n395:\\t\\tsuppressRedraw := false\\n396:\\t\\ttab.mu.Lock()\\n397:\\t\\tif ev.writeEpoch != tab.actorWriteEpoch {\\n398:\\t\\t\\tstaleWrite = true\\n399:\\t\\t} else if tab.Terminal != nil {\\n400:\\t\\t\\toutput := common.FilterKnownPTYNoiseStream(ev.output, &tab.ptyNoiseTrailing)\\n401:\\t\\t\\tfilteredLen = len(output)\\n402:\\t\\t\\tfilterApplied = true\\n403:\\t\\t\\tif len(output) > 0 {\\n404:\\t\\t\\t\\tflushDone := perf.Time(\\\"pty_flush\\\")\\n405:\\t\\t\\t\\ttab.Terminal.Write(output)\\n406:\\t\\t\\t\\tflushDone()\\n407:\\t\\t\\t\\tperf.Count(\\\"pty_flush_bytes\\\", int64(len(output)))\\n408:\\t\\t\\t}\\n409:\\t\\t\\t// Activity state intentionally tracks visible terminal mutations only.\\n410:\\t\\t\\t// Noise-only chunks are filtered above and must not update activity tags.\\n411:\\t\\t\\ttagSessionName, tagTimestamp, _ = m.noteVisibleActivityLockedWithOutput(tab, ev.hasMoreBuffered, ev.visibleSeq, output)\\n412:\\t\\t\\tif tab.actorWritesPending > 0 {\\n413:\\t\\t\\t\\ttab.actorWritesPending--\\n414:\\t\\t\\t}\\n415:\\t\\t\\tif tab.actorQueuedBytes >= processedBytes {\\n416:\\t\\t\\t\\ttab.actorQueuedBytes -= processedBytes\\n417:\\t\\t\\t} else {\\n418:\\t\\t\\t\\ttab.actorQueuedBytes = 0\\n419:\\t\\t\\t}\\n420:\\t\\t\\tcatchUpBefore, catchUpAfter := tab.settlePTYBytesLocked(processedBytes)\\n421:\\t\\t\\tsuppressRedraw = catchUpBefore && catchUpAfter\\n422:\\t\\t\\tif tab.actorWritesPending == 0 {\\n423:\\t\\t\\t\\ttab.actorQueuedCarry = tab.Terminal.ParserCarryState()\\n424:\\t\\t\\t\\ttab.actorQueuedNoiseTrailing = append(tab.actorQueuedNoiseTrailing[:0], tab.ptyNoiseTrailing...)\\n425:\\t\\t\\t\\tif tab.parserResetPending {\\n426:\\t\\t\\t\\t\\ttab.Terminal.ResetParserState()\\n427:\\t\\t\\t\\t\\ttab.activityANSIState = ansiActivityText\\n428:\\t\\t\\t\\t\\ttab.ptyNoiseTrailing = nil\\n429:\\t\\t\\t\\t\\ttab.actorQueuedCarry = tab.Terminal.ParserCarryState()\\n430:\\t\\t\\t\\t\\ttab.actorQueuedNoiseTrailing = tab.actorQueuedNoiseTrailing[:0]\\n431:\\t\\t\\t\\t\\ttab.parserResetPending = false\\n432:\\t\\t\\t\\t\\trequestFlush = true\\n433:\\t\\t\\t\\t}\\n434:\\t\\t\\t}\\n435:\\t\\t}\\n436:\\t\\ttab.mu.Unlock()\\n437:\\t\\tif staleWrite {\\n438:\\t\\t\\treturn\\n439:\\t\\t}\\n440:\\t\\tperf.Count(\\\"pty_flush_bytes_processed\\\", int64(processedBytes))\\n441:\\t\\tif filterApplied {\\n442:\\t\\t\\tfilteredBytes := processedBytes - filteredLen\\n443:\\t\\t\\tif filteredBytes > 0 {\\n444:\\t\\t\\t\\tperf.Count(\\\"pty_flush_bytes_filtered\\\", int64(filteredBytes))\\n445:\\t\\t\\t}\\n446:\\t\\t}\\n447:\\t\\tif tagSessionName != \\\"\\\" {\\n448:\\t\\t\\topts := m.getTmuxOptions()\\n449:\\t\\t\\tsessionName := tagSessionName\\n450:\\t\\t\\ttimestamp := strconv.FormatInt(tagTimestamp, 10)\\n451:\\t\\t\\tgo func() {\\n452:\\t\\t\\t\\t_ = tmux.SetSessionTagValue(sessionName, tmux.TagLastOutputAt, timestamp, opts)\\n453:\\t\\t\\t}()\\n454:\\t\\t}\\n455:\\t\\tif requestFlush && m.msgSink != nil {\\n456:\\t\\t\\tm.msgSink(PTYFlush{WorkspaceID: ev.workspaceID, TabID: ev.tabID, CatchUp: ev.catchUp})\\n457:\\t\\t}\\n458:\\t\\tif !suppressRedraw && m.msgSink != nil && m.shouldPostWriteRedraw(tab) {\\n459:\\t\\t\\t// Visible tabs need one redraw after actor-applied terminal writes.\\n460:\\t\\t\\tm.msgSink(PTYCursorRefresh{WorkspaceID: ev.workspaceID, TabID: ev.tabID})\\n461:\\t\\t}\\n462:\\tdefault:\\n463:\\t\\tlogging.Debug(\\\"unknown tab event: %v\\\", ev.kind)\\n464:\\t}\\n465:}\\n466:\\n467:func (m *Model) sendToTerminal(tab *Tab, data string, tabID TabID, workspaceID, label string) {\\n468:\\tif tab == nil || tab.Agent == nil || tab.Agent.Terminal == nil {\\n469:\\t\\treturn\\n470:\\t}\\n471:\\tif data == \\\"\\\" {\\n472:\\t\\treturn\\n473:\\t}\\n474:\\tif err := tab.Agent.Terminal.SendString(data); err != nil {\\n475:\\t\\tlogging.Warn(\\\"%s failed for tab %s: %v\\\", label, tab.ID, err)\\n476:\\t\\ttab.mu.Lock()\\n477:\\t\\ttab.Running = false\\n478:\\t\\ttab.Detached = true\\n479:\\t\\ttab.mu.Unlock()\\n480:\\t\\tif m.msgSink != nil {\\n481:\\t\\t\\tm.msgSink(TabInputFailed{TabID: tabID, WorkspaceID: workspaceID, Err: err})\\n482:\\t\\t}\\n483:\\t\\treturn\\n484:\\t}\\n485:\\trecordLocalInputEchoWindow(tab, data, time.Now())\\n486:\\tif m.msgSink != nil && m.isChatTab(tab) {\\n487:\\t\\tm.msgSink(PTYCursorRefresh{WorkspaceID: workspaceID, TabID: tabID})\\n488:\\t}\\n489:}]]>\\n</file>\")] } }, ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_01_DzFiJ6WOS2S7i9ecW6ezc8SU\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/Documents/projects/amux/polecats/rust/badmux/internal/ui/center/model_input_lifecycle.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"269\\\"\\n><![CDATA[  1:package center\\n  2:\\n  3:import (\\n  4:\\t\\\"fmt\\\"\\n  5:\\t\\\"strconv\\\"\\n  6:\\t\\\"time\\\"\\n  7:\\n  8:\\ttea \\\"charm.land/bubbletea/v2\\\"\\n  9:\\n 10:\\t\\\"github.com/andyrewlee/amux/internal/logging\\\"\\n 11:\\t\\\"github.com/andyrewlee/amux/internal/messages\\\"\\n 12:\\t\\\"github.com/andyrewlee/amux/internal/tmux\\\"\\n 13:\\t\\\"github.com/andyrewlee/amux/internal/ui/common\\\"\\n 14:\\t\\\"github.com/andyrewlee/amux/internal/vterm\\\"\\n 15:)\\n 16:\\n 17:const activityTagThrottle = 1 * time.Second\\n 18:\\n 19:func (m *Model) userInputActivityTagCmd(tab *Tab) tea.Cmd {\\n 20:\\tif tab == nil || tab.isClosed() || !m.isChatTab(tab) {\\n 21:\\t\\treturn nil\\n 22:\\t}\\n 23:\\tsessionName := tab.SessionName\\n 24:\\tif sessionName == \\\"\\\" && tab.Agent != nil {\\n 25:\\t\\tsessionName = tab.Agent.Session\\n 26:\\t}\\n 27:\\tif sessionName == \\\"\\\" {\\n 28:\\t\\treturn nil\\n 29:\\t}\\n 30:\\tnow := time.Now()\\n 31:\\tif now.Sub(tab.lastInputTagAt) < activityTagThrottle {\\n 32:\\t\\treturn nil\\n 33:\\t}\\n 34:\\ttab.lastInputTagAt = now\\n 35:\\topts := m.getTmuxOptions()\\n 36:\\ttimestamp := now.UnixMilli()\\n 37:\\treturn func() tea.Msg {\\n 38:\\t\\traw := strconv.FormatInt(timestamp, 10)\\n 39:\\t\\t_ = tmux.SetSessionTagValues(sessionName, []tmux.OptionValue{\\n 40:\\t\\t\\t{Key: tmux.TagLastInputAt, Value: raw},\\n 41:\\t\\t\\t{Key: tmux.TagSessionLeaseAt, Value: raw},\\n 42:\\t\\t}, opts)\\n 43:\\t\\treturn nil\\n 44:\\t}\\n 45:}\\n 46:\\n 47:// updateLaunchAgent handles messages.LaunchAgent.\\n 48:func (m *Model) updateLaunchAgent(msg messages.LaunchAgent) (*Model, tea.Cmd) {\\n 49:\\treturn m, m.createAgentTabWithMetadata(msg.Assistant, msg.Workspace, msg.TicketID, msg.TicketTitle, msg.Model, msg.AgentMode)\\n 50:}\\n 51:\\n 52:// updateOpenFileInVim handles messages.OpenFileInVim.\\n 53:func (m *Model) updateOpenFileInVim(msg messages.OpenFileInVim) (*Model, tea.Cmd) {\\n 54:\\treturn m, m.createVimTab(msg.Path, msg.Workspace)\\n 55:}\\n 56:\\n 57:// updatePtyTabCreateResult handles ptyTabCreateResult.\\n 58:func (m *Model) updatePtyTabCreateResult(msg ptyTabCreateResult) (*Model, tea.Cmd) {\\n 59:\\treturn m, m.handlePtyTabCreated(msg)\\n 60:}\\n 61:\\n 62:func (m *Model) sessionRestoreLiveSize(captureFullPane bool, captureCols, captureRows int) (int, int) {\\n 63:\\tif captureFullPane && captureCols > 0 && captureRows > 0 && (m.width <= 0 || m.height <= 0) {\\n 64:\\t\\treturn captureCols, captureRows\\n 65:\\t}\\n 66:\\ttm := m.terminalMetrics()\\n 67:\\tcols := tm.Width\\n 68:\\trows := tm.Height\\n 69:\\tif cols <= 0 || rows <= 0 {\\n 70:\\t\\treturn 80, 24\\n 71:\\t}\\n 72:\\treturn cols, rows\\n 73:}\\n 74:\\n 75:// updatePtyTabReattachResult handles ptyTabReattachResult.\\n 76:func (m *Model) updatePtyTabReattachResult(msg ptyTabReattachResult) (*Model, tea.Cmd) {\\n 77:\\ttab := m.getTabByID(msg.WorkspaceID, msg.TabID)\\n 78:\\tif tab == nil || msg.Agent == nil {\\n 79:\\t\\treturn m, nil\\n 80:\\t}\\n 81:\\tcaptureRows := msg.Rows\\n 82:\\tcaptureCols := msg.Cols\\n 83:\\tcols, rows := m.sessionRestoreLiveSize(msg.CaptureFullPane, captureCols, captureRows)\\n 84:\\tinitialCols, initialRows := common.SessionSnapshotSize(msg.CaptureFullPane, msg.SnapshotCols, msg.SnapshotRows, cols, rows)\\n 85:\\ttab.mu.Lock()\\n 86:\\tcreatedTerminal := false\\n 87:\\tif tab.Terminal == nil {\\n 88:\\t\\ttab.Terminal = vterm.New(initialCols, initialRows)\\n 89:\\t\\tcreatedTerminal = true\\n 90:\\t}\\n 91:\\tif tab.Terminal != nil {\\n 92:\\t\\t// Do not reset parser state when reusing an existing terminal here.\\n 93:\\t\\t// pendingOutput may still contain continuation bytes queued under the\\n 94:\\t\\t// current parser carry, and reconnect must preserve that continuity until\\n 95:\\t\\t// buffered output is explicitly reconciled.\\n 96:\\t\\ttab.Terminal.AllowAltScreenScrollback = true\\n 97:\\t\\tm.applyTerminalCursorPolicyLocked(tab)\\n 98:\\t\\tif msg.CaptureFullPane {\\n 99:\\t\\t\\t// The tmux snapshot is now the source of truth for the restored frame.\\n100:\\t\\t\\t// Any preserved local PTY backlog may already be represented there and\\n101:\\t\\t\\t// would duplicate on the next flush if we kept it alive.\\n102:\\t\\t\\ttab.pendingOutput = nil\\n103:\\t\\t\\tcommon.RestorePaneCapture(\\n104:\\t\\t\\t\\ttab.Terminal,\\n105:\\t\\t\\t\\tmsg.ScrollbackCapture,\\n106:\\t\\t\\t\\tmsg.PostAttachScrollbackCapture,\\n107:\\t\\t\\t\\tmsg.SnapshotCursorX,\\n108:\\t\\t\\t\\tmsg.SnapshotCursorY,\\n109:\\t\\t\\t\\tmsg.SnapshotHasCursor,\\n110:\\t\\t\\t\\tmsg.SnapshotModeState,\\n111:\\t\\t\\t\\tmsg.SnapshotCols,\\n112:\\t\\t\\t\\tmsg.SnapshotRows,\\n113:\\t\\t\\t\\tcols,\\n114:\\t\\t\\t\\trows,\\n115:\\t\\t\\t)\\n116:\\t\\t} else if createdTerminal || len(tab.Terminal.Scrollback) == 0 {\\n117:\\t\\t\\tcommon.RestoreScrollbackCapture(tab.Terminal, msg.ScrollbackCapture, captureCols, captureRows, cols, rows)\\n118:\\t\\t} else if m.width > 0 && m.height > 0 {\\n119:\\t\\t\\tcommon.ResizeTerminalForSessionRestore(tab.Terminal, cols, rows)\\n120:\\t\\t}\\n121:\\t}\\n122:\\ttab.Agent = msg.Agent\\n123:\\ttab.SessionName = msg.Agent.Session\\n124:\\ttab.Detached = false\\n125:\\ttab.reattachInFlight = false\\n126:\\ttab.Running = true\\n127:\\tresetChatCursorActivityStateLocked(tab)\\n128:\\ttab.parserResetPending = false\\n129:\\ttab.settlePTYBytesLocked(tab.actorQueuedBytes)\\n130:\\ttab.actorQueuedBytes = 0\\n131:\\ttab.actorWritesPending = 0\\n132:\\ttab.actorWriteEpoch++\\n133:\\ttab.clearCatchUpLocked()\\n134:\\ttab.pendingOutputBytes = len(tab.pendingOutput)\\n135:\\ttab.overflowTrimCarry = vterm.ParserCarryState{}\\n136:\\ttab.ptyNoiseTrailing = nil\\n137:\\ttab.actorQueuedNoiseTrailing = tab.actorQueuedNoiseTrailing[:0]\\n138:\\ttab.actorQueuedCarry = tab.Terminal.ParserCarryState()\\n139:\\ttab.bootstrapActivity = true\\n140:\\ttab.bootstrapLastOutputAt = time.Now()\\n141:\\ttab.mu.Unlock()\\n142:\\ttab.resetActivityANSIState()\\n143:\\n144:\\tif tab.Terminal != nil && msg.Agent.Terminal != nil {\\n145:\\t\\tagentTerm := msg.Agent.Terminal\\n146:\\t\\tworkspaceID := msg.WorkspaceID\\n147:\\t\\ttabID := tab.ID\\n148:\\t\\ttab.Terminal.SetResponseWriter(func(data []byte) {\\n149:\\t\\t\\tif len(data) == 0 || agentTerm == nil {\\n150:\\t\\t\\t\\treturn\\n151:\\t\\t\\t}\\n152:\\t\\t\\tif err := agentTerm.SendString(string(data)); err != nil {\\n153:\\t\\t\\t\\tlogging.Warn(\\\"Response write failed for tab %s: %v\\\", tabID, err)\\n154:\\t\\t\\t\\tif m.msgSink != nil {\\n155:\\t\\t\\t\\t\\tm.msgSink(TabInputFailed{TabID: tabID, WorkspaceID: workspaceID, Err: err})\\n156:\\t\\t\\t\\t}\\n157:\\t\\t\\t}\\n158:\\t\\t})\\n159:\\t}\\n160:\\n161:\\tm.resizePTY(tab, rows, cols)\\n162:\\n163:\\tcmd := m.startPTYReader(msg.WorkspaceID, tab)\\n164:\\treturn m, common.SafeBatch(cmd, func() tea.Msg {\\n165:\\t\\treturn messages.TabReattached{WorkspaceID: msg.WorkspaceID, TabID: string(msg.TabID)}\\n166:\\t})\\n167:}\\n168:\\n169:// updatePtyTabReattachFailed handles ptyTabReattachFailed.\\n170:func (m *Model) updatePtyTabReattachFailed(msg ptyTabReattachFailed) (*Model, tea.Cmd) {\\n171:\\ttab := m.getTabByID(msg.WorkspaceID, msg.TabID)\\n172:\\tif tab == nil {\\n173:\\t\\treturn m, nil\\n174:\\t}\\n175:\\ttab.mu.Lock()\\n176:\\ttab.Running = false\\n177:\\ttab.reattachInFlight = false\\n178:\\t// Any stopped reattach clears Detached so the tab shows as stopped.\\n179:\\tif msg.Stopped {\\n180:\\t\\ttab.Detached = false\\n181:\\t}\\n182:\\ttab.mu.Unlock()\\n183:\\tlogging.Warn(\\\"Reattach failed for tab %s: %v\\\", msg.TabID, msg.Err)\\n184:\\taction := msg.Action\\n185:\\tif action == \\\"\\\" {\\n186:\\t\\taction = \\\"reattach\\\"\\n187:\\t}\\n188:\\tlabel := \\\"Reattach\\\"\\n189:\\tswitch action {\\n190:\\tcase \\\"restart\\\":\\n191:\\t\\tlabel = \\\"Restart\\\"\\n192:\\tcase \\\"reattach\\\":\\n193:\\t\\tlabel = \\\"Reattach\\\"\\n194:\\t}\\n195:\\treturn m, common.SafeBatch(func() tea.Msg {\\n196:\\t\\treturn messages.TabStateChanged{WorkspaceID: msg.WorkspaceID, TabID: string(msg.TabID)}\\n197:\\t}, func() tea.Msg {\\n198:\\t\\treturn messages.Toast{\\n199:\\t\\t\\tMessage: fmt.Sprintf(\\\"%s failed: %v\\\", label, msg.Err),\\n200:\\t\\t\\tLevel:   messages.ToastWarning,\\n201:\\t\\t}\\n202:\\t})\\n203:}\\n204:\\n205:// updateTabSessionStatus handles messages.TabSessionStatus.\\n206:func (m *Model) updateTabSessionStatus(msg messages.TabSessionStatus) (*Model, tea.Cmd) {\\n207:\\tif msg.Status != \\\"stopped\\\" {\\n208:\\t\\treturn m, nil\\n209:\\t}\\n210:\\ttab := m.getTabBySession(msg.WorkspaceID, msg.SessionName)\\n211:\\tif tab == nil {\\n212:\\t\\treturn m, nil\\n213:\\t}\\n214:\\tm.stopPTYReader(tab)\\n215:\\ttab.mu.Lock()\\n216:\\tagent := tab.Agent\\n217:\\ttab.Agent = nil\\n218:\\ttab.mu.Unlock()\\n219:\\tif agent != nil {\\n220:\\t\\t_ = m.agentManager.CloseAgent(agent)\\n221:\\t}\\n222:\\ttab.mu.Lock()\\n223:\\ttab.Running = false\\n224:\\ttab.Detached = false\\n225:\\ttab.mu.Unlock()\\n226:\\ttab.resetActivityANSIState()\\n227:\\treturn m, common.SafeBatch(func() tea.Msg {\\n228:\\t\\treturn messages.TabStateChanged{WorkspaceID: msg.WorkspaceID, TabID: string(tab.ID)}\\n229:\\t})\\n230:}\\n231:\\n232:// updateOpenDiff handles messages.OpenDiff.\\n233:func (m *Model) updateOpenDiff(msg messages.OpenDiff) (*Model, tea.Cmd) {\\n234:\\tif msg.Change == nil {\\n235:\\t\\treturn m, nil\\n236:\\t}\\n237:\\treturn m, m.createDiffTab(msg.Change, msg.Mode, msg.Workspace)\\n238:}\\n239:\\n240:// updateWorkspaceDeleted handles messages.WorkspaceDeleted.\\n241:func (m *Model) updateWorkspaceDeleted(msg messages.WorkspaceDeleted) (*Model, tea.Cmd) {\\n242:\\tm.CleanupWorkspace(msg.Workspace)\\n243:\\treturn m, nil\\n244:}\\n245:\\n246:// updateTabSelectionResult handles tabSelectionResult.\\n247:func (m *Model) updateTabSelectionResult(msg tabSelectionResult) (*Model, tea.Cmd) {\\n248:\\tif msg.clipboard != \\\"\\\" {\\n249:\\t\\tif err := common.CopyToClipboard(msg.clipboard); err != nil {\\n250:\\t\\t\\tlogging.Error(\\\"Failed to copy to clipboard: %v\\\", err)\\n251:\\t\\t} else {\\n252:\\t\\t\\tlogging.Info(\\\"Copied %d chars to clipboard\\\", len(msg.clipboard))\\n253:\\t\\t}\\n254:\\t}\\n255:\\treturn m, nil\\n256:}\\n257:\\n258:// updateSelectionTickRequest handles selectionTickRequest.\\n259:func (m *Model) updateSelectionTickRequest(msg selectionTickRequest) (*Model, tea.Cmd) {\\n260:\\tcmd := common.SafeTick(100*time.Millisecond, func(time.Time) tea.Msg {\\n261:\\t\\treturn selectionScrollTick{WorkspaceID: msg.workspaceID, TabID: msg.tabID, Gen: msg.gen}\\n262:\\t})\\n263:\\treturn m, cmd\\n264:}\\n265:\\n266:// updateTabDiffCmd handles tabDiffCmd.\\n267:func (m *Model) updateTabDiffCmd(msg tabDiffCmd) (*Model, tea.Cmd) {\\n268:\\treturn m, msg.cmd\\n269:}]]>\\n</file>\")] } }, ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_02_FV1ppOsN9vEWz6kKdlXIdyEK\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/Documents/projects/amux/polecats/rust/badmux/internal/ui/center/model_input.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"447\\\"\\n><![CDATA[  1:package center\\n  2:\\n  3:import (\\n  4:\\t\\\"time\\\"\\n  5:\\n  6:\\t\\\"charm.land/bubbles/v2/key\\\"\\n  7:\\ttea \\\"charm.land/bubbletea/v2\\\"\\n  8:\\n  9:\\t\\\"github.com/andyrewlee/amux/internal/logging\\\"\\n 10:\\t\\\"github.com/andyrewlee/amux/internal/messages\\\"\\n 11:\\t\\\"github.com/andyrewlee/amux/internal/perf\\\"\\n 12:\\t\\\"github.com/andyrewlee/amux/internal/ui/common\\\"\\n 13:)\\n 14:\\n 15:// directSendToTerminal sends data directly to the terminal, handling errors.\\n 16:// Returns whether data was actually sent and an optional command for failures.\\n 17:func (m *Model) directSendToTerminal(tab *Tab, data, label string) (*Model, bool, tea.Cmd) {\\n 18:\\tif tab.Agent == nil || tab.Agent.Terminal == nil {\\n 19:\\t\\treturn m, false, nil\\n 20:\\t}\\n 21:\\tif err := tab.Agent.Terminal.SendString(data); err != nil {\\n 22:\\t\\tlogging.Warn(\\\"%s failed for tab %s: %v\\\", label, tab.ID, err)\\n 23:\\t\\ttab.mu.Lock()\\n 24:\\t\\ttab.Running = false\\n 25:\\t\\ttab.Detached = true\\n 26:\\t\\ttab.mu.Unlock()\\n 27:\\t\\twsID := m.workspaceID()\\n 28:\\t\\treturn m, false, func() tea.Msg {\\n 29:\\t\\t\\treturn TabInputFailed{TabID: tab.ID, WorkspaceID: wsID, Err: err}\\n 30:\\t\\t}\\n 31:\\t}\\n 32:\\treturn m, true, nil\\n 33:}\\n 34:\\n 35:// noteLocalInput records local typing/editing activity for activity suppression\\n 36:// and chat cursor tracking, and schedules a redraw for timer-driven cursor\\n 37:// state changes.\\n 38:func (m *Model) noteLocalInput(tab *Tab, workspaceID, data string, now time.Time) tea.Cmd {\\n 39:\\tif tab == nil {\\n 40:\\t\\treturn nil\\n 41:\\t}\\n 42:\\trecordLocalInputEchoWindow(tab, data, now)\\n 43:\\treturn m.scheduleChatCursorRefresh(tab, workspaceID, now)\\n 44:}\\n 45:\\n 46:// Update handles messages\\n 47:func (m *Model) Update(msg tea.Msg) (*Model, tea.Cmd) {\\n 48:\\tdefer perf.Time(\\\"center_update\\\")()\\n 49:\\tvar cmds []tea.Cmd\\n 50:\\n 51:\\tswitch msg := msg.(type) {\\n 52:\\tcase tea.MouseClickMsg:\\n 53:\\t\\tif m.draft != nil {\\n 54:\\t\\t\\treturn m, nil\\n 55:\\t\\t}\\n 56:\\t\\treturn m.updateMouseClick(msg)\\n 57:\\n 58:\\tcase tea.MouseMotionMsg:\\n 59:\\t\\treturn m.updateMouseMotion(msg)\\n 60:\\n 61:\\tcase tea.MouseReleaseMsg:\\n 62:\\t\\treturn m.updateMouseRelease(msg)\\n 63:\\n 64:\\tcase tea.MouseWheelMsg:\\n 65:\\t\\tif m.draft != nil {\\n 66:\\t\\t\\treturn m, nil\\n 67:\\t\\t}\\n 68:\\t\\treturn m.updateMouseWheel(msg)\\n 69:\\n 70:\\tcase tea.PasteMsg:\\n 71:\\t\\ttabs := m.getTabs()\\n 72:\\t\\tactiveIdx := m.getActiveTabIdx()\\n 73:\\t\\tif len(tabs) > 0 && activeIdx < len(tabs) {\\n 74:\\t\\t\\ttab := tabs[activeIdx]\\n 75:\\t\\t\\tif !m.focused {\\n 76:\\t\\t\\t\\treturn m, nil\\n 77:\\t\\t\\t}\\n 78:\\t\\t\\tif m.isTabActorReady() {\\n 79:\\t\\t\\t\\tqueued := m.sendTabEvent(tabEvent{\\n 80:\\t\\t\\t\\t\\ttab:         tab,\\n 81:\\t\\t\\t\\t\\tworkspaceID: m.workspaceID(),\\n 82:\\t\\t\\t\\t\\ttabID:       tab.ID,\\n 83:\\t\\t\\t\\t\\tkind:        tabEventPaste,\\n 84:\\t\\t\\t\\t\\tpasteText:   msg.Content,\\n 85:\\t\\t\\t\\t})\\n 86:\\t\\t\\t\\t// When the actor accepts the event, it will stamp local-input\\n 87:\\t\\t\\t\\t// timing after the PTY write actually happens. Doing it here at\\n 88:\\t\\t\\t\\t// enqueue time would make queue latency look like local echo.\\n 89:\\t\\t\\t\\tif !queued {\\n 90:\\t\\t\\t\\t\\tif _, sent, cmd := m.directSendToTerminal(tab, \\\"\\\\x1b[200~\\\"+msg.Content+\\\"\\\\x1b[201~\\\", \\\"Direct paste\\\"); cmd != nil {\\n 91:\\t\\t\\t\\t\\t\\treturn m, cmd\\n 92:\\t\\t\\t\\t\\t} else if !sent {\\n 93:\\t\\t\\t\\t\\t\\treturn m, nil\\n 94:\\t\\t\\t\\t\\t}\\n 95:\\t\\t\\t\\t\\tnow := time.Now()\\n 96:\\t\\t\\t\\t\\tpayload := \\\"\\\\x1b[200~\\\" + msg.Content + \\\"\\\\x1b[201~\\\"\\n 97:\\t\\t\\t\\t\\tcmds = append(cmds, m.noteLocalInput(tab, m.workspaceID(), payload, now))\\n 98:\\t\\t\\t\\t}\\n 99:\\t\\t\\t\\tlogging.Debug(\\\"Pasted %d bytes via bracketed paste\\\", len(msg.Content))\\n100:\\t\\t\\t\\tcmds = append(cmds, m.userInputActivityTagCmd(tab))\\n101:\\t\\t\\t\\treturn m, common.SafeBatch(cmds...)\\n102:\\t\\t\\t}\\n103:\\t\\t\\tif _, sent, cmd := m.directSendToTerminal(tab, \\\"\\\\x1b[200~\\\"+msg.Content+\\\"\\\\x1b[201~\\\", \\\"Direct paste\\\"); cmd != nil {\\n104:\\t\\t\\t\\treturn m, cmd\\n105:\\t\\t\\t} else if !sent {\\n106:\\t\\t\\t\\treturn m, nil\\n107:\\t\\t\\t}\\n108:\\t\\t\\tlogging.Debug(\\\"Pasted %d bytes via bracketed paste\\\", len(msg.Content))\\n109:\\t\\t\\tnow := time.Now()\\n110:\\t\\t\\tpayload := \\\"\\\\x1b[200~\\\" + msg.Content + \\\"\\\\x1b[201~\\\"\\n111:\\t\\t\\tcmds = append(cmds, m.noteLocalInput(tab, m.workspaceID(), payload, now))\\n112:\\t\\t\\tcmds = append(cmds, m.userInputActivityTagCmd(tab))\\n113:\\t\\t\\treturn m, common.SafeBatch(cmds...)\\n114:\\t\\t}\\n115:\\t\\treturn m, nil\\n116:\\n117:\\tcase tea.KeyPressMsg:\\n118:\\t\\tif m.draft != nil {\\n119:\\t\\t\\tnewDraft, cmd := m.draft.Update(msg)\\n120:\\t\\t\\tm.draft = newDraft\\n121:\\t\\t\\treturn m, cmd\\n122:\\t\\t}\\n123:\\n124:\\t\\ttabs := m.getTabs()\\n125:\\t\\tactiveIdx := m.getActiveTabIdx()\\n126:\\t\\tlogging.Debug(\\\"Center received key: %s, focused=%v, hasTabs=%v, numTabs=%d\\\",\\n127:\\t\\t\\tmsg.String(), m.focused, m.hasActiveAgent(), len(tabs))\\n128:\\n129:\\t\\t// Check if this is Cmd+C (copy command)\\n130:\\t\\tk := msg.Key()\\n131:\\t\\tisCopyKey := k.Mod.Contains(tea.ModSuper) && k.Code == 'c'\\n132:\\n133:\\t\\t// Handle explicit Cmd+C to copy current selection\\n134:\\t\\tif isCopyKey && len(tabs) > 0 && activeIdx < len(tabs) {\\n135:\\t\\t\\ttab := tabs[activeIdx]\\n136:\\t\\t\\tif m.isTabActorReady() {\\n137:\\t\\t\\t\\tif m.sendTabEvent(tabEvent{\\n138:\\t\\t\\t\\t\\ttab:         tab,\\n139:\\t\\t\\t\\t\\tworkspaceID: m.workspaceID(),\\n140:\\t\\t\\t\\t\\ttabID:       tab.ID,\\n141:\\t\\t\\t\\t\\tkind:        tabEventSelectionCopy,\\n142:\\t\\t\\t\\t\\tnotifyCopy:  true,\\n143:\\t\\t\\t\\t}) {\\n144:\\t\\t\\t\\t\\treturn m, nil\\n145:\\t\\t\\t\\t}\\n146:\\t\\t\\t}\\n147:\\t\\t\\ttab.mu.Lock()\\n148:\\t\\t\\tif tab.Terminal != nil && tab.Terminal.HasSelection() {\\n149:\\t\\t\\t\\ttext := tab.Terminal.SelectedText()\\n150:\\t\\t\\t\\tif text != \\\"\\\" {\\n151:\\t\\t\\t\\t\\tif err := common.CopyToClipboard(text); err != nil {\\n152:\\t\\t\\t\\t\\t\\tlogging.Error(\\\"Failed to copy to clipboard: %v\\\", err)\\n153:\\t\\t\\t\\t\\t} else {\\n154:\\t\\t\\t\\t\\t\\tlogging.Info(\\\"Cmd+C copied %d chars to clipboard\\\", len(text))\\n155:\\t\\t\\t\\t\\t}\\n156:\\t\\t\\t\\t}\\n157:\\t\\t\\t}\\n158:\\t\\t\\ttab.mu.Unlock()\\n159:\\t\\t\\treturn m, nil // Don't forward to terminal, don't clear selection\\n160:\\t\\t}\\n161:\\n162:\\t\\t// Clear any selection when user types (except Cmd+C which is handled above)\\n163:\\t\\tif len(tabs) > 0 && activeIdx < len(tabs) {\\n164:\\t\\t\\ttab := tabs[activeIdx]\\n165:\\t\\t\\tsent := false\\n166:\\t\\t\\tif m.isTabActorReady() {\\n167:\\t\\t\\t\\tsent = m.sendTabEvent(tabEvent{\\n168:\\t\\t\\t\\t\\ttab:         tab,\\n169:\\t\\t\\t\\t\\tworkspaceID: m.workspaceID(),\\n170:\\t\\t\\t\\t\\ttabID:       tab.ID,\\n171:\\t\\t\\t\\t\\tkind:        tabEventSelectionClear,\\n172:\\t\\t\\t\\t})\\n173:\\t\\t\\t}\\n174:\\t\\t\\tif !sent {\\n175:\\t\\t\\t\\ttab.mu.Lock()\\n176:\\t\\t\\t\\tif tab.Terminal != nil {\\n177:\\t\\t\\t\\t\\ttab.Terminal.ClearSelection()\\n178:\\t\\t\\t\\t}\\n179:\\t\\t\\t\\ttab.Selection = common.SelectionState{}\\n180:\\t\\t\\t\\ttab.selectionScroll.Reset()\\n181:\\t\\t\\t\\ttab.mu.Unlock()\\n182:\\t\\t\\t}\\n183:\\t\\t}\\n184:\\n185:\\t\\tif !m.focused {\\n186:\\t\\t\\tlogging.Debug(\\\"Center not focused, ignoring key\\\")\\n187:\\t\\t\\treturn m, nil\\n188:\\t\\t}\\n189:\\n190:\\t\\t// When we have an active agent, handle keys\\n191:\\t\\tif m.hasActiveAgent() {\\n192:\\t\\t\\ttab := tabs[activeIdx]\\n193:\\t\\t\\tlogging.Debug(\\\"Has active agent, Agent=%v, Terminal=%v\\\", tab.Agent != nil, tab.Agent != nil && tab.Agent.Terminal != nil)\\n194:\\n195:\\t\\t\\t// DiffViewer tabs: forward keys to diff viewer\\n196:\\t\\t\\ttab.mu.Lock()\\n197:\\t\\t\\tdv := tab.DiffViewer\\n198:\\t\\t\\ttab.mu.Unlock()\\n199:\\t\\t\\tif dv != nil {\\n200:\\t\\t\\t\\t// Handle ctrl+w for closing tab\\n201:\\t\\t\\t\\tif key.Matches(msg, key.NewBinding(key.WithKeys(\\\"ctrl+w\\\"))) {\\n202:\\t\\t\\t\\t\\treturn m, m.closeCurrentTab()\\n203:\\t\\t\\t\\t}\\n204:\\t\\t\\t\\t// Handle ctrl+n/p for tab switching\\n205:\\t\\t\\t\\tif key.Matches(msg, key.NewBinding(key.WithKeys(\\\"ctrl+n\\\"))) {\\n206:\\t\\t\\t\\t\\tbefore := m.getActiveTabIdx()\\n207:\\t\\t\\t\\t\\tm.nextTab()\\n208:\\t\\t\\t\\t\\treturn m, m.tabSelectionChangedCmd(m.getActiveTabIdx() != before)\\n209:\\t\\t\\t\\t}\\n210:\\t\\t\\t\\tif key.Matches(msg, key.NewBinding(key.WithKeys(\\\"ctrl+p\\\"))) {\\n211:\\t\\t\\t\\t\\tbefore := m.getActiveTabIdx()\\n212:\\t\\t\\t\\t\\tm.prevTab()\\n213:\\t\\t\\t\\t\\treturn m, m.tabSelectionChangedCmd(m.getActiveTabIdx() != before)\\n214:\\t\\t\\t\\t}\\n215:\\t\\t\\t\\t// Forward all other keys to diff viewer\\n216:\\t\\t\\t\\tif handled, cmd := m.dispatchDiffInput(tab, msg); handled {\\n217:\\t\\t\\t\\t\\treturn m, cmd\\n218:\\t\\t\\t\\t}\\n219:\\t\\t\\t\\treturn m, nil\\n220:\\t\\t\\t}\\n221:\\n222:\\t\\t\\tif tab.Agent != nil && tab.Agent.Terminal != nil {\\n223:\\t\\t\\t\\t// Only intercept these specific keys - everything else goes to terminal\\n224:\\t\\t\\t\\tswitch {\\n225:\\t\\t\\t\\tcase key.Matches(msg, key.NewBinding(key.WithKeys(\\\"ctrl+n\\\"))):\\n226:\\t\\t\\t\\t\\tbefore := m.getActiveTabIdx()\\n227:\\t\\t\\t\\t\\tm.nextTab()\\n228:\\t\\t\\t\\t\\treturn m, m.tabSelectionChangedCmd(m.getActiveTabIdx() != before)\\n229:\\n230:\\t\\t\\t\\tcase key.Matches(msg, key.NewBinding(key.WithKeys(\\\"ctrl+p\\\"))):\\n231:\\t\\t\\t\\t\\tbefore := m.getActiveTabIdx()\\n232:\\t\\t\\t\\t\\tm.prevTab()\\n233:\\t\\t\\t\\t\\treturn m, m.tabSelectionChangedCmd(m.getActiveTabIdx() != before)\\n234:\\n235:\\t\\t\\t\\tcase key.Matches(msg, key.NewBinding(key.WithKeys(\\\"ctrl+w\\\"))):\\n236:\\t\\t\\t\\t\\t// Close tab\\n237:\\t\\t\\t\\t\\treturn m, m.closeCurrentTab()\\n238:\\n239:\\t\\t\\t\\tcase key.Matches(msg, key.NewBinding(key.WithKeys(\\\"ctrl+]\\\"))):\\n240:\\t\\t\\t\\t\\t// Switch to next tab (escape hatch that won't conflict)\\n241:\\t\\t\\t\\t\\tbefore := m.getActiveTabIdx()\\n242:\\t\\t\\t\\t\\tm.nextTab()\\n243:\\t\\t\\t\\t\\treturn m, m.tabSelectionChangedCmd(m.getActiveTabIdx() != before)\\n244:\\n245:\\t\\t\\t\\tcase key.Matches(msg, key.NewBinding(key.WithKeys(\\\"ctrl+[\\\"))):\\n246:\\t\\t\\t\\t\\t// This is Escape - let it go to terminal\\n247:\\t\\t\\t\\t\\tif _, sent, cmd := m.directSendToTerminal(tab, \\\"\\\\x1b\\\", \\\"Escape key\\\"); cmd != nil {\\n248:\\t\\t\\t\\t\\t\\treturn m, cmd\\n249:\\t\\t\\t\\t\\t} else if !sent {\\n250:\\t\\t\\t\\t\\t\\treturn m, nil\\n251:\\t\\t\\t\\t\\t}\\n252:\\t\\t\\t\\t\\tnow := time.Now()\\n253:\\t\\t\\t\\t\\tcmds = append(cmds, m.noteLocalInput(tab, m.workspaceID(), \\\"\\\\x1b\\\", now))\\n254:\\t\\t\\t\\t\\tcmds = append(cmds, m.userInputActivityTagCmd(tab))\\n255:\\t\\t\\t\\t\\treturn m, common.SafeBatch(cmds...)\\n256:\\t\\t\\t\\t}\\n257:\\n258:\\t\\t\\t\\t// PgUp/PgDown for scrollback (these don't conflict with embedded TUIs)\\n259:\\t\\t\\t\\tswitch msg.Key().Code {\\n260:\\t\\t\\t\\tcase tea.KeyPgUp:\\n261:\\t\\t\\t\\t\\tif m.isTabActorReady() {\\n262:\\t\\t\\t\\t\\t\\tif m.sendTabEvent(tabEvent{\\n263:\\t\\t\\t\\t\\t\\t\\ttab:         tab,\\n264:\\t\\t\\t\\t\\t\\t\\tworkspaceID: m.workspaceID(),\\n265:\\t\\t\\t\\t\\t\\t\\ttabID:       tab.ID,\\n266:\\t\\t\\t\\t\\t\\t\\tkind:        tabEventScrollPage,\\n267:\\t\\t\\t\\t\\t\\t\\tscrollPage:  1,\\n268:\\t\\t\\t\\t\\t\\t}) {\\n269:\\t\\t\\t\\t\\t\\t\\treturn m, nil\\n270:\\t\\t\\t\\t\\t\\t}\\n271:\\t\\t\\t\\t\\t}\\n272:\\t\\t\\t\\t\\ttab.mu.Lock()\\n273:\\t\\t\\t\\t\\tif tab.Terminal != nil {\\n274:\\t\\t\\t\\t\\t\\ttab.Terminal.ScrollView(tab.Terminal.Height / 4)\\n275:\\t\\t\\t\\t\\t}\\n276:\\t\\t\\t\\t\\ttab.mu.Unlock()\\n277:\\t\\t\\t\\t\\treturn m, nil\\n278:\\n279:\\t\\t\\t\\tcase tea.KeyPgDown:\\n280:\\t\\t\\t\\t\\tif m.isTabActorReady() {\\n281:\\t\\t\\t\\t\\t\\tif m.sendTabEvent(tabEvent{\\n282:\\t\\t\\t\\t\\t\\t\\ttab:         tab,\\n283:\\t\\t\\t\\t\\t\\t\\tworkspaceID: m.workspaceID(),\\n284:\\t\\t\\t\\t\\t\\t\\ttabID:       tab.ID,\\n285:\\t\\t\\t\\t\\t\\t\\tkind:        tabEventScrollPage,\\n286:\\t\\t\\t\\t\\t\\t\\tscrollPage:  -1,\\n287:\\t\\t\\t\\t\\t\\t}) {\\n288:\\t\\t\\t\\t\\t\\t\\treturn m, nil\\n289:\\t\\t\\t\\t\\t\\t}\\n290:\\t\\t\\t\\t\\t}\\n291:\\t\\t\\t\\t\\ttab.mu.Lock()\\n292:\\t\\t\\t\\t\\tif tab.Terminal != nil {\\n293:\\t\\t\\t\\t\\t\\ttab.Terminal.ScrollView(-tab.Terminal.Height / 4)\\n294:\\t\\t\\t\\t\\t}\\n295:\\t\\t\\t\\t\\ttab.mu.Unlock()\\n296:\\t\\t\\t\\t\\treturn m, nil\\n297:\\t\\t\\t\\t}\\n298:\\n299:\\t\\t\\t\\t// If scrolled, any typing goes back to live and sends key\\n300:\\t\\t\\t\\tsent := false\\n301:\\t\\t\\t\\tif m.isTabActorReady() {\\n302:\\t\\t\\t\\t\\tsent = m.sendTabEvent(tabEvent{\\n303:\\t\\t\\t\\t\\t\\ttab:         tab,\\n304:\\t\\t\\t\\t\\t\\tworkspaceID: m.workspaceID(),\\n305:\\t\\t\\t\\t\\t\\ttabID:       tab.ID,\\n306:\\t\\t\\t\\t\\t\\tkind:        tabEventScrollToBottom,\\n307:\\t\\t\\t\\t\\t})\\n308:\\t\\t\\t\\t}\\n309:\\t\\t\\t\\tif !sent {\\n310:\\t\\t\\t\\t\\ttab.mu.Lock()\\n311:\\t\\t\\t\\t\\tif tab.Terminal != nil && tab.Terminal.IsScrolled() {\\n312:\\t\\t\\t\\t\\t\\ttab.Terminal.ScrollViewToBottom()\\n313:\\t\\t\\t\\t\\t}\\n314:\\t\\t\\t\\t\\ttab.mu.Unlock()\\n315:\\t\\t\\t\\t}\\n316:\\n317:\\t\\t\\t\\t// Forward ALL keys to terminal (no Ctrl interceptions)\\n318:\\t\\t\\t\\tinput := common.KeyToBytes(msg)\\n319:\\t\\t\\t\\tif len(input) > 0 {\\n320:\\t\\t\\t\\t\\tlogging.Debug(\\\"Sending to terminal: %q (len=%d)\\\", input, len(input))\\n321:\\t\\t\\t\\t\\tqueued := false\\n322:\\t\\t\\t\\t\\tif m.isTabActorReady() {\\n323:\\t\\t\\t\\t\\t\\tqueued = m.sendTabEvent(tabEvent{\\n324:\\t\\t\\t\\t\\t\\t\\ttab:         tab,\\n325:\\t\\t\\t\\t\\t\\t\\tworkspaceID: m.workspaceID(),\\n326:\\t\\t\\t\\t\\t\\t\\ttabID:       tab.ID,\\n327:\\t\\t\\t\\t\\t\\t\\tkind:        tabEventSendInput,\\n328:\\t\\t\\t\\t\\t\\t\\tinput:       input,\\n329:\\t\\t\\t\\t\\t\\t})\\n330:\\t\\t\\t\\t\\t\\tif !queued {\\n331:\\t\\t\\t\\t\\t\\t\\tif _, sent, cmd := m.directSendToTerminal(tab, string(input), \\\"Direct input\\\"); cmd != nil {\\n332:\\t\\t\\t\\t\\t\\t\\t\\treturn m, cmd\\n333:\\t\\t\\t\\t\\t\\t\\t} else if !sent {\\n334:\\t\\t\\t\\t\\t\\t\\t\\treturn m, nil\\n335:\\t\\t\\t\\t\\t\\t\\t}\\n336:\\t\\t\\t\\t\\t\\t\\tcmds = append(cmds, m.noteLocalInput(tab, m.workspaceID(), string(input), time.Now()))\\n337:\\t\\t\\t\\t\\t\\t}\\n338:\\t\\t\\t\\t\\t} else {\\n339:\\t\\t\\t\\t\\t\\tif _, sent, cmd := m.directSendToTerminal(tab, string(input), \\\"Direct input\\\"); cmd != nil {\\n340:\\t\\t\\t\\t\\t\\t\\treturn m, cmd\\n341:\\t\\t\\t\\t\\t\\t} else if !sent {\\n342:\\t\\t\\t\\t\\t\\t\\treturn m, nil\\n343:\\t\\t\\t\\t\\t\\t}\\n344:\\t\\t\\t\\t\\t\\tcmds = append(cmds, m.noteLocalInput(tab, m.workspaceID(), string(input), time.Now()))\\n345:\\t\\t\\t\\t\\t}\\n346:\\t\\t\\t\\t\\tcmds = append(cmds, m.userInputActivityTagCmd(tab))\\n347:\\t\\t\\t\\t\\treturn m, common.SafeBatch(cmds...)\\n348:\\t\\t\\t\\t}\\n349:\\t\\t\\t\\tlogging.Debug(\\\"keyToBytes returned empty for: %s\\\", msg.String())\\n350:\\t\\t\\t\\treturn m, nil\\n351:\\t\\t\\t}\\n352:\\t\\t}\\n353:\\n354:\\tcase DraftComplete:\\n355:\\t\\tm.draft = nil\\n356:\\t\\treturn m, func() tea.Msg {\\n357:\\t\\t\\treturn messages.LaunchAgent{\\n358:\\t\\t\\t\\tAssistant:   msg.Assistant,\\n359:\\t\\t\\t\\tWorkspace:   msg.Workspace,\\n360:\\t\\t\\t\\tTicketID:    msg.TicketID,\\n361:\\t\\t\\t\\tTicketTitle: msg.TicketTitle,\\n362:\\t\\t\\t\\tModel:       msg.Model,\\n363:\\t\\t\\t\\tAgentMode:   msg.AgentMode,\\n364:\\t\\t\\t}\\n365:\\t\\t}\\n366:\\n367:\\tcase DraftCancelled:\\n368:\\t\\tm.draft = nil\\n369:\\t\\treturn m, nil\\n370:\\n371:\\tcase messages.LaunchAgent:\\n372:\\t\\treturn m.updateLaunchAgent(msg)\\n373:\\n374:\\tcase messages.OpenFileInVim:\\n375:\\t\\treturn m.updateOpenFileInVim(msg)\\n376:\\n377:\\tcase ptyTabCreateResult:\\n378:\\t\\treturn m.updatePtyTabCreateResult(msg)\\n379:\\n380:\\tcase ptyTabReattachResult:\\n381:\\t\\treturn m.updatePtyTabReattachResult(msg)\\n382:\\n383:\\tcase ptyTabReattachFailed:\\n384:\\t\\treturn m.updatePtyTabReattachFailed(msg)\\n385:\\n386:\\tcase messages.TabSessionStatus:\\n387:\\t\\treturn m.updateTabSessionStatus(msg)\\n388:\\n389:\\tcase messages.OpenDiff:\\n390:\\t\\treturn m.updateOpenDiff(msg)\\n391:\\n392:\\tcase messages.WorkspaceDeleted:\\n393:\\t\\treturn m.updateWorkspaceDeleted(msg)\\n394:\\n395:\\tcase tabSelectionResult:\\n396:\\t\\treturn m.updateTabSelectionResult(msg)\\n397:\\n398:\\tcase selectionTickRequest:\\n399:\\t\\treturn m.updateSelectionTickRequest(msg)\\n400:\\n401:\\tcase tabDiffCmd:\\n402:\\t\\treturn m.updateTabDiffCmd(msg)\\n403:\\n404:\\tcase tabActorRedraw:\\n405:\\t\\tm.clearTabActorRedrawPending()\\n406:\\t\\treturn m, nil\\n407:\\n408:\\tcase PTYOutput:\\n409:\\t\\tcmd := m.updatePTYOutput(msg)\\n410:\\t\\tcmds = append(cmds, cmd)\\n411:\\n412:\\tcase PTYFlush:\\n413:\\t\\tcmd := m.updatePTYFlush(msg)\\n414:\\t\\tcmds = append(cmds, cmd)\\n415:\\n416:\\tcase PTYCursorRefresh:\\n417:\\t\\tcmd := m.updatePTYCursorRefresh(msg)\\n418:\\t\\tcmds = append(cmds, cmd)\\n419:\\n420:\\tcase PTYStopped:\\n421:\\t\\tcmd := m.updatePTYStopped(msg)\\n422:\\t\\tcmds = append(cmds, cmd)\\n423:\\n424:\\tcase PTYRestart:\\n425:\\t\\tcmd := m.updatePTYRestart(msg)\\n426:\\t\\tcmds = append(cmds, cmd)\\n427:\\n428:\\tcase selectionScrollTick:\\n429:\\t\\tcmd := m.updateSelectionScrollTick(msg)\\n430:\\t\\tcmds = append(cmds, cmd)\\n431:\\n432:\\tdefault:\\n433:\\t\\t// Forward unknown messages to active viewer if one exists\\n434:\\t\\ttabs := m.getTabs()\\n435:\\t\\tactiveIdx := m.getActiveTabIdx()\\n436:\\t\\tif len(tabs) > 0 && activeIdx < len(tabs) {\\n437:\\t\\t\\ttab := tabs[activeIdx]\\n438:\\t\\t\\tif handled, cmd := m.dispatchDiffInput(tab, msg); handled {\\n439:\\t\\t\\t\\tif cmd != nil {\\n440:\\t\\t\\t\\t\\tcmds = append(cmds, cmd)\\n441:\\t\\t\\t\\t}\\n442:\\t\\t\\t}\\n443:\\t\\t}\\n444:\\t}\\n445:\\n446:\\treturn m, common.SafeBatch(cmds...)\\n447:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
