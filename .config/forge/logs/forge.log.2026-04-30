{"timestamp":" 179.586644366s","level":"DEBUG","fields":{"message":"Adding tool results to context","results":"[ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_00_TJkmmH7zN3ylEpvVssjgGaDy\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/gt/badmux/polecats/rust/badmux/internal/ui/center/model_pty_lifecycle.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"116\\\"\\n><![CDATA[  1:package center\\n  2:\\n  3:import (\\n  4:\\t\\\"sync/atomic\\\"\\n  5:\\t\\\"time\\\"\\n  6:\\n  7:\\ttea \\\"charm.land/bubbletea/v2\\\"\\n  8:\\n  9:\\t\\\"github.com/andyrewlee/amux/internal/safego\\\"\\n 10:\\t\\\"github.com/andyrewlee/amux/internal/ui/common\\\"\\n 11:)\\n 12:\\n 13:func (m *Model) startPTYReader(wtID string, tab *Tab) tea.Cmd {\\n 14:\\tif tab == nil {\\n 15:\\t\\treturn nil\\n 16:\\t}\\n 17:\\tif tab.isClosed() {\\n 18:\\t\\treturn nil\\n 19:\\t}\\n 20:\\tif !tab.Running {\\n 21:\\t\\treturn nil\\n 22:\\t}\\n 23:\\ttab.mu.Lock()\\n 24:\\tif tab.readerActive {\\n 25:\\t\\tif tab.ptyMsgCh == nil || tab.readerCancel == nil {\\n 26:\\t\\t\\ttab.readerActive = false\\n 27:\\t\\t\\tatomic.StoreUint32(&tab.readerActiveState, 0)\\n 28:\\t\\t} else {\\n 29:\\t\\t\\ttab.mu.Unlock()\\n 30:\\t\\t\\treturn nil\\n 31:\\t\\t}\\n 32:\\t}\\n 33:\\tif tab.Agent == nil || tab.Agent.Terminal == nil || tab.Agent.Terminal.IsClosed() {\\n 34:\\t\\ttab.readerActive = false\\n 35:\\t\\tatomic.StoreUint32(&tab.readerActiveState, 0)\\n 36:\\t\\ttab.mu.Unlock()\\n 37:\\t\\treturn nil\\n 38:\\t}\\n 39:\\ttab.readerActive = true\\n 40:\\tatomic.StoreUint32(&tab.readerActiveState, 1)\\n 41:\\ttab.ptyRestartBackoff = 0\\n 42:\\tatomic.StoreInt64(&tab.ptyHeartbeat, time.Now().UnixNano())\\n 43:\\n 44:\\tif tab.readerCancel != nil {\\n 45:\\t\\tcommon.SafeClose(tab.readerCancel)\\n 46:\\t}\\n 47:\\ttab.readerCancel = make(chan struct{})\\n 48:\\ttab.ptyMsgCh = make(chan tea.Msg, ptyReadQueueSize)\\n 49:\\n 50:\\tterm := tab.Agent.Terminal\\n 51:\\ttabID := tab.ID\\n 52:\\tcancel := tab.readerCancel\\n 53:\\tmsgCh := tab.ptyMsgCh\\n 54:\\ttab.mu.Unlock()\\n 55:\\n 56:\\tsafego.Go(\\\"center.pty_reader\\\", func() {\\n 57:\\t\\tdefer m.markPTYReaderStopped(tab)\\n 58:\\t\\tcommon.RunPTYReader(term, msgCh, cancel, &tab.ptyHeartbeat, common.PTYReaderConfig{\\n 59:\\t\\t\\tLabel:           \\\"center.pty_read_loop\\\",\\n 60:\\t\\t\\tReadBufferSize:  ptyReadBufferSize,\\n 61:\\t\\t\\tReadQueueSize:   ptyReadQueueSize,\\n 62:\\t\\t\\tFrameInterval:   ptyFrameInterval,\\n 63:\\t\\t\\tMaxPendingBytes: ptyMaxPendingBytes,\\n 64:\\t\\t}, common.PTYMsgFactory{\\n 65:\\t\\t\\tOutput:  func(data []byte) tea.Msg { return PTYOutput{WorkspaceID: wtID, TabID: tabID, Data: data} },\\n 66:\\t\\t\\tStopped: func(err error) tea.Msg { return PTYStopped{WorkspaceID: wtID, TabID: tabID, Err: err} },\\n 67:\\t\\t})\\n 68:\\t})\\n 69:\\tsafego.Go(\\\"center.pty_forward\\\", func() {\\n 70:\\t\\tm.forwardPTYMsgs(msgCh)\\n 71:\\t})\\n 72:\\treturn nil\\n 73:}\\n 74:\\n 75:func (m *Model) resizePTY(tab *Tab, rows, cols int) {\\n 76:\\tif tab == nil || tab.Agent == nil || tab.Agent.Terminal == nil {\\n 77:\\t\\treturn\\n 78:\\t}\\n 79:\\tif rows < 1 || cols < 1 {\\n 80:\\t\\treturn\\n 81:\\t}\\n 82:\\tif tab.ptyRows == rows && tab.ptyCols == cols {\\n 83:\\t\\treturn\\n 84:\\t}\\n 85:\\t_ = tab.Agent.Terminal.SetSize(uint16(rows), uint16(cols))\\n 86:\\ttab.ptyRows = rows\\n 87:\\ttab.ptyCols = cols\\n 88:}\\n 89:\\n 90:func (m *Model) stopPTYReader(tab *Tab) {\\n 91:\\tif tab == nil {\\n 92:\\t\\treturn\\n 93:\\t}\\n 94:\\ttab.mu.Lock()\\n 95:\\tif tab.readerCancel != nil {\\n 96:\\t\\tcommon.SafeClose(tab.readerCancel)\\n 97:\\t\\ttab.readerCancel = nil\\n 98:\\t}\\n 99:\\ttab.readerActive = false\\n100:\\tatomic.StoreUint32(&tab.readerActiveState, 0)\\n101:\\ttab.ptyMsgCh = nil\\n102:\\ttab.mu.Unlock()\\n103:\\tatomic.StoreInt64(&tab.ptyHeartbeat, 0)\\n104:}\\n105:\\n106:func (m *Model) markPTYReaderStopped(tab *Tab) {\\n107:\\tif tab == nil {\\n108:\\t\\treturn\\n109:\\t}\\n110:\\ttab.mu.Lock()\\n111:\\ttab.readerActive = false\\n112:\\tatomic.StoreUint32(&tab.readerActiveState, 0)\\n113:\\ttab.ptyMsgCh = nil\\n114:\\ttab.mu.Unlock()\\n115:\\tatomic.StoreInt64(&tab.ptyHeartbeat, 0)\\n116:}]]>\\n</file>\")] } }, ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_01_Hal1khxN1tgW3QkhxHP8Cyiy\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/gt/badmux/polecats/rust/badmux/internal/ui/center/model_pty_status.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"460\\\"\\n><![CDATA[  1:package center\\n  2:\\n  3:import (\\n  4:\\t\\\"sync/atomic\\\"\\n  5:\\t\\\"time\\\"\\n  6:\\n  7:\\ttea \\\"charm.land/bubbletea/v2\\\"\\n  8:\\n  9:\\t\\\"github.com/andyrewlee/amux/internal/logging\\\"\\n 10:\\t\\\"github.com/andyrewlee/amux/internal/perf\\\"\\n 11:\\t\\\"github.com/andyrewlee/amux/internal/ui/compositor\\\"\\n 12:)\\n 13:\\n 14:const tabActiveWindow = 2 * time.Second\\n 15:\\n 16:// isChatInputCursorPosition reports whether the cursor is in the visible chat\\n 17:// input area, using a stricter bottom-band heuristic during active output.\\n 18:func isChatInputCursorPosition(snap *compositor.VTermSnapshot, x, y int, allowFullViewport bool) bool {\\n 19:\\tif snap == nil || snap.ViewOffset != 0 {\\n 20:\\t\\treturn false\\n 21:\\t}\\n 22:\\tif y < 0 || y >= len(snap.Screen) {\\n 23:\\t\\treturn false\\n 24:\\t}\\n 25:\\trow := snap.Screen[y]\\n 26:\\tif x < 0 || x >= len(row) {\\n 27:\\t\\treturn false\\n 28:\\t}\\n 29:\\tif allowFullViewport {\\n 30:\\t\\treturn true\\n 31:\\t}\\n 32:\\theight := len(snap.Screen)\\n 33:\\tif height <= 4 {\\n 34:\\t\\treturn true\\n 35:\\t}\\n 36:\\tband := height / 4\\n 37:\\tif band < 2 {\\n 38:\\t\\tband = 2\\n 39:\\t}\\n 40:\\treturn y >= height-band\\n 41:}\\n 42:\\n 43:// isRenderableChatCursorPosition returns whether a live terminal cursor is\\n 44:// sane enough to adopt as the chat input cursor.\\n 45:func isRenderableChatCursorPosition(\\n 46:\\tsnap *compositor.VTermSnapshot,\\n 47:\\tx, y int,\\n 48:\\tallowFullViewport bool,\\n 49:\\tallowBlankCorner bool,\\n 50:) bool {\\n 51:\\tif !isChatInputCursorPosition(snap, x, y, allowFullViewport) {\\n 52:\\t\\treturn false\\n 53:\\t}\\n 54:\\tif isSuspiciousBottomEdgeCornerCursor(snap, x, y) && !allowBlankCorner {\\n 55:\\t\\treturn false\\n 56:\\t}\\n 57:\\treturn true\\n 58:}\\n 59:\\n 60:// isStoredChatCursorPosition returns whether a stored chat cursor still fits in\\n 61:// the current terminal viewport and remains inside the input section.\\n 62:func isStoredChatCursorPosition(snap *compositor.VTermSnapshot, x, y int, allowFullViewport bool) bool {\\n 63:\\tif snap == nil {\\n 64:\\t\\treturn false\\n 65:\\t}\\n 66:\\tif snap.ViewOffset != 0 {\\n 67:\\t\\treturn x >= 0 && y >= 0\\n 68:\\t}\\n 69:\\tif y < 0 || y >= len(snap.Screen) {\\n 70:\\t\\treturn false\\n 71:\\t}\\n 72:\\trow := snap.Screen[y]\\n 73:\\tif x < 0 || x >= len(row) {\\n 74:\\t\\treturn false\\n 75:\\t}\\n 76:\\treturn isChatInputCursorPosition(snap, x, y, allowFullViewport)\\n 77:}\\n 78:\\n 79:// isBottomEdgeCornerPosition reports whether (x,y) is either bottom-left or\\n 80:// bottom-right corner of the snapshot viewport.\\n 81:func isBottomEdgeCornerPosition(snap *compositor.VTermSnapshot, x, y int) bool {\\n 82:\\tif snap == nil || len(snap.Screen) == 0 {\\n 83:\\t\\treturn false\\n 84:\\t}\\n 85:\\tlastY := len(snap.Screen) - 1\\n 86:\\tif y != lastY {\\n 87:\\t\\treturn false\\n 88:\\t}\\n 89:\\trow := snap.Screen[lastY]\\n 90:\\tif len(row) == 0 {\\n 91:\\t\\treturn false\\n 92:\\t}\\n 93:\\tlastX := len(row) - 1\\n 94:\\treturn x == 0 || x == lastX\\n 95:}\\n 96:\\n 97:// isSuspiciousBottomEdgeCornerCursor reports a common PTY cursor artifact where\\n 98:// cursor state lands on an empty corner cell on the bottom row.\\n 99:func isSuspiciousBottomEdgeCornerCursor(snap *compositor.VTermSnapshot, x, y int) bool {\\n100:\\tif !isBottomEdgeCornerPosition(snap, x, y) {\\n101:\\t\\treturn false\\n102:\\t}\\n103:\\trow := snap.Screen[len(snap.Screen)-1]\\n104:\\tcell := row[x]\\n105:\\treturn cell.Rune == 0 || cell.Rune == ' '\\n106:}\\n107:\\n108:// HasRunningAgents returns whether any tab has an active agent across workspaces.\\n109:func (m *Model) HasRunningAgents() bool {\\n110:\\tfor _, tabs := range m.tabsByWorkspace {\\n111:\\t\\tfor _, tab := range tabs {\\n112:\\t\\t\\tif tab.isClosed() {\\n113:\\t\\t\\t\\tcontinue\\n114:\\t\\t\\t}\\n115:\\t\\t\\tif !m.isChatTab(tab) {\\n116:\\t\\t\\t\\tcontinue\\n117:\\t\\t\\t}\\n118:\\t\\t\\tif tab.Running {\\n119:\\t\\t\\t\\treturn true\\n120:\\t\\t\\t}\\n121:\\t\\t}\\n122:\\t}\\n123:\\treturn false\\n124:}\\n125:\\n126:// HasActiveAgents returns whether any tab has emitted output recently.\\n127:// This is used to drive UI activity indicators without relying on process liveness alone.\\n128:func (m *Model) HasActiveAgents() bool {\\n129:\\tfor _, tabs := range m.tabsByWorkspace {\\n130:\\t\\tfor _, tab := range tabs {\\n131:\\t\\t\\tif m.IsTabActive(tab) {\\n132:\\t\\t\\t\\treturn true\\n133:\\t\\t\\t}\\n134:\\t\\t}\\n135:\\t}\\n136:\\treturn false\\n137:}\\n138:\\n139:// IsTabActive returns whether a specific tab has emitted output recently.\\n140:// This is used for the tab bar spinner animation (shows activity, not just running state).\\n141:func (m *Model) IsTabActive(tab *Tab) bool {\\n142:\\tif tab == nil {\\n143:\\t\\treturn false\\n144:\\t}\\n145:\\tif tab.isClosed() {\\n146:\\t\\treturn false\\n147:\\t}\\n148:\\tif !m.isChatTab(tab) {\\n149:\\t\\treturn false\\n150:\\t}\\n151:\\ttab.mu.Lock()\\n152:\\tactive := isTabVisiblyActiveLocked(tab, time.Now())\\n153:\\ttab.mu.Unlock()\\n154:\\treturn active\\n155:}\\n156:\\n157:func isTabVisiblyActiveLocked(tab *Tab, now time.Time) bool {\\n158:\\tif tab == nil || tab.Detached || !tab.Running {\\n159:\\t\\treturn false\\n160:\\t}\\n161:\\treturn !tab.lastVisibleOutput.IsZero() && now.Sub(tab.lastVisibleOutput) < tabActiveWindow\\n162:}\\n163:\\n164:// isTabCursorOutputActiveLocked reports whether recent PTY output should keep\\n165:// chat cursor trust constrained even when that output did not mutate visible\\n166:// screen content (for example cursor-move or DECTCEM-only sequences).\\n167:func isTabCursorOutputActiveLocked(tab *Tab, now time.Time) bool {\\n168:\\tif tab == nil || tab.Detached || !tab.Running || tab.bootstrapActivity {\\n169:\\t\\treturn false\\n170:\\t}\\n171:\\tif tab.lastOutputAt.IsZero() || now.Sub(tab.lastOutputAt) >= tabActiveWindow {\\n172:\\t\\treturn false\\n173:\\t}\\n174:\\t// Ignore output that is still attributable to the user's own recent edit.\\n175:\\t// That prevents wrapped multiline prompts from becoming cursor-restricted\\n176:\\t// after the short local-input window expires.\\n177:\\tif !tab.lastUserInputAt.IsZero() &&\\n178:\\t\\t!tab.lastOutputAt.Before(tab.lastUserInputAt) &&\\n179:\\t\\ttab.lastOutputAt.Sub(tab.lastUserInputAt) <= localInputEchoSuppressWindow &&\\n180:\\t\\t(tab.lastVisibleOutput.IsZero() || !tab.lastVisibleOutput.After(tab.lastUserInputAt)) {\\n181:\\t\\treturn false\\n182:\\t}\\n183:\\treturn true\\n184:}\\n185:\\n186:// HasActiveAgentsInWorkspace returns whether any tab in a workspace is actively outputting.\\n187:func (m *Model) HasActiveAgentsInWorkspace(wsID string) bool {\\n188:\\tfor _, tab := range m.tabsByWorkspace[wsID] {\\n189:\\t\\tif m.IsTabActive(tab) {\\n190:\\t\\t\\treturn true\\n191:\\t\\t}\\n192:\\t}\\n193:\\treturn false\\n194:}\\n195:\\n196:// GetActiveWorkspaceRoots returns all workspace root paths with active agents.\\n197:func (m *Model) GetActiveWorkspaceRoots() []string {\\n198:\\tvar active []string\\n199:\\tfor wsID, tabs := range m.tabsByWorkspace {\\n200:\\t\\tif m.HasActiveAgentsInWorkspace(wsID) {\\n201:\\t\\t\\t// Get the root path from one of the tabs\\n202:\\t\\t\\tfor _, tab := range tabs {\\n203:\\t\\t\\t\\tif tab.Workspace != nil {\\n204:\\t\\t\\t\\t\\tactive = append(active, tab.Workspace.Root)\\n205:\\t\\t\\t\\t\\tbreak\\n206:\\t\\t\\t\\t}\\n207:\\t\\t\\t}\\n208:\\t\\t}\\n209:\\t}\\n210:\\treturn active\\n211:}\\n212:\\n213:// GetActiveWorkspaceIDs returns all workspace IDs with active agents.\\n214:func (m *Model) GetActiveWorkspaceIDs() []string {\\n215:\\tvar active []string\\n216:\\tfor wsID := range m.tabsByWorkspace {\\n217:\\t\\tif m.HasActiveAgentsInWorkspace(wsID) {\\n218:\\t\\t\\tactive = append(active, wsID)\\n219:\\t\\t}\\n220:\\t}\\n221:\\treturn active\\n222:}\\n223:\\n224:// GetRunningWorkspaceRoots returns all workspace root paths with running agents.\\n225:// This includes agents that are running but idle (waiting at prompt).\\n226:func (m *Model) GetRunningWorkspaceRoots() []string {\\n227:\\tvar running []string\\n228:\\tfor _, tabs := range m.tabsByWorkspace {\\n229:\\t\\tfor _, tab := range tabs {\\n230:\\t\\t\\tif !m.isChatTab(tab) {\\n231:\\t\\t\\t\\tcontinue\\n232:\\t\\t\\t}\\n233:\\t\\t\\tif tab.Running && tab.Workspace != nil {\\n234:\\t\\t\\t\\trunning = append(running, tab.Workspace.Root)\\n235:\\t\\t\\t\\tbreak // Only need one per workspace\\n236:\\t\\t\\t}\\n237:\\t\\t}\\n238:\\t}\\n239:\\treturn running\\n240:}\\n241:\\n242:// StartPTYReaders starts reading from all PTYs across all workspaces\\n243:func (m *Model) StartPTYReaders() tea.Cmd {\\n244:\\tfor wtID, tabs := range m.tabsByWorkspace {\\n245:\\t\\tfor _, tab := range tabs {\\n246:\\t\\t\\tif tab == nil || tab.isClosed() {\\n247:\\t\\t\\t\\tcontinue\\n248:\\t\\t\\t}\\n249:\\t\\t\\ttab.mu.Lock()\\n250:\\t\\t\\treaderActive := tab.readerActive\\n251:\\t\\t\\ttab.mu.Unlock()\\n252:\\t\\t\\tif readerActive {\\n253:\\t\\t\\t\\tlastBeat := atomic.LoadInt64(&tab.ptyHeartbeat)\\n254:\\t\\t\\t\\tif lastBeat > 0 && time.Since(time.Unix(0, lastBeat)) > ptyReaderStallTimeout {\\n255:\\t\\t\\t\\t\\tlogging.Warn(\\\"PTY reader stalled for tab %s; restarting\\\", tab.ID)\\n256:\\t\\t\\t\\t\\tm.stopPTYReader(tab)\\n257:\\t\\t\\t\\t}\\n258:\\t\\t\\t}\\n259:\\t\\t\\t_ = m.startPTYReader(wtID, tab)\\n260:\\t\\t}\\n261:\\t}\\n262:\\treturn nil\\n263:}\\n264:\\n265:// TerminalLayer returns a VTermLayer for the active terminal, if any.\\n266:// It snapshots terminal state under lock and reuses cached snapshots when valid.\\n267:func (m *Model) TerminalLayer() *compositor.VTermLayer {\\n268:\\treturn m.TerminalLayerWithCursorOwner(true)\\n269:}\\n270:\\n271:// TerminalLayerWithCursorOwner returns a VTermLayer for the active terminal while\\n272:// enforcing whether this pane currently owns cursor rendering.\\n273:func (m *Model) TerminalLayerWithCursorOwner(cursorOwner bool) *compositor.VTermLayer {\\n274:\\ttabs := m.getTabs()\\n275:\\tactiveIdx := m.getActiveTabIdx()\\n276:\\tif len(tabs) == 0 || activeIdx >= len(tabs) {\\n277:\\t\\treturn nil\\n278:\\t}\\n279:\\ttab := tabs[activeIdx]\\n280:\\ttab.mu.Lock()\\n281:\\tdefer tab.mu.Unlock()\\n282:\\tif tab.Terminal == nil {\\n283:\\t\\treturn nil\\n284:\\t}\\n285:\\tm.applyTerminalCursorPolicyLocked(tab)\\n286:\\tisChat := m.isChatTabLocked(tab)\\n287:\\tversion := tab.Terminal.Version()\\n288:\\tshowCursor := m.focused\\n289:\\tif !cursorOwner {\\n290:\\t\\tshowCursor = false\\n291:\\t}\\n292:\\tnow := time.Now()\\n293:\\trecentLocalInput := false\\n294:\\trestrictCursor := false\\n295:\\tvisibleOutputActive := false\\n296:\\tcursorOutputActive := false\\n297:\\tif isChat && showCursor && !tab.Terminal.AltScreen {\\n298:\\t\\tvisibleOutputActive = isTabVisiblyActiveLocked(tab, now)\\n299:\\t\\tcursorOutputActive = isTabCursorOutputActiveLocked(tab, now)\\n300:\\t\\trecentLocalInput = isRecentPromptEditInput(tab.lastPromptInputAt, tab.lastPromptSubmitAt, now) ||\\n301:\\t\\t\\tisRecentSubmitPromptBeforeOutput(tab.lastPromptSubmitAt, tab.lastVisibleOutput, now)\\n302:\\t\\tif !recentLocalInput &&\\n303:\\t\\t\\tisRecentLocalChatInput(tab.lastPromptSubmitAt, now) &&\\n304:\\t\\t\\t(!tab.stableCursorSet ||\\n305:\\t\\t\\t\\tisNearbySubmitPromptCursor(\\n306:\\t\\t\\t\\t\\ttab.stableCursorX,\\n307:\\t\\t\\t\\t\\ttab.stableCursorY,\\n308:\\t\\t\\t\\t\\ttab.Terminal.CursorX,\\n309:\\t\\t\\t\\t\\ttab.Terminal.CursorY,\\n310:\\t\\t\\t\\t)) {\\n311:\\t\\t\\trecentLocalInput = true\\n312:\\t\\t}\\n313:\\t\\trestrictCursor = !recentLocalInput && (visibleOutputActive || cursorOutputActive)\\n314:\\t}\\n315:\\t// Cache key: (version, showCursor, recentLocalInput, restrictCursor) for chat\\n316:\\t// tabs. Both recent local input and recent PTY activity can change cursor\\n317:\\t// policy without a PTY version bump.\\n318:\\tif tab.cachedSnap != nil &&\\n319:\\t\\ttab.cachedVersion == version &&\\n320:\\t\\ttab.cachedShowCursor == showCursor &&\\n321:\\t\\t(!isChat ||\\n322:\\t\\t\\t(tab.cachedRecentLocalInput == recentLocalInput &&\\n323:\\t\\t\\t\\ttab.cachedRestrictCursor == restrictCursor)) {\\n324:\\t\\t// Reuse cached snapshot\\n325:\\t\\tperf.Count(\\\"vterm_snapshot_cache_hit\\\", 1)\\n326:\\t\\treturn compositor.NewVTermLayer(tab.cachedSnap)\\n327:\\t}\\n328:\\n329:\\t// Create new snapshot while holding the lock.\\n330:\\t// Do not pass the previous snapshot for reuse: NewVTermSnapshotWithCache\\n331:\\t// mutates the provided snapshot/rows in-place, which can mutate a snapshot\\n332:\\t// already handed to a previously returned layer.\\n333:\\tsnap := compositor.NewVTermSnapshot(tab.Terminal, showCursor)\\n334:\\tif snap == nil {\\n335:\\t\\treturn nil\\n336:\\t}\\n337:\\n338:\\tif isChat {\\n339:\\t\\tliveCursorX, liveCursorY := snap.CursorX, snap.CursorY\\n340:\\t\\tappOwnsCursor := showCursor &&\\n341:\\t\\t\\t!tab.Terminal.AltScreen &&\\n342:\\t\\t\\tsnap.CursorHidden &&\\n343:\\t\\t\\thasChatOwnedCursorGlyph(\\n344:\\t\\t\\t\\tsnap,\\n345:\\t\\t\\t\\tliveCursorX,\\n346:\\t\\t\\t\\tliveCursorY,\\n347:\\t\\t\\t\\ttab.stableCursorSet,\\n348:\\t\\t\\t\\ttab.stableCursorX,\\n349:\\t\\t\\t\\ttab.stableCursorY,\\n350:\\t\\t\\t)\\n351:\\t\\tif showCursor && !tab.Terminal.AltScreen {\\n352:\\t\\t\\tif appOwnsCursor {\\n353:\\t\\t\\t\\tsnap.ShowCursor = false\\n354:\\t\\t\\t} else {\\n355:\\t\\t\\t\\tsnap.CursorHidden = false\\n356:\\t\\t\\t\\ttrustFullViewport := !restrictCursor\\n357:\\t\\t\\t\\tif restrictCursor {\\n358:\\t\\t\\t\\t\\ttab.lastRestrictedVersion = version\\n359:\\t\\t\\t\\t\\tif cursorOutputActive && !visibleOutputActive && tab.stableCursorSet {\\n360:\\t\\t\\t\\t\\t\\ttab.pendingIdleCursorRelearn = true\\n361:\\t\\t\\t\\t\\t}\\n362:\\t\\t\\t\\t}\\n363:\\t\\t\\t\\tversionChangedFromStable := version != tab.stableCursorVersion\\n364:\\t\\t\\t\\tidleSameVersionRelearn := trustFullViewport &&\\n365:\\t\\t\\t\\t\\ttab.stableCursorSet &&\\n366:\\t\\t\\t\\t\\t!recentLocalInput &&\\n367:\\t\\t\\t\\t\\tversion == tab.lastRestrictedVersion &&\\n368:\\t\\t\\t\\t\\t(tab.pendingIdleCursorRelearn || tab.stableCursorVersion == 0) &&\\n369:\\t\\t\\t\\t\\thasChatCursorContextNearPosition(snap, liveCursorY)\\n370:\\t\\t\\t\\tplausibleInitialCursor := isPlausibleInitialChatCursor(snap, liveCursorX, liveCursorY)\\n371:\\t\\t\\t\\tinitialFullViewportLearn := !tab.stableCursorSet && plausibleInitialCursor\\n372:\\t\\t\\t\\tlearnFullViewport := trustFullViewport &&\\n373:\\t\\t\\t\\t\\t(initialFullViewportLearn ||\\n374:\\t\\t\\t\\t\\t\\t(tab.stableCursorSet && recentLocalInput) ||\\n375:\\t\\t\\t\\t\\t\\tidleSameVersionRelearn ||\\n376:\\t\\t\\t\\t\\t\\t(versionChangedFromStable && version != tab.lastRestrictedVersion))\\n377:\\t\\t\\t\\tliveCursorVisible := isChatInputCursorPosition(snap, liveCursorX, liveCursorY, trustFullViewport)\\n378:\\t\\t\\t\\tliveCursorDisplayable := liveCursorVisible &&\\n379:\\t\\t\\t\\t\\t(!restrictCursor || !isSuspiciousBottomEdgeCornerCursor(snap, liveCursorX, liveCursorY)) &&\\n380:\\t\\t\\t\\t\\t(tab.stableCursorSet || !trustFullViewport || plausibleInitialCursor)\\n381:\\t\\t\\t\\tliveCursorRenderable := isRenderableChatCursorPosition(\\n382:\\t\\t\\t\\t\\tsnap,\\n383:\\t\\t\\t\\t\\tliveCursorX,\\n384:\\t\\t\\t\\t\\tliveCursorY,\\n385:\\t\\t\\t\\t\\tlearnFullViewport,\\n386:\\t\\t\\t\\t\\trecentLocalInput,\\n387:\\t\\t\\t\\t)\\n388:\\t\\t\\t\\tstoredCursorInViewport := tab.stableCursorSet &&\\n389:\\t\\t\\t\\t\\tisStoredChatCursorPosition(snap, tab.stableCursorX, tab.stableCursorY, true)\\n390:\\t\\t\\t\\tstoredCursorVisible := tab.stableCursorSet &&\\n391:\\t\\t\\t\\t\\tisStoredChatCursorPosition(snap, tab.stableCursorX, tab.stableCursorY, trustFullViewport)\\n392:\\t\\t\\t\\t// Stable chat cursor learning lives in the render path because it\\n393:\\t\\t\\t\\t// depends on the fully materialized snapshot and the current cursor\\n394:\\t\\t\\t\\t// trust policy. The cache key above prevents repeated View passes\\n395:\\t\\t\\t\\t// from churning this state when those inputs have not changed.\\n396:\\t\\t\\t\\tif liveCursorRenderable {\\n397:\\t\\t\\t\\t\\ttab.stableCursorSet = true\\n398:\\t\\t\\t\\t\\ttab.stableCursorX = liveCursorX\\n399:\\t\\t\\t\\t\\ttab.stableCursorY = liveCursorY\\n400:\\t\\t\\t\\t\\ttab.stableCursorVersion = version\\n401:\\t\\t\\t\\t\\ttab.pendingIdleCursorRelearn = false\\n402:\\t\\t\\t\\t} else if tab.stableCursorSet &&\\n403:\\t\\t\\t\\t\\ttab.stableCursorVersion == 0 &&\\n404:\\t\\t\\t\\t\\ttrustFullViewport &&\\n405:\\t\\t\\t\\t\\tstoredCursorVisible {\\n406:\\t\\t\\t\\t\\ttab.stableCursorVersion = version\\n407:\\t\\t\\t\\t} else if tab.stableCursorSet &&\\n408:\\t\\t\\t\\t\\t!storedCursorInViewport {\\n409:\\t\\t\\t\\t\\ttab.stableCursorSet = false\\n410:\\t\\t\\t\\t\\ttab.stableCursorVersion = 0\\n411:\\t\\t\\t\\t\\ttab.pendingIdleCursorRelearn = false\\n412:\\t\\t\\t\\t}\\n413:\\n414:\\t\\t\\t\\tswitch {\\n415:\\t\\t\\t\\tcase tab.stableCursorSet:\\n416:\\t\\t\\t\\t\\tsnap.CursorX = tab.stableCursorX\\n417:\\t\\t\\t\\t\\tsnap.CursorY = tab.stableCursorY\\n418:\\t\\t\\t\\tcase liveCursorDisplayable:\\n419:\\t\\t\\t\\t\\t// Leave the live cursor in place until we learn a stable input-band position.\\n420:\\t\\t\\t\\tdefault:\\n421:\\t\\t\\t\\t\\tsnap.ShowCursor = false\\n422:\\t\\t\\t\\t}\\n423:\\t\\t\\t}\\n424:\\t\\t}\\n425:\\n426:\\t\\t// Some assistants paint a synthetic block cursor glyph in the buffer; sanitize it\\n427:\\t\\t// before global blink cleanup, but skip scrollback/history views.\\n428:\\t\\tif snap.ViewOffset == 0 && !appOwnsCursor {\\n429:\\t\\t\\tsanitizeChatCursorCell(snap, liveCursorX, liveCursorY)\\n430:\\t\\t\\tif snap.ShowCursor &&\\n431:\\t\\t\\t\\ttab.stableCursorSet &&\\n432:\\t\\t\\t\\t(tab.stableCursorX != liveCursorX || tab.stableCursorY != liveCursorY) {\\n433:\\t\\t\\t\\tsanitizeStoredChatCursorCell(snap, tab.stableCursorX, tab.stableCursorY)\\n434:\\t\\t\\t}\\n435:\\t\\t}\\n436:\\n437:\\t\\t// Prevent residual flicker from SGR blink attributes in assistant output.\\n438:\\t\\tfor y := range snap.Screen {\\n439:\\t\\t\\trow := snap.Screen[y]\\n440:\\t\\t\\tfor x := range row {\\n441:\\t\\t\\t\\tif !row[x].Style.Blink {\\n442:\\t\\t\\t\\t\\tcontinue\\n443:\\t\\t\\t\\t}\\n444:\\t\\t\\t\\tcell := row[x]\\n445:\\t\\t\\t\\tcell.Style.Blink = false\\n446:\\t\\t\\t\\trow[x] = cell\\n447:\\t\\t\\t}\\n448:\\t\\t}\\n449:\\t}\\n450:\\tperf.Count(\\\"vterm_snapshot_cache_miss\\\", 1)\\n451:\\n452:\\t// Cache the snapshot\\n453:\\ttab.cachedSnap = snap\\n454:\\ttab.cachedVersion = version\\n455:\\ttab.cachedShowCursor = showCursor\\n456:\\ttab.cachedRecentLocalInput = recentLocalInput\\n457:\\ttab.cachedRestrictCursor = restrictCursor\\n458:\\n459:\\treturn compositor.NewVTermLayer(snap)\\n460:}]]>\\n</file>\")] } }, ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_02_88puIiPMjSYobtnVIG13LS32\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/gt/badmux/polecats/rust/badmux/internal/ui/center/model_pty_reader.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"120\\\"\\n><![CDATA[  1:package center\\n  2:\\n  3:import (\\n  4:\\t\\\"sync/atomic\\\"\\n  5:\\t\\\"time\\\"\\n  6:\\n  7:\\ttea \\\"charm.land/bubbletea/v2\\\"\\n  8:\\n  9:\\t\\\"github.com/andyrewlee/amux/internal/ui/common\\\"\\n 10:)\\n 11:\\n 12:func (m *Model) flushTiming(tab *Tab, active bool) (time.Duration, time.Duration) {\\n 13:\\tquiet := ptyFlushQuiet\\n 14:\\tmaxInterval := ptyFlushMaxInterval\\n 15:\\n 16:\\t// Snapshot terminal state under lock, then release before the load-sampling call.\\n 17:\\ttab.mu.Lock()\\n 18:\\taltScreen := tab.Terminal != nil && tab.Terminal.AltScreen\\n 19:\\tvar termWidth, termHeight int\\n 20:\\tvar pendingLen int\\n 21:\\tif tab.Terminal != nil {\\n 22:\\t\\ttermWidth = tab.Terminal.Width\\n 23:\\t\\ttermHeight = tab.Terminal.Height\\n 24:\\t\\tpendingLen = len(tab.pendingOutput)\\n 25:\\t}\\n 26:\\ttab.mu.Unlock()\\n 27:\\n 28:\\t// Only use slower Alt timing for true AltScreen mode (full-screen TUIs).\\n 29:\\t// SyncActive (DEC 2026) already handles partial updates via screen snapshots,\\n 30:\\t// so we don't need slower flush timing - it just makes streaming text feel laggy.\\n 31:\\tif altScreen {\\n 32:\\t\\tquiet = ptyFlushQuietAlt\\n 33:\\t\\tmaxInterval = ptyFlushMaxAlt\\n 34:\\t}\\n 35:\\n 36:\\t// Apply backpressure when pending output exceeds threshold\\n 37:\\t// This prevents renderer thrashing during heavy output (like builds)\\n 38:\\tif pendingLen > 0 {\\n 39:\\t\\tthreshold := ptyBackpressureMultiplier * termWidth * termHeight\\n 40:\\t\\tif pendingLen > threshold {\\n 41:\\t\\t\\t// Under backpressure: use minimum flush interval\\n 42:\\t\\t\\tif quiet < ptyBackpressureFlushFloor {\\n 43:\\t\\t\\t\\tquiet = ptyBackpressureFlushFloor\\n 44:\\t\\t\\t}\\n 45:\\t\\t\\tif maxInterval < ptyBackpressureFlushFloor {\\n 46:\\t\\t\\t\\tmaxInterval = ptyBackpressureFlushFloor\\n 47:\\t\\t\\t}\\n 48:\\t\\t}\\n 49:\\t}\\n 50:\\n 51:\\tif !active {\\n 52:\\t\\tbusyCount := m.busyPTYTabCount(time.Now())\\n 53:\\t\\tvar mult time.Duration\\n 54:\\t\\tswitch {\\n 55:\\t\\tcase busyCount >= ptyVeryHeavyLoadTabThreshold:\\n 56:\\t\\t\\tmult = ptyFlushInactiveVeryHeavyMultiplier\\n 57:\\t\\tcase busyCount >= ptyHeavyLoadTabThreshold:\\n 58:\\t\\t\\tmult = ptyFlushInactiveHeavyMultiplier\\n 59:\\t\\tdefault:\\n 60:\\t\\t\\tmult = ptyFlushInactiveMultiplier\\n 61:\\t\\t}\\n 62:\\t\\tquiet *= mult\\n 63:\\t\\tmaxInterval *= mult\\n 64:\\t\\tif quiet > ptyFlushInactiveMaxIntervalCap {\\n 65:\\t\\t\\tquiet = ptyFlushInactiveMaxIntervalCap\\n 66:\\t\\t}\\n 67:\\t\\tif maxInterval > ptyFlushInactiveMaxIntervalCap {\\n 68:\\t\\t\\tmaxInterval = ptyFlushInactiveMaxIntervalCap\\n 69:\\t\\t}\\n 70:\\t\\tif maxInterval < quiet {\\n 71:\\t\\t\\tmaxInterval = quiet\\n 72:\\t\\t}\\n 73:\\t}\\n 74:\\n 75:\\treturn quiet, maxInterval\\n 76:}\\n 77:\\n 78:func (m *Model) busyPTYTabCount(now time.Time) int {\\n 79:\\t// Return cached count if sampled within ptyLoadSampleInterval (100ms)\\n 80:\\tif !m.flushLoadSampleAt.IsZero() && now.Sub(m.flushLoadSampleAt) < ptyLoadSampleInterval {\\n 81:\\t\\treturn m.cachedBusyTabCount\\n 82:\\t}\\n 83:\\tcount := 0\\n 84:\\tfor _, tabs := range m.tabsByWorkspace {\\n 85:\\t\\tfor _, tab := range tabs {\\n 86:\\t\\t\\tif tab == nil || tab.isClosed() {\\n 87:\\t\\t\\t\\tcontinue\\n 88:\\t\\t\\t}\\n 89:\\t\\t\\tbusy := atomic.LoadUint32(&tab.readerActiveState) == 1 || len(tab.pendingOutput) > 0\\n 90:\\t\\t\\tif busy {\\n 91:\\t\\t\\t\\tcount++\\n 92:\\t\\t\\t}\\n 93:\\t\\t}\\n 94:\\t}\\n 95:\\tm.flushLoadSampleAt = now\\n 96:\\tm.cachedBusyTabCount = count\\n 97:\\treturn count\\n 98:}\\n 99:\\n100:func (m *Model) forwardPTYMsgs(msgCh <-chan tea.Msg) {\\n101:\\tcommon.ForwardPTYMsgs(msgCh, m.msgSink, common.OutputMerger{\\n102:\\t\\tExtractData: func(msg tea.Msg) ([]byte, bool) {\\n103:\\t\\t\\tif out, ok := msg.(PTYOutput); ok {\\n104:\\t\\t\\t\\treturn out.Data, true\\n105:\\t\\t\\t}\\n106:\\t\\t\\treturn nil, false\\n107:\\t\\t},\\n108:\\t\\tCanMerge: func(cur, next tea.Msg) bool {\\n109:\\t\\t\\tc, _ := cur.(PTYOutput)\\n110:\\t\\t\\tn, _ := next.(PTYOutput)\\n111:\\t\\t\\treturn c.WorkspaceID == n.WorkspaceID && c.TabID == n.TabID\\n112:\\t\\t},\\n113:\\t\\tBuild: func(first tea.Msg, data []byte) tea.Msg {\\n114:\\t\\t\\tout, _ := first.(PTYOutput)\\n115:\\t\\t\\tout.Data = data\\n116:\\t\\t\\treturn out\\n117:\\t\\t},\\n118:\\t\\tMaxPending: ptyMaxPendingBytes,\\n119:\\t})\\n120:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
