= processedBytes {\\n440:\\t\\t\\t\\ttab.actorQueuedBytes -= processedBytes\\n441:\\t\\t\\t} else {\\n442:\\t\\t\\t\\ttab.actorQueuedBytes = 0\\n443:\\t\\t\\t}\\n444:\\t\\t\\tcatchUpBefore, catchUpAfter := tab.settlePTYBytesLocked(processedBytes)\\n445:\\t\\t\\tsuppressRedraw = catchUpBefore && catchUpAfter\\n446:\\t\\t\\tif tab.actorWritesPending == 0 {\\n447:\\t\\t\\t\\ttab.actorQueuedCarry = tab.Terminal.ParserCarryState()\\n448:\\t\\t\\t\\ttab.actorQueuedNoiseTrailing = append(tab.actorQueuedNoiseTrailing[:0], tab.ptyNoiseTrailing...)\\n449:\\t\\t\\t\\tif tab.parserResetPending {\\n450:\\t\\t\\t\\t\\ttab.Terminal.ResetParserState()\\n451:\\t\\t\\t\\t\\ttab.activityANSIState = ansiActivityText\\n452:\\t\\t\\t\\t\\ttab.ptyNoiseTrailing = nil\\n453:\\t\\t\\t\\t\\ttab.actorQueuedCarry = tab.Terminal.ParserCarryState()\\n454:\\t\\t\\t\\t\\ttab.actorQueuedNoiseTrailing = tab.actorQueuedNoiseTrailing[:0]\\n455:\\t\\t\\t\\t\\ttab.parserResetPending = false\\n456:\\t\\t\\t\\t\\trequestFlush = true\\n457:\\t\\t\\t\\t}\\n458:\\t\\t\\t}\\n459:\\t\\t}\\n460:\\t\\ttab.mu.Unlock()\\n461:\\t\\tif staleWrite {\\n462:\\t\\t\\treturn\\n463:\\t\\t}\\n464:\\t\\tperf.Count(\\\"pty_flush_bytes_processed\\\", int64(processedBytes))\\n465:\\t\\tif filterApplied {\\n466:\\t\\t\\tfilteredBytes := processedBytes - filteredLen\\n467:\\t\\t\\tif filteredBytes > 0 {\\n468:\\t\\t\\t\\tperf.Count(\\\"pty_flush_bytes_filtered\\\", int64(filteredBytes))\\n469:\\t\\t\\t}\\n470:\\t\\t}\\n471:\\t\\tif tagSessionName != \\\"\\\" {\\n472:\\t\\t\\topts := m.getTmuxOptions()\\n473:\\t\\t\\tsessionName := tagSessionName\\n474:\\t\\t\\ttimestamp := strconv.FormatInt(tagTimestamp, 10)\\n475:\\t\\t\\tgo func() {\\n476:\\t\\t\\t\\t_ = tmux.SetSessionTagValue(sessionName, tmux.TagLastOutputAt, timestamp, opts)\\n477:\\t\\t\\t}()\\n478:\\t\\t}\\n479:\\t\\tif requestFlush && m.msgSink != nil {\\n480:\\t\\t\\tm.msgSink(PTYFlush{WorkspaceID: ev.workspaceID, TabID: ev.tabID, CatchUp: ev.catchUp})\\n481:\\t\\t}\\n4