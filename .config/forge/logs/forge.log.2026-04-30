rkspaceID: msg.WorkspaceID, TabID: tabID}\\n145:\\t\\t\\t}))\\n146:\\t\\t}\\n147:\\t}\\n148:\\treturn common.SafeBatch(cmds...)\\n149:}\\n150:\\n151:// updatePTYFlush handles PTYFlush.\\n152:func (m *Model) updatePTYFlush(msg PTYFlush) tea.Cmd {\\n153:\\tvar cmds []tea.Cmd\\n154:\\ttab := m.getTabByID(msg.WorkspaceID, msg.TabID)\\n155:\\tif tab != nil && !tab.isClosed() {\\n156:\\t\\tisActive := m.isActiveTab(msg.WorkspaceID, msg.TabID)\\n157:\\t\\ttab.mu.Lock()\\n158:\\t\\tif !isActive {\\n159:\\t\\t\\ttab.clearCatchUpLocked()\\n160:\\t\\t} else {\\n161:\\t\\t\\ttab.expireCatchUpLocked()\\n162:\\t\\t}\\n163:\\t\\tcatchUp := isActive && tab.catchUpActiveLocked()\\n164:\\t\\ttab.mu.Unlock()\\n165:\\t\\tnow := time.Now()\\n166:\\t\\tquietFor := now.Sub(tab.lastOutputAt)\\n167:\\t\\tpendingFor := time.Duration(0)\\n168:\\t\\tif !tab.flushPendingSince.IsZero() {\\n169:\\t\\t\\tpendingFor = now.Sub(tab.flushPendingSince)\\n170:\\t\\t}\\n171:\\t\\tquiet, maxInterval := m.flushTiming(tab, isActive)\\n172:\\t\\tif quietFor < quiet && pendingFor < maxInterval {\\n173:\\t\\t\\tdelay := max(quiet-quietFor, time.Millisecond)\\n174:\\t\\t\\ttabID := msg.TabID\\n175:\\t\\t\\ttab.flushScheduled = true\\n176:\\t\\t\\tcmds = append(cmds, common.SafeTick(delay, func(t time.Time) tea.Msg {\\n177:\\t\\t\\t\\treturn PTYFlush{WorkspaceID: msg.WorkspaceID, TabID: tabID, CatchUp: catchUp}\\n178:\\t\\t\\t}))\\n179:\\t\\t\\treturn common.SafeBatch(cmds...)\\n180:\\t\\t}\\n181:\\n182:\\t\\ttab.flushScheduled = false\\n183:\\t\\ttab.flushPendingSince = time.Time{}\\n184:\\t\\tif len(tab.pendingOutput) > 0 {\\n185:\\t\\t\\tvar chunk []byte\\n186:\\t\\t\\twriteOutput := false\\n187:\\t\\t\\thasMoreBuffered := false\\n188:\\t\\t\\tvisibleSeq := uint64(0)\\n189:\\t\\t\\ttagSessionName := \\\"\\\"\\n190:\\t\\t\\tvar tagTimestamp int64\\n191:\\t\\t\\tparserResetPending := false\\n192:\\t\\t\\tactorWritesPending := 0\\n193:\\t\\t\\ttab.mu.Lock()\\n194:\\t\\t\\tif tab.Terminal != nil {\\n195:\\t\\t\\t\\tparserResetPending = tab.parserResetPending\\n196:\\t\\t\\t\\tactorWritesPending = tab.actorWritesPending\\n197:\\t\\t\\t\\tchunkSize := len(tab.pendingOutput)\\n198:\\t\\t\\t\\tmaxChunk := ptyFlushChunkSize\\n199:\\t\\t\\t\\tif isActive {\\n200:\\t\\t\\t\\t\\tmaxChunk = ptyFlushChunkSizeActive\\n201:\\t\\t\\t\\t}\\n202:\\t\\t\\t\\tif catchUp && m.isTabActorReady() {\\n203:\\t\\t\\t\\t\\tif ptyFlushChunkSizeCatchUp > maxChunk {\\n204:\\t\\t\\t\\t\\t\\tmaxChunk = ptyFlushChunkSizeCatchUp\\n205:\\t\\t\\t\\t\\t}\\n206:\\t\\t\\t\\t}\\n207:\\t\\t\\t\\tif !parserResetPending && chunkSize > maxChunk {\\n208:\\t\\t\\t\\t\\tchunkSize = maxChunk\\n209:\\t\\t\\t\\t}\\n210:\\t\\t\\t\\tif !parserResetPending && chunkSize > 0 {\\n211:\\t\\t\\t\\t\\tchunk = append(chunk, tab.pendingOutput[:chunkSize]...)\\n212:\\t\\t\\t\\t\\tcopy(tab.pendingOutput, tab.pendingOutput[chunkSize:])\\n213:\\t\\t\\t\\t\\ttab.pendingOutput = tab.pendingOutput[:len(tab.pendingOutput)-chunkSize]\\n214:\\t\\t\\t\\t\\ttab.pendingOutputBytes = len(tab.pendingOutput)\\n215:\\t\\t\\t\\t\\thasMoreBuffered = len(tab.pendingOutput) > 0\\n216:\\t\\t\\t\\t\\tvisibleSeq = tab.pendingVisibleSeq\\n217:\\t\\t\\t\\t\\twriteOutput = true\\n218:\\t\\t\\t\\t}\\n219:\\t\\t\\t}\\n220:\\t\\t\\ttab.mu.Unlock()\\n221:\\t\\t\\tif parserResetPending {\\n222:\\t\\t\\t\\tif actorWritesPending > 0 && m.isTabActorReady() {\\n223:\\t\\t\\t\\t\\ttab.flushScheduled = true\\n224:\\t\\t\\t\\t\\ttab.flushPendingSince = time.Now()\\n225:\\t\\t\\t\\t\\tdelay, _ := m.flushTiming(tab, m.isActiveTab(msg.WorkspaceID, msg.TabID))\\n226:\\t\\t\\t\\t\\tif delay < time.Millisecond {\\n227:\\t\\t\\t\\t\\t\\tdelay = time.Millisecond\\n228:\\t\\t\\t\\t\\t}\\n229:\\t\\t\\t\\t\\ttabID := msg.TabID\\n230:\\t\\t\\t\\t\\tcmds = append(cmds, common.SafeTick(delay, func(t time.Time) tea.Msg {\\n231:\\t\\t\\t\\t\\t\\treturn PTYFlush{\\n232:\\t\\t\\t\\t\\t\\t\\tWorkspaceID: msg.WorkspaceID,\\n233:\\t\\t\\t\\t\\t\\t\\tTabID:       tabID,\\n234:\\t\\t\\t\\t\\t\\t\\tCatchUp:     catchUp,\\n235:\\t\\t\\t\\t\\t\\t}\\n236:\\t\\t\\t\\t\\t}))\\n237:\\t\\t\\t\\t\\treturn common.SafeBatch(cmds...)\\n238:\\t\\t\\t\\t}\\n239:\\t\\t\\t\\ttab.mu.Lock()\\n240:\\t\\t\\t\\tif tab.Terminal != nil {\\n241:\\t\\t\\t\\t\\tif actorWritesPending > 0 {\\n242:\\t\\t\\t\\t\\t\\ttab.settlePTYBytesLocked(tab.actorQueuedBytes)\\n243:\\t\\t\\t\\t\\t\\ttab.actorQueuedBytes = 0\\n244:\\t\\t\\t\\t\\t\\ttab.actorWriteEpoch++\\n245:\\t\\t\\t\\t\\t\\ttab.ptyNoiseTrailing = nil\\n246:\\t\\t\\t\\t\\t}\\n247:\\t\\t\\t\\t\\ttab.Terminal.ResetParserState()\\n248:\\t\\t\\t\\t\\ttab.activityANSIState = ansiActivityText\\n249:\\t\\t\\t\\t}\\n250:\\t\\t\\t\\ttab.parserResetPending = false\\n251:\\t\\t\\t\\ttab.actorWritesPending = 0\\n252:\\t\\t\\t\\ttab.actorQueuedCarry = vterm.ParserCarryState{}\\n253:\\t\\t\\t\\ttab.actorQueuedNoiseTrailing = tab.actorQueuedNoiseTrailing[:0]\\n254:\\t\\t\\t\\ttab.mu.Unlock()\\n255:\\t\\t\\t}\\n256:\\t\\t\\tif writeOutput && len(chunk) > 0 {\\n257:\\t\\t\\t\\tif m.isTabActorReady() {\\n258:\\t\\t\\t\\t\\tprevPending := 0\\n259:\\t\\t\\t\\t\\tprevEpoch := uint64(0)\\n260:\\t\\t\\t\\t\\tprevCarry := vterm.ParserCarryState{}\\n261:\\t\\t\\t\\t\\tvar nextCarry vterm.ParserCarryState\\n262:\\t\\t\\t\\t\\tprevNoiseTrailing := []byte(nil)\\n263:\\t\\t\\t\\t\\tnextNoiseTrailing := []byte(nil)\\n264:\\t\\t\\t\\t\\ttab.mu.Lock()\\n265:\\t\\t\\t\\t\\tif tab.Terminal != nil {\\n266:\\t\\t\\t\\t\\t\\tprevPending = tab.actorWritesPending\\n267:\\t\\t\\t\\t\\t\\tprevEpoch = tab.actorWriteEpoch\\n268:\\t\\t\\t\\t\\t\\tprevCarry = tab.actorQueuedCarry\\n269:\\t\\t\\t\\t\\t\\tprevNoiseTrailing = append(\\n270:\\t\\t\\t\\t\\t\\t\\tprevNoiseTrailing,\\n271:\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedNoiseTrailing...)\\n272:\\t\\t\\t\\t\\t\\tseedCarry := tab.Terminal.ParserCarryState()\\n273:\\t\\t\\t\\t\\t\\tif prevPending > 0 {\\n274:\\t\\t\\t\\t\\t\\t\\tseedCarry = prevCarry\\n275:\\t\\t\\t\\t\\t\\t}\\n276:\\t\\t\\t\\t\\t\\tpreviewTrailing := append([]byte(nil), tab.ptyNoiseTrailing...)\\n277:\\t\\t\\t\\t\\t\\tif prevPending > 0 {\\n278:\\t\\t\\t\\t\\t\\t\\tpreviewTrailing = append(\\n279:\\t\\t\\t\\t\\t\\t\\t\\tpreviewTrailing[:0],\\n280:\\t\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedNoiseTrailing...)\\n281:\\t\\t\\t\\t\\t\\t}\\n282:\\t\\t\\t\\t\\t\\tfilteredPreview := common.FilterKnownPTYNoiseStream(chunk, &previewTrailing)\\n283:\\t\\t\\t\\t\\t\\tnextCarry = vterm.AdvanceParserCarryState(seedCarry, filteredPreview)\\n284:\\t\\t\\t\\t\\t\\tnextNoiseTrailing = append(nextNoiseTrailing, previewTrailing...)\\n285:\\t\\t\\t\\t\\t\\ttab.actorWritesPending = prevPending + 1\\n286:\\t\\t\\t\\t\\t\\ttab.actorQueuedBytes += len(chunk)\\n287:\\t\\t\\t\\t\\t\\ttab.actorQueuedCarry = nextCarry\\n288:\\t\\t\\t\\t\\t\\ttab.actorQueuedNoiseTrailing = append(\\n289:\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedNoiseTrailing[:0],\\n290:\\t\\t\\t\\t\\t\\t\\tnextNoiseTrailing...)\\n291:\\t\\t\\t\\t\\t}\\n292:\\t\\t\\t\\t\\ttab.mu.Unlock()\\n293:\\t\\t\\t\\t\\tif !m.sendTabEvent(tabEvent{\\n294:\\t\\t\\t\\t\\t\\ttab:             tab,\\n295:\\t\\t\\t\\t\\t\\tworkspaceID:     msg.WorkspaceID,\\n296:\\t\\t\\t\\t\\t\\ttabID:           msg.TabID,\\n297:\\t\\t\\t\\t\\t\\tkind:            tabEventWriteOutput,\\n298:\\t\\t\\t\\t\\t\\toutput:          chunk,\\n299:\\t\\t\\t\\t\\t\\twriteEpoch:      prevEpoch,\\n300:\\t\\t\\t\\t\\t\\tcatchUp:         catchUp,\\n301:\\t\\t\\t\\t\\t\\thasMoreBuffered: hasMoreBuffered,\\n302:\\t\\t\\t\\t\\t\\tvisibleSeq:      visibleSeq,\\n303:\\t\\t\\t\\t\\t}) {\\n304:\\t\\t\\t\\t\\t\\trebuffered := false\\n305:\\t\\t\\t\\t\\t\\tdropWrite := false\\n306:\\t\\t\\t\\t\\t\\tsyncFallbackChunkSize := 0\\n307:\\t\\t\\t\\t\\t\\ttab.mu.Lock()\\n308:\\t\\t\\t\\t\\t\\tif tab.actorWriteEpoch == prevEpoch && tab.actorWritesPending > 0 {\\n309:\\t\\t\\t\\t\\t\\t\\ttab.actorWritesPending--\\n310:\\t\\t\\t\\t\\t\\t\\tif tab.actorQueuedBytes >= len(chunk) {\\n311:\\t\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedBytes -= len(chunk)\\n312:\\t\\t\\t\\t\\t\\t\\t} else {\\n313:\\t\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedBytes = 0\\n314:\\t\\t\\t\\t\\t\\t\\t}\\n315:\\t\\t\\t\\t\\t\\t\\tif tab.isClosed() {\\n316:\\t\\t\\t\\t\\t\\t\\t\\tdropWrite = true\\n317:\\t\\t\\t\\t\\t\\t\\t} else if tab.actorWritesPending > 0 {\\n318:\\t\\t\\t\\t\\t\\t\\t\\trebuffered = true\\n319:\\t\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedCarry = prevCarry\\n320:\\t\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedNoiseTrailing = append(\\n321:\\t\\t\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedNoiseTrailing[:0],\\n322:\\t\\t\\t\\t\\t\\t\\t\\t\\tprevNoiseTrailing...)\\n323:\\t\\t\\t\\t\\t\\t\\t\\trestored := make([]byte, 0, len(chunk)+len(tab.pendingOutput))\\n324:\\t\\t\\t\\t\\t\\t\\t\\trestored = append(restored, chunk...)\\n325:\\t\\t\\t\\t\\t\\t\\t\\trestored = append(restored, tab.pendingOutput...)\\n326:\\t\\t\\t\\t\\t\\t\\t\\ttab.pendingOutput = restored\\n327:\\t\\t\\t\\t\\t\\t\\t\\ttab.pendingOutputBytes = len(tab.pendingOutput)\\n328:\\t\\t\\t\\t\\t\\t\\t} else if catchUp && len(chunk) > ptyFlushChunkSizeActive {\\n329:\\t\\t\\t\\t\\t\\t\\t\\tsyncFallbackChunkSize = ptyFlushChunkSizeActive\\n330:\\t\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedCarry = prevCarry\\n331:\\t\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedNoiseTrailing = append(\\n332:\\t\\t\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedNoiseTrailing[:0],\\n333:\\t\\t\\t\\t\\t\\t\\t\\t\\tprevNoiseTrailing...)\\n334:\\t\\t\\t\\t\\t\\t\\t\\trestored := make(\\n335:\\t\\t\\t\\t\\t\\t\\t\\t\\t[]byte,\\n336:\\t\\t\\t\\t\\t\\t\\t\\t\\t0,\\n337:\\t\\t\\t\\t\\t\\t\\t\\t\\tlen(chunk)-syncFallbackChunkSize+len(tab.pendingOutput),\\n338:\\t\\t\\t\\t\\t\\t\\t\\t)\\n339:\\t\\t\\t\\t\\t\\t\\t\\trestored = append(restored, chunk[syncFallbackChunkSize:]...)\\n340:\\t\\t\\t\\t\\t\\t\\t\\trestored = append(restored, tab.pendingOutput...)\\n341:\\t\\t\\t\\t\\t\\t\\t\\ttab.pendingOutput = restored\\n342:\\t\\t\\t\\t\\t\\t\\t\\ttab.pendingOutputBytes = len(tab.pendingOutput)\\n343:\\t\\t\\t\\t\\t\\t\\t\\thasMoreBuffered = len(tab.pendingOutput) > 0\\n344:\\t\\t\\t\\t\\t\\t\\t}\\n345:\\t\\t\\t\\t\\t\\t} else if tab.actorWriteEpoch != prevEpoch || tab.isClosed() {\\n346:\\t\\t\\t\\t\\t\\t\\tdropWrite = true\\n347:\\t\\t\\t\\t\\t\\t}\\n348:\\t\\t\\t\\t\\t\\ttab.mu.Unlock()\\n349:\\t\\t\\t\\t\\t\\tif syncFallbackChunkSize > 0 {\\n350:\\t\\t\\t\\t\\t\\t\\tchunk = chunk[:syncFallbackChunkSize]\\n351:\\t\\t\\t\\t\\t\\t}\\n352:\\t\\t\\t\\t\\t\\tif !rebuffered && !dropWrite {\\n353:\\t\\t\\t\\t\\t\\t\\tprocessedBytes := len(chunk)\\n354:\\t\\t\\t\\t\\t\\t\\tfilteredLen := 0\\n355:\\t\\t\\t\\t\\t\\t\\tfilterApplied := false\\n356:\\t\\t\\t\\t\\t\\t\\tsuppressRedraw := false\\n357:\\t\\t\\t\\t\\t\\t\\ttab.mu.Lock()\\n358:\\t\\t\\t\\t\\t\\t\\tif tab.Terminal != nil {\\n359:\\t\\t\\t\\t\\t\\t\\t\\tfiltered := common.FilterKnownPTYNoiseStream(\\n360:\\t\\t\\t\\t\\t\\t\\t\\t\\tchunk,\\n361:\\t\\t\\t\\t\\t\\t\\t\\t\\t&tab.ptyNoiseTrailing,\\n362:\\t\\t\\t\\t\\t\\t\\t\\t)\\n363:\\t\\t\\t\\t\\t\\t\\t\\tfilteredLen = len(filtered)\\n364:\\t\\t\\t\\t\\t\\t\\t\\tfilterApplied = true\\n365:\\t\\t\\t\\t\\t\\t\\t\\tif len(filtered) > 0 {\\n366:\\t\\t\\t\\t\\t\\t\\t\\t\\tflushDone := perf.Time(\\\"pty_flush\\\")\\n367:\\t\\t\\t\\t\\t\\t\\t\\t\\ttab.Terminal.Write(filtered)\\n368:\\t\\t\\t\\t\\t\\t\\t\\t\\tflushDone()\\n369:\\t\\t\\t\\t\\t\\t\\t\\t\\tperf.Count(\\\"pty_flush_bytes\\\", int64(len(filtered)))\\n370:\\t\\t\\t\\t\\t\\t\\t\\t}\\n371:\\t\\t\\t\\t\\t\\t\\t\\t// Activity state intentionally tracks visible terminal mutations only.\\n372:\\t\\t\\t\\t\\t\\t\\t\\t// Noise-only chunks are filtered above and must not update activity tags.\\n373:\\t\\t\\t\\t\\t\\t\\t\\t// We still run this to clear pending visible state when no mutation occurred.\\n374:\\t\\t\\t\\t\\t\\t\\t\\ttagSessionName, tagTimestamp, _ = m.noteVisibleActivityLockedWithOutput(\\n375:\\t\\t\\t\\t\\t\\t\\t\\t\\ttab,\\n376:\\t\\t\\t\\t\\t\\t\\t\\t\\thasMoreBuffered,\\n377:\\t\\t\\t\\t\\t\\t\\t\\t\\tvisibleSeq,\\n378:\\t\\t\\t\\t\\t\\t\\t\\t\\tfiltered,\\n379:\\t\\t\\t\\t\\t\\t\\t\\t)\\n380:\\t\\t\\t\\t\\t\\t\\t\\tcatchUpBefore, catchUpAfter := tab.settlePTYBytesLocked(\\n381:\\t\\t\\t\\t\\t\\t\\t\\t\\tprocessedBytes,\\n382:\\t\\t\\t\\t\\t\\t\\t\\t)\\n383:\\t\\t\\t\\t\\t\\t\\t\\tsuppressRedraw = catchUpBefore && catchUpAfter\\n384:\\t\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedCarry = tab.Terminal.ParserCarryState()\\n385:\\t\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedNoiseTrailing = append(\\n386:\\t\\t\\t\\t\\t\\t\\t\\t\\ttab.actorQueuedNoiseTrailing[:0],\\n387:\\t\\t\\t\\t\\t\\t\\t\\t\\ttab.ptyNoiseTrailing...)\\n388:\\t\\t\\t\\t\\t\\t\\t}\\n389:\\t\\t\\t\\t\\t\\t\\ttab.mu.Unlock()\\n390:\\t\\t\\t\\t\\t\\t\\tif !suppressRedraw {\\n391:\\t\\t\\t\\t\\t\\t\\t\\tcmds = append(\\n392:\\t\\t\\t\\t\\t\\t\\t\\t\\tcmds,\\n393:\\t\\t\\t\\t\\t\\t\\t\\t\\tm.scheduleChatCursorRefresh(tab, msg.WorkspaceID, time.Now()),\\n394:\\t\\t\\t\\t\\t\\t\\t\\t)\\n395:\\t\\t\\t\\t\\t\\t\\t}\\n396:\\t\\t\\t\\t\\t\\t\\tperf.Count(\\\"pty_flush_bytes_processed\\\", int64(processedBytes))\\n397:\\t\\t\\t\\t\\t\\t\\tif filterApplied {\\n398:\\t\\t\\t\\t\\t\\t\\t\\tfilteredBytes := processedBytes - filteredLen\\n399:\\t\\t\\t\\t\\t\\t\\t\\tif filteredBytes > 0 {\\n400:\\t\\t\\t\\t\\t\\t\\t\\t\\tperf.Count(\\\"pty_flush_bytes_filtered\\\", int64(filteredBytes))\\n401:\\t\\t\\t\\t\\t\\t\\t\\t}\\n402:\\t\\t\\t\\t\\t\\t\\t}\\n403:\\t\\t\\t\\t\\t\\t}\\n404:\\t\\t\\t\\t\\t}\\n405:\\t\\t\\t\\t} else {\\n406:\\t\\t\\t\\t\\tprocessedBytes := len(chunk)\\n407:\\t\\t\\t\\t\\tfilteredLen := 0\\n408:\\t\\t\\t\\t\\tfilterApplied := false\\n409:\\t\\t\\t\\t\\tsuppressRedraw := false\\n410:\\t\\t\\t\\t\\ttab.mu.Lock()\\n411:\\t\\t\\t\\t\\tif tab.Terminal != nil {\\n412:\\t\\t\\t\\t\\t\\tfiltered := common.FilterKnownPTYNoiseStream(chunk, &tab.ptyNoiseTrailing)\\n413:\\t\\t\\t\\t\\t\\tfilteredLen = len(filtered)\\n414:\\t\\t\\t\\t\\t\\tfilterApplied = true\\n415:\\t\\t\\t\\t\\t\\tif len(filtered) > 0 {\\n416:\\t\\t\\t\\t\\t\\t\\tflushDone := perf.Time(\\\"pty_flush\\\")\\n417:\\t\\t\\t\\t\\t\\t\\ttab.Terminal.Write(filtered)\\n418:\\t\\t\\t\\t\\t\\t\\tflushDone()\\n419:\\t\\t\\t\\t\\t\\t\\tperf.Count(\\\"pty_flush_bytes\\\", int64(len(filtered)))\\n420:\\t\\t\\t\\t\\t\\t}\\n421:\\t\\t\\t\\t\\t\\t// Activity state intentionally tracks visible terminal mutations only.\\n422:\\t\\t\\t\\t\\t\\t// Noise-only chunks are filtered above and must not update activity tags.\\n423:\\t\\t\\t\\t\\t\\t// We still run this to clear pending visible state when no mutation occurred.\\n424:\\t\\t\\t\\t\\t\\ttagSessionName, tagTimestamp, _ = m.noteVisibleActivityLockedWithOutput(\\n425:\\t\\t\\t\\t\\t\\t\\ttab,\\n426:\\t\\t\\t\\t\\t\\t\\thasMoreBuffered,\\n427:\\t\\t\\t\\t\\t\\t\\tvisibleSeq,\\n428:\\t\\t\\t\\t\\t\\t\\tfiltered,\\n429:\\t\\t\\t\\t\\t\\t)\\n430:\\t\\t\\t\\t\\t\\tcatchUpBefore, catchUpAfter := tab.settlePTYBytesLocked(processedBytes)\\n431:\\t\\t\\t\\t\\t\\tsuppressRedraw = catchUpBefore && catchUpAfter\\n432:\\t\\t\\t\\t\\t}\\n433:\\t\\t\\t\\t\\ttab.mu.Unlock()\\n434:\\t\\t\\t\\t\\tif !suppressRedraw {\\n435:\\t\\t\\t\\t\\t\\tcmds = append(\\n436:\\t\\t\\t\\t\\t\\t\\tcmds,\\n437:\\t\\t\\t\\t\\t\\t\\tm.scheduleChatCursorRefresh(tab, msg.WorkspaceID, time.Now()),\\n438:\\t\\t\\t\\t\\t\\t)\\n439:\\t\\t\\t\\t\\t}\\n440:\\t\\t\\t\\t\\tperf.Count(\\\"pty_flush_bytes_processed\\\", int64(processedBytes))\\n441:\\t\\t\\t\\t\\tif filterApplied {\\n442:\\t\\t\\t\\t\\t\\tfilteredBytes := processedBytes - filteredLen\\n443:\\t\\t\\t\\t\\t\\tif filteredBytes > 0 {\\n444:\\t\\t\\t\\t\\t\\t\\tperf.Count(\\\"pty_flush_bytes_filtered\\\", int64(filteredBytes))\\n445:\\t\\t\\t\\t\\t\\t}\\n446:\\t\\t\\t\\t\\t}\\n447:\\t\\t\\t\\t}\\n448:\\t\\t\\t\\tif tagSessionName != \\\"\\\" {\\n449:\\t\\t\\t\\t\\topts := m.getTmuxOptions()\\n450:\\t\\t\\t\\t\\tsessionName := tagSessionName\\n451:\\t\\t\\t\\t\\ttimestamp := strconv.FormatInt(tagTimestamp, 10)\\n452:\\t\\t\\t\\t\\tcmds = append(cmds, func() tea.Msg {\\n453:\\t\\t\\t\\t\\t\\t_ = tmux.SetSessionTagValue(\\n454:\\t\\t\\t\\t\\t\\t\\tsessionName,\\n455:\\t\\t\\t\\t\\t\\t\\ttmux.TagLastOutputAt,\\n456:\\t\\t\\t\\t\\t\\t\\ttimestamp,\\n457:\\t\\t\\t\\t\\t\\t\\topts,\\n458:\\t\\t\\t\\t\\t\\t)\\n459:\\t\\t\\t\\t\\t\\treturn nil\\n460:\\t\\t\\t\\t\\t})\\n461:\\t\\t\\t\\t}\\n462:\\t\\t\\t}\\n463:\\t\\t\\ttab.mu.Lock()\\n464:\\t\\t\\tcatchUpStillActive := tab.catchUpActiveLocked()\\n465:\\t\\t\\ttab.mu.Unlock()\\n466:\\t\\t\\tif len(tab.pendingOutput) == 0 {\\n467:\\t\\t\\t\\ttab.pendingOutput = tab.pendingOutput[:0]\\n468:\\t\\t\\t\\ttab.mu.Lock()\\n469:\\t\\t\\t\\ttab.pendingOutputBytes = 0\\n470:\\t\\t\\t\\ttab.mu.Unlock()\\n471:\\t\\t\\t} else {\\n472:\\t\\t\\t\\ttab.flushScheduled = true\\n473:\\t\\t\\t\\ttab.flushPendingSince = time.Now()\\n474:\\t\\t\\t\\ttabID := msg.TabID\\n475:\\t\\t\\t\\tquietNext, _ := m.flushTiming(tab, isActive)\\n476:\\t\\t\\t\\tdelay := max(quietNext, time.Millisecond)\\n477:\\t\\t\\t\\tcmds = append(cmds, common.SafeTick(delay, func(t time.Time) tea.Msg {\\n478:\\t\\t\\t\\t\\treturn PTYFlush{\\n479:\\t\\t\\t\\t\\t\\tWorkspaceID: msg.WorkspaceID,\\n480:\\t\\t\\t\\t\\t\\tTabID:       tabID,\\n481:\\t\\t\\t\\t\\t\\tCatchUp:     catchUpStillActive,\\n482:\\t\\t\\t\\t\\t}\\n483:\\t\\t\\t\\t}))\\n484:\\t\\t\\t}\\n485:\\t\\t}\\n486:\\t}\\n487:\\treturn common.SafeBatch(cmds...)\\n488:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
