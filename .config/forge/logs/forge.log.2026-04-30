{"timestamp":" 867.107960137s","level":"DEBUG","fields":{"message":"Tool call started","agent_id":"forge","tool_name":"write","call_id":"Some(ToolCallId(\"call_00_M5sVi2R9k8JNpKhFOBzXifTz\"))","arguments":"{\"content\": \"package pty\\n\\nimport (\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/andyrewlee/amux/internal/config\\\"\\n\\t\\\"github.com/andyrewlee/amux/internal/data\\\"\\n\\t\\\"github.com/andyrewlee/amux/internal/tmux\\\"\\n)\\n\\n// AgentType represents the type of AI agent\\ntype AgentType string\\n\\nconst (\\n\\tAgentClaude   AgentType = \\\"claude\\\"\\n\\tAgentCodex    AgentType = \\\"codex\\\"\\n\\tAgentGemini   AgentType = \\\"gemini\\\"\\n\\tAgentAmp      AgentType = \\\"amp\\\"\\n\\tAgentOpencode AgentType = \\\"opencode\\\"\\n\\tAgentDroid    AgentType = \\\"droid\\\"\\n\\tAgentCline    AgentType = \\\"cline\\\"\\n\\tAgentCursor   AgentType = \\\"cursor\\\"\\n\\tAgentPi       AgentType = \\\"pi\\\"\\n)\\n\\n// Agent represents a running AI agent instance\\ntype Agent struct {\\n\\tType      AgentType\\n\\tTerminal  *Terminal\\n\\tWorkspace *data.Workspace\\n\\tConfig    config.AssistantConfig\\n\\tSession   string\\n}\\n\\n// AgentStateChange represents a state change produced by AgentManager operations.\\n// Callers convert these to tea.Msg for Bubbletea processing.\\ntype AgentStateChange struct {\\n\\tKind       string  // \\\"created\\\", \\\"closed\\\"\\n\\tAgentType  string  // string representation of AgentType\\n\\tSession    string  // tmux session name\\n\\tError      error   // non-nil when operation failed\\n}\\n\\n// agentCmd is a command sent to the AgentManager's serial command channel.\\ntype agentCmd struct {\\n\\tkind string\\n\\n\\t// create\\n\\tws          *data.Workspace\\n\\tagentType   AgentType\\n\\tsessionName string\\n\\trows        uint16\\n\\tcols        uint16\\n\\ttags        tmux.SessionTags\\n\\tviewerCmd   string\\n\\n\\t// close\\n\\tagent *Agent\\n\\n\\t// tmux options\\n\\ttmuxOpts tmux.Options\\n\\n\\t// response\\n\\trespCh chan agentResp\\n}\\n\\ntype agentResp struct {\\n\\tagent       *Agent\\n\\terr         error\\n\\ttmuxOptions tmux.Options\\n\\tchange      AgentStateChange\\n}\\n\\n// AgentManager manages agent instances.\\n// All mutable state is serialized through a command channel processed by a\\n// single background goroutine, eliminating the need for a sync.Mutex.\\ntype AgentManager struct {\\n\\tconfig      *config.Config\\n\\tcmdCh       chan agentCmd\\n\\tstopCh      chan struct{}\\n}\\n\\n// NewAgentManager creates a new agent manager and starts its command-processing goroutine.\\nfunc NewAgentManager(cfg *config.Config) *AgentManager {\\n\\tm := &AgentManager{\\n\\t\\tconfig: cfg,\\n\\t\\tcmdCh:  make(chan agentCmd, 64),\\n\\t\\tstopCh: make(chan struct{}),\\n\\t}\\n\\tgo m.loop()\\n\\treturn m\\n}\\n\\nfunc (m *AgentManager) loop() {\\n\\tagents := make(map[data.WorkspaceID][]*Agent)\\n\\ttmuxOptions := tmux.DefaultOptions()\\n\\n\\tfor {\\n\\t\\tselect {\\n\\t\\tcase <-m.stopCh:\\n\\t\\t\\t// Drain remaining commands before shutting down\\n\\t\\t\\tfor {\\n\\t\\t\\t\\tselect {\\n\\t\\t\\t\\tcase cmd := <-m.cmdCh:\\n\\t\\t\\t\\t\\tm.handle(&cmd, agents, &tmuxOptions)\\n\\t\\t\\t\\tdefault:\\n\\t\\t\\t\\t\\treturn\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\tcase cmd := <-m.cmdCh:\\n\\t\\t\\tm.handle(&cmd, agents, &tmuxOptions)\\n\\t\\t}\\n\\t}\\n}\\n\\nfunc (m *AgentManager) handle(cmd *agentCmd, agents map[data.WorkspaceID][]*Agent, tmuxOpts *tmux.Options) {\\n\\tswitch cmd.kind {\\n\\tcase \\\"set_tmux_opts\\\":\\n\\t\\t*tmuxOpts = cmd.tmuxOpts\\n\\t\\tcmd.respCh <- agentResp{tmuxOptions: *tmuxOpts}\\n\\n\\tcase \\\"get_tmux_opts\\\":\\n\\t\\tcmd.respCh <- agentResp{tmuxOptions: *tmuxOpts}\\n\\n\\tcase \\\"create_agent\\\":\\n\\t\\tagent, err := m.createAgentLocked(cmd, agents, tmuxOpts)\\n\\t\\tcmd.respCh <- agentResp{agent: agent, err: err, change: AgentStateChange{\\n\\t\\t\\tKind:      \\\"created\\\",\\n\\t\\t\\tAgentType: string(cmd.agentType),\\n\\t\\t\\tSession:   cmd.sessionName,\\n\\t\\t\\tError:     err,\\n\\t\\t}}\\n\\n\\tcase \\\"close_agent\\\":\\n\\t\\tm.closeAgentLocked(cmd.agent, agents)\\n\\t\\tcmd.respCh <- agentResp{change: AgentStateChange{\\n\\t\\t\\tKind:    \\\"closed\\\",\\n\\t\\t\\tSession: cmd.agent.Session,\\n\\t\\t}}\\n\\n\\tcase \\\"close_all\\\":\\n\\t\\tfor _, ags := range agents {\\n\\t\\t\\tfor _, a := range ags {\\n\\t\\t\\t\\tif a.Terminal != nil {\\n\\t\\t\\t\\t\\ta.Terminal.Close()\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\tagents = make(map[data.WorkspaceID][]*Agent)\\n\\t\\t// The agents map variable is shadowed here, so we need to ensure\\n\\t\\t// the caller's map is updated by copying back.\\n\\t\\tfor k := range agents {\\n\\t\\t\\tdelete(agents, k)\\n\\t\\t}\\n\\t\\tcmd.respCh <- agentResp{}\\n\\n\\tcase \\\"close_workspace\\\":\\n\\t\\tws := cmd.ws\\n\\t\\tif ws != nil {\\n\\t\\t\\twsID := ws.ID()\\n\\t\\t\\tfor _, a := range agents[wsID] {\\n\\t\\t\\t\\tif a.Terminal != nil {\\n\\t\\t\\t\\t\\ta.Terminal.Close()\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tdelete(agents, wsID)\\n\\t\\t}\\n\\t\\tcmd.respCh <- agentResp{}\\n\\t}\\n}\\n\\nfunc (m *AgentManager) createAgentLocked(cmd *agentCmd, agents map[data.WorkspaceID][]*Agent, tmuxOpts *tmux.Options) (*Agent, error) {\\n\\tws := cmd.ws\\n\\tagentType := cmd.agentType\\n\\tsessionName := cmd.sessionName\\n\\n\\tif sessionName == \\\"\\\" {\\n\\t\\tif cmd.kind == \\\"create_agent\\\" {\\n\\t\\t\\tsessionName = tmux.SessionName(\\\"amux\\\", string(ws.ID()), string(agentType))\\n\\t\\t} else {\\n\\t\\t\\tsessionName = tmux.SessionName(\\\"amux\\\", string(ws.ID()), \\\"viewer\\\")\\n\\t\\t}\\n\\t}\\n\\n\\tif cmd.kind == \\\"create_agent\\\" {\\n\\t\\tassistantCfg, ok := m.config.Assistants[string(agentType)]\\n\\t\\tif !ok {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"unknown agent type: %s\\\", agentType)\\n\\t\\t}\\n\\t\\tif err := tmux.EnsureAvailable(); err != nil {\\n\\t\\t\\treturn nil, err\\n\\t\\t}\\n\\n\\t\\tenv := []string{\\n\\t\\t\\t\\\"WORKSPACE_ROOT=\\\" + ws.Root,\\n\\t\\t\\t\\\"WORKSPACE_NAME=\\\" + ws.Name,\\n\\t\\t\\t\\\"LINES=\\\",\\n\\t\\t\\t\\\"COLUMNS=\\\",\\n\\t\\t\\t\\\"COLORTERM=truecolor\\\",\\n\\t\\t}\\n\\n\\t\\tshell := os.Getenv(\\\"SHELL\\\")\\n\\t\\tif shell == \\\"\\\" {\\n\\t\\t\\tshell = \\\"/bin/bash\\\"\\n\\t\\t}\\n\\n\\t\\tfullCommand := fmt.Sprintf(\\\"%s; stty sane; printf '\\\\\\\\033[?1049l\\\\\\\\033[?25h\\\\\\\\033[0m\\\\\\\\033c'; echo 'Agent exited. Dropping to shell...'; export TERM=xterm-256color; exec %s -l\\\", assistantCfg.Command, shell)\\n\\n\\t\\ttermCommand := tmux.NewClientCommand(sessionName, tmux.ClientCommandParams{\\n\\t\\t\\tWorkDir:        ws.Root,\\n\\t\\t\\tCommand:        fullCommand,\\n\\t\\t\\tOptions:        *tmuxOpts,\\n\\t\\t\\tTags:           cmd.tags,\\n\\t\\t\\tDetachExisting: true,\\n\\t\\t})\\n\\t\\tterm, err := NewWithSize(termCommand, ws.Root, env, cmd.rows, cmd.cols)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to create terminal: %w\\\", err)\\n\\t\\t}\\n\\n\\t\\tagent := &Agent{\\n\\t\\t\\tType:      agentType,\\n\\t\\t\\tTerminal:  term,\\n\\t\\t\\tWorkspace: ws,\\n\\t\\t\\tConfig:    assistantCfg,\\n\\t\\t\\tSession:   sessionName,\\n\\t\\t}\\n\\t\\tagents[ws.ID()] = append(agents[ws.ID()], agent)\\n\\t\\treturn agent, nil\\n\\t}\\n\\n\\t// create_viewer\\n\\tif ws == nil {\\n\\t\\treturn nil, errors.New(\\\"workspace is required\\\")\\n\\t}\\n\\tif err := tmux.EnsureAvailable(); err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\tenv := []string{\\n\\t\\t\\\"WORKSPACE_ROOT=\\\" + ws.Root,\\n\\t\\t\\\"WORKSPACE_NAME=\\\" + ws.Name,\\n\\t\\t\\\"TERM=xterm-256color\\\",\\n\\t\\t\\\"COLORTERM=truecolor\\\",\\n\\t}\\n\\n\\ttermCommand := tmux.NewClientCommand(sessionName, tmux.ClientCommandParams{\\n\\t\\tWorkDir:        ws.Root,\\n\\t\\tCommand:        cmd.viewerCmd,\\n\\t\\tOptions:        *tmuxOpts,\\n\\t\\tTags:           cmd.tags,\\n\\t\\tDetachExisting: true,\\n\\t})\\n\\tterm, err := NewWithSize(termCommand, ws.Root, env, cmd.rows, cmd.cols)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to create terminal: %w\\\", err)\\n\\t}\\n\\n\\tagent := &Agent{\\n\\t\\tType:      AgentType(\\\"viewer\\\"),\\n\\t\\tTerminal:  term,\\n\\t\\tWorkspace: ws,\\n\\t\\tConfig:    config.AssistantConfig{},\\n\\t\\tSession:   sessionName,\\n\\t}\\n\\tagents[ws.ID()] = append(agents[ws.ID()], agent)\\n\\treturn agent, nil\\n}\\n\\nfunc (m *AgentManager) closeAgentLocked(agent *Agent, agents map[data.WorkspaceID][]*Agent) {\\n\\tif agent.Terminal != nil {\\n\\t\\tagent.Terminal.Close()\\n\\t}\\n\\tif agent.Workspace != nil {\\n\\t\\twsID := agent.Workspace.ID()\\n\\t\\tags := agents[wsID]\\n\\t\\tfor i, a := range ags {\\n\\t\\t\\tif a == agent {\\n\\t\\t\\t\\tagents[wsID] = append(ags[:i], ags[i+1:]...)\\n\\t\\t\\t\\tbreak\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n}\\n\\n// sendCmd sends a command to the loop and returns the response.\\nfunc (m *AgentManager) sendCmd(cmd agentCmd) agentResp {\\n\\tif m.cmdCh == nil {\\n\\t\\treturn agentResp{err: errors.New(\\\"agent manager is shutting down\\\")}\\n\\t}\\n\\trespCh := make(chan agentResp, 1)\\n\\tcmd.respCh = respCh\\n\\tm.cmdCh <- cmd\\n\\treturn <-respCh\\n}\\n\\n// SetTmuxOptions updates tmux options for future agent/viewer command construction.\\nfunc (m *AgentManager) SetTmuxOptions(opts tmux.Options) {\\n\\tresp := m.sendCmd(agentCmd{kind: \\\"set_tmux_opts\\\", tmuxOpts: opts})\\n\\t_ = resp\\n}\\n\\nfunc (m *AgentManager) getTmuxOptions() tmux.Options {\\n\\tresp := m.sendCmd(agentCmd{kind: \\\"get_tmux_opts\\\"})\\n\\treturn resp.tmuxOptions\\n}\\n\\n// CreateAgent creates a new agent for the given workspace.\\nfunc (m *AgentManager) CreateAgent(ws *data.Workspace, agentType AgentType, sessionName string, rows, cols uint16) (*Agent, error) {\\n\\treturn m.CreateAgentWithTags(ws, agentType, sessionName, rows, cols, tmux.SessionTags{})\\n}\\n\\n// CreateAgentWithTags creates a new agent for the given workspace with tmux tags.\\nfunc (m *AgentManager) CreateAgentWithTags(ws *data.Workspace, agentType AgentType, sessionName string, rows, cols uint16, tags tmux.SessionTags) (*Agent, error) {\\n\\tresp := m.sendCmd(agentCmd{\\n\\t\\tkind:        \\\"create_agent\\\",\\n\\t\\tws:          ws,\\n\\t\\tagentType:   agentType,\\n\\t\\tsessionName: sessionName,\\n\\t\\trows:        rows,\\n\\t\\tcols:        cols,\\n\\t\\ttags:        tags,\\n\\t})\\n\\treturn resp.agent, resp.err\\n}\\n\\n// CreateViewer creates a new agent (viewer) for the given workspace and command.\\nfunc (m *AgentManager) CreateViewer(ws *data.Workspace, command, sessionName string, rows, cols uint16) (*Agent, error) {\\n\\treturn m.CreateViewerWithTags(ws, command, sessionName, rows, cols, tmux.SessionTags{})\\n}\\n\\n// CreateViewerWithTags creates a new viewer for the given workspace with tmux tags.\\nfunc (m *AgentManager) CreateViewerWithTags(ws *data.Workspace, command, sessionName string, rows, cols uint16, tags tmux.SessionTags) (*Agent, error) {\\n\\tresp := m.sendCmd(agentCmd{\\n\\t\\tkind:        \\\"create_viewer\\\",\\n\\t\\tws:          ws,\\n\\t\\tsessionName: sessionName,\\n\\t\\trows:        rows,\\n\\t\\tcols:        cols,\\n\\t\\ttags:        tags,\\n\\t\\tviewerCmd:   command,\\n\\t})\\n\\treturn resp.agent, resp.err\\n}\\n\\n// CloseAgent closes an agent.\\n// Returns AgentStateChange that the caller can convert to a tea.Msg.\\nfunc (m *AgentManager) CloseAgent(agent *Agent) AgentStateChange {\\n\\tif agent == nil {\\n\\t\\treturn AgentStateChange{}\\n\\t}\\n\\tresp := m.sendCmd(agentCmd{kind: \\\"close_agent\\\", agent: agent})\\n\\treturn resp.change\\n}\\n\\n// CloseAll closes all agents.\\nfunc (m *AgentManager) CloseAll() {\\n\\trespCh := make(chan agentResp, 1)\\n\\tm.cmdCh <- agentCmd{kind: \\\"close_all\\\", respCh: respCh}\\n\\t<-respCh\\n}\\n\\n// CloseWorkspaceAgents closes and removes all agents for a specific workspace.\\nfunc (m *AgentManager) CloseWorkspaceAgents(ws *data.Workspace) {\\n\\tif ws == nil {\\n\\t\\treturn\\n\\t}\\n\\trespCh := make(chan agentResp, 1)\\n\\tm.cmdCh <- agentCmd{kind: \\\"close_workspace\\\", ws: ws, respCh: respCh}\\n\\t<-respCh\\n}\\n\\n// SendInterrupt sends an interrupt to an agent.\\nfunc (m *AgentManager) SendInterrupt(agent *Agent) error {\\n\\tif agent.Terminal == nil {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Send multiple interrupts if configured (e.g., for Claude)\\n\\tfor i := 0; i < agent.Config.InterruptCount; i++ {\\n\\t\\tif err := agent.Terminal.SendInterrupt(); err != nil {\\n\\t\\t\\treturn err\\n\\t\\t}\\n\\t\\t// Add delay between interrupts if configured\\n\\t\\tif i < agent.Config.InterruptCount-1 && agent.Config.InterruptDelayMs > 0 {\\n\\t\\t\\ttime.Sleep(time.Duration(agent.Config.InterruptDelayMs) * time.Millisecond)\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\", \"file_path\": \"/home/sloth/Documents/projects/amux/polecats/rust/badmux/internal/pty/agent.go\", \"overwrite\": true}"},"filename":"crates/forge_app/src/hooks/tracing.rs","line_number":99}
{"timestamp":" 867.108106451s","level":"INFO","fields":{"message":"Executing tool call","tool_name":"write","arguments":"{\"content\": \"package pty\\n\\nimport (\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/andyrewlee/amux/internal/config\\\"\\n\\t\\\"github.com/andyrewlee/amux/internal/data\\\"\\n\\t\\\"github.com/andyrewlee/amux/internal/tmux\\\"\\n)\\n\\n// AgentType represents the type of AI agent\\ntype AgentType string\\n\\nconst (\\n\\tAgentClaude   AgentType = \\\"claude\\\"\\n\\tAgentCodex    AgentType = \\\"codex\\\"\\n\\tAgentGemini   AgentType = \\\"gemini\\\"\\n\\tAgentAmp      AgentType = \\\"amp\\\"\\n\\tAgentOpencode AgentType = \\\"opencode\\\"\\n\\tAgentDroid    AgentType = \\\"droid\\\"\\n\\tAgentCline    AgentType = \\\"cline\\\"\\n\\tAgentCursor   AgentType = \\\"cursor\\\"\\n\\tAgentPi       AgentType = \\\"pi\\\"\\n)\\n\\n// Agent represents a running AI agent instance\\ntype Agent struct {\\n\\tType      AgentType\\n\\tTerminal  *Terminal\\n\\tWorkspace *data.Workspace\\n\\tConfig    config.AssistantConfig\\n\\tSession   string\\n}\\n\\n// AgentStateChange represents a state change produced by AgentManager operations.\\n// Callers convert these to tea.Msg for Bubbletea processing.\\ntype AgentStateChange struct {\\n\\tKind       string  // \\\"created\\\", \\\"closed\\\"\\n\\tAgentType  string  // string representation of AgentType\\n\\tSession    string  // tmux session name\\n\\tError      error   // non-nil when operation failed\\n}\\n\\n// agentCmd is a command sent to the AgentManager's serial command channel.\\ntype agentCmd struct {\\n\\tkind string\\n\\n\\t// create\\n\\tws          *data.Workspace\\n\\tagentType   AgentType\\n\\tsessionName string\\n\\trows        uint16\\n\\tcols        uint16\\n\\ttags        tmux.SessionTags\\n\\tviewerCmd   string\\n\\n\\t// close\\n\\tagent *Agent\\n\\n\\t// tmux options\\n\\ttmuxOpts tmux.Options\\n\\n\\t// response\\n\\trespCh chan agentResp\\n}\\n\\ntype agentResp struct {\\n\\tagent       *Agent\\n\\terr         error\\n\\ttmuxOptions tmux.Options\\n\\tchange      AgentStateChange\\n}\\n\\n// AgentManager manages agent instances.\\n// All mutable state is serialized through a command channel processed by a\\n// single background goroutine, eliminating the need for a sync.Mutex.\\ntype AgentManager struct {\\n\\tconfig      *config.Config\\n\\tcmdCh       chan agentCmd\\n\\tstopCh      chan struct{}\\n}\\n\\n// NewAgentManager creates a new agent manager and starts its command-processing goroutine.\\nfunc NewAgentManager(cfg *config.Config) *AgentManager {\\n\\tm := &AgentManager{\\n\\t\\tconfig: cfg,\\n\\t\\tcmdCh:  make(chan agentCmd, 64),\\n\\t\\tstopCh: make(chan struct{}),\\n\\t}\\n\\tgo m.loop()\\n\\treturn m\\n}\\n\\nfunc (m *AgentManager) loop() {\\n\\tagents := make(map[data.WorkspaceID][]*Agent)\\n\\ttmuxOptions := tmux.DefaultOptions()\\n\\n\\tfor {\\n\\t\\tselect {\\n\\t\\tcase <-m.stopCh:\\n\\t\\t\\t// Drain remaining commands before shutting down\\n\\t\\t\\tfor {\\n\\t\\t\\t\\tselect {\\n\\t\\t\\t\\tcase cmd := <-m.cmdCh:\\n\\t\\t\\t\\t\\tm.handle(&cmd, agents, &tmuxOptions)\\n\\t\\t\\t\\tdefault:\\n\\t\\t\\t\\t\\treturn\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\tcase cmd := <-m.cmdCh:\\n\\t\\t\\tm.handle(&cmd, agents, &tmuxOptions)\\n\\t\\t}\\n\\t}\\n}\\n\\nfunc (m *AgentManager) handle(cmd *agentCmd, agents map[data.WorkspaceID][]*Agent, tmuxOpts *tmux.Options) {\\n\\tswitch cmd.kind {\\n\\tcase \\\"set_tmux_opts\\\":\\n\\t\\t*tmuxOpts = cmd.tmuxOpts\\n\\t\\tcmd.respCh <- agentResp{tmuxOptions: *tmuxOpts}\\n\\n\\tcase \\\"get_tmux_opts\\\":\\n\\t\\tcmd.respCh <- agentResp{tmuxOptions: *tmuxOpts}\\n\\n\\tcase \\\"create_agent\\\":\\n\\t\\tagent, err := m.createAgentLocked(cmd, agents, tmuxOpts)\\n\\t\\tcmd.respCh <- agentResp{agent: agent, err: err, change: AgentStateChange{\\n\\t\\t\\tKind:      \\\"created\\\",\\n\\t\\t\\tAgentType: string(cmd.agentType),\\n\\t\\t\\tSession:   cmd.sessionName,\\n\\t\\t\\tError:     err,\\n\\t\\t}}\\n\\n\\tcase \\\"close_agent\\\":\\n\\t\\tm.closeAgentLocked(cmd.agent, agents)\\n\\t\\tcmd.respCh <- agentResp{change: AgentStateChange{\\n\\t\\t\\tKind:    \\\"closed\\\",\\n\\t\\t\\tSession: cmd.agent.Session,\\n\\t\\t}}\\n\\n\\tcase \\\"close_all\\\":\\n\\t\\tfor _, ags := range agents {\\n\\t\\t\\tfor _, a := range ags {\\n\\t\\t\\t\\tif a.Terminal != nil {\\n\\t\\t\\t\\t\\ta.Terminal.Close()\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\tagents = make(map[data.WorkspaceID][]*Agent)\\n\\t\\t// The agents map variable is shadowed here, so we need to ensure\\n\\t\\t// the caller's map is updated by copying back.\\n\\t\\tfor k := range agents {\\n\\t\\t\\tdelete(agents, k)\\n\\t\\t}\\n\\t\\tcmd.respCh <- agentResp{}\\n\\n\\tcase \\\"close_workspace\\\":\\n\\t\\tws := cmd.ws\\n\\t\\tif ws != nil {\\n\\t\\t\\twsID := ws.ID()\\n\\t\\t\\tfor _, a := range agents[wsID] {\\n\\t\\t\\t\\tif a.Terminal != nil {\\n\\t\\t\\t\\t\\ta.Terminal.Close()\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tdelete(agents, wsID)\\n\\t\\t}\\n\\t\\tcmd.respCh <- agentResp{}\\n\\t}\\n}\\n\\nfunc (m *AgentManager) createAgentLocked(cmd *agentCmd, agents map[data.WorkspaceID][]*Agent, tmuxOpts *tmux.Options) (*Agent, error) {\\n\\tws := cmd.ws\\n\\tagentType := cmd.agentType\\n\\tsessionName := cmd.sessionName\\n\\n\\tif sessionName == \\\"\\\" {\\n\\t\\tif cmd.kind == \\\"create_agent\\\" {\\n\\t\\t\\tsessionName = tmux.SessionName(\\\"amux\\\", string(ws.ID()), string(agentType))\\n\\t\\t} else {\\n\\t\\t\\tsessionName = tmux.SessionName(\\\"amux\\\", string(ws.ID()), \\\"viewer\\\")\\n\\t\\t}\\n\\t}\\n\\n\\tif cmd.kind == \\\"create_agent\\\" {\\n\\t\\tassistantCfg, ok := m.config.Assistants[string(agentType)]\\n\\t\\tif !ok {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"unknown agent type: %s\\\", agentType)\\n\\t\\t}\\n\\t\\tif err := tmux.EnsureAvailable(); err != nil {\\n\\t\\t\\treturn nil, err\\n\\t\\t}\\n\\n\\t\\tenv := []string{\\n\\t\\t\\t\\\"WORKSPACE_ROOT=\\\" + ws.Root,\\n\\t\\t\\t\\\"WORKSPACE_NAME=\\\" + ws.Name,\\n\\t\\t\\t\\\"LINES=\\\",\\n\\t\\t\\t\\\"COLUMNS=\\\",\\n\\t\\t\\t\\\"COLORTERM=truecolor\\\",\\n\\t\\t}\\n\\n\\t\\tshell := os.Getenv(\\\"SHELL\\\")\\n\\t\\tif shell == \\\"\\\" {\\n\\t\\t\\tshell = \\\"/bin/bash\\\"\\n\\t\\t}\\n\\n\\t\\tfullCommand := fmt.Sprintf(\\\"%s; stty sane; printf '\\\\\\\\033[?1049l\\\\\\\\033[?25h\\\\\\\\033[0m\\\\\\\\033c'; echo 'Agent exited. Dropping to shell...'; export TERM=xterm-256color; exec %s -l\\\", assistantCfg.Command, shell)\\n\\n\\t\\ttermCommand := tmux.NewClientCommand(sessionName, tmux.ClientCommandParams{\\n\\t\\t\\tWorkDir:        ws.Root,\\n\\t\\t\\tCommand:        fullCommand,\\n\\t\\t\\tOptions:        *tmuxOpts,\\n\\t\\t\\tTags:           cmd.tags,\\n\\t\\t\\tDetachExisting: true,\\n\\t\\t})\\n\\t\\tterm, err := NewWithSize(termCommand, ws.Root, env, cmd.rows, cmd.cols)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to create terminal: %w\\\", err)\\n\\t\\t}\\n\\n\\t\\tagent := &Agent{\\n\\t\\t\\tType:      agentType,\\n\\t\\t\\tTerminal:  term,\\n\\t\\t\\tWorkspace: ws,\\n\\t\\t\\tConfig:    assistantCfg,\\n\\t\\t\\tSession:   sessionName,\\n\\t\\t}\\n\\t\\tagents[ws.ID()] = append(agents[ws.ID()], agent)\\n\\t\\treturn agent, nil\\n\\t}\\n\\n\\t// create_viewer\\n\\tif ws == nil {\\n\\t\\treturn nil, errors.New(\\\"workspace is required\\\")\\n\\t}\\n\\tif err := tmux.EnsureAvailable(); err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\tenv := []string{\\n\\t\\t\\\"WORKSPACE_ROOT=\\\" + ws.Root,\\n\\t\\t\\\"WORKSPACE_NAME=\\\" + ws.Name,\\n\\t\\t\\\"TERM=xterm-256color\\\",\\n\\t\\t\\\"COLORTERM=truecolor\\\",\\n\\t}\\n\\n\\ttermCommand := tmux.NewClientCommand(sessionName, tmux.ClientCommandParams{\\n\\t\\tWorkDir:        ws.Root,\\n\\t\\tCommand:        cmd.viewerCmd,\\n\\t\\tOptions:        *tmuxOpts,\\n\\t\\tTags:           cmd.tags,\\n\\t\\tDetachExisting: true,\\n\\t})\\n\\tterm, err := NewWithSize(termCommand, ws.Root, env, cmd.rows, cmd.cols)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to create terminal: %w\\\", err)\\n\\t}\\n\\n\\tagent := &Agent{\\n\\t\\tType:      AgentType(\\\"viewer\\\"),\\n\\t\\tTerminal:  term,\\n\\t\\tWorkspace: ws,\\n\\t\\tConfig:    config.AssistantConfig{},\\n\\t\\tSession:   sessionName,\\n\\t}\\n\\tagents[ws.ID()] = append(agents[ws.ID()], agent)\\n\\treturn agent, nil\\n}\\n\\nfunc (m *AgentManager) closeAgentLocked(agent *Agent, agents map[data.WorkspaceID][]*Agent) {\\n\\tif agent.Terminal != nil {\\n\\t\\tagent.Terminal.Close()\\n\\t}\\n\\tif agent.Workspace != nil {\\n\\t\\twsID := agent.Workspace.ID()\\n\\t\\tags := agents[wsID]\\n\\t\\tfor i, a := range ags {\\n\\t\\t\\tif a == agent {\\n\\t\\t\\t\\tagents[wsID] = append(ags[:i], ags[i+1:]...)\\n\\t\\t\\t\\tbreak\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n}\\n\\n// sendCmd sends a command to the loop and returns the response.\\nfunc (m *AgentManager) sendCmd(cmd agentCmd) agentResp {\\n\\tif m.cmdCh == nil {\\n\\t\\treturn agentResp{err: errors.New(\\\"agent manager is shutting down\\\")}\\n\\t}\\n\\trespCh := make(chan agentResp, 1)\\n\\tcmd.respCh = respCh\\n\\tm.cmdCh <- cmd\\n\\treturn <-respCh\\n}\\n\\n// SetTmuxOptions updates tmux options for future agent/viewer command construction.\\nfunc (m *AgentManager) SetTmuxOptions(opts tmux.Options) {\\n\\tresp := m.sendCmd(agentCmd{kind: \\\"set_tmux_opts\\\", tmuxOpts: opts})\\n\\t_ = resp\\n}\\n\\nfunc (m *AgentManager) getTmuxOptions() tmux.Options {\\n\\tresp := m.sendCmd(agentCmd{kind: \\\"get_tmux_opts\\\"})\\n\\treturn resp.tmuxOptions\\n}\\n\\n// CreateAgent creates a new agent for the given workspace.\\nfunc (m *AgentManager) CreateAgent(ws *data.Workspace, agentType AgentType, sessionName string, rows, cols uint16) (*Agent, error) {\\n\\treturn m.CreateAgentWithTags(ws, agentType, sessionName, rows, cols, tmux.SessionTags{})\\n}\\n\\n// CreateAgentWithTags creates a new agent for the given workspace with tmux tags.\\nfunc (m *AgentManager) CreateAgentWithTags(ws *data.Workspace, agentType AgentType, sessionName string, rows, cols uint16, tags tmux.SessionTags) (*Agent, error) {\\n\\tresp := m.sendCmd(agentCmd{\\n\\t\\tkind:        \\\"create_agent\\\",\\n\\t\\tws:          ws,\\n\\t\\tagentType:   agentType,\\n\\t\\tsessionName: sessionName,\\n\\t\\trows:        rows,\\n\\t\\tcols:        cols,\\n\\t\\ttags:        tags,\\n\\t})\\n\\treturn resp.agent, resp.err\\n}\\n\\n// CreateViewer creates a new agent (viewer) for the given workspace and command.\\nfunc (m *AgentManager) CreateViewer(ws *data.Workspace, command, sessionName string, rows, cols uint16) (*Agent, error) {\\n\\treturn m.CreateViewerWithTags(ws, command, sessionName, rows, cols, tmux.SessionTags{})\\n}\\n\\n// CreateViewerWithTags creates a new viewer for the given workspace with tmux tags.\\nfunc (m *AgentManager) CreateViewerWithTags(ws *data.Workspace, command, sessionName string, rows, cols uint16, tags tmux.SessionTags) (*Agent, error) {\\n\\tresp := m.sendCmd(agentCmd{\\n\\t\\tkind:        \\\"create_viewer\\\",\\n\\t\\tws:          ws,\\n\\t\\tsessionName: sessionName,\\n\\t\\trows:        rows,\\n\\t\\tcols:        cols,\\n\\t\\ttags:        tags,\\n\\t\\tviewerCmd:   command,\\n\\t})\\n\\treturn resp.agent, resp.err\\n}\\n\\n// CloseAgent closes an agent.\\n// Returns AgentStateChange that the caller can convert to a tea.Msg.\\nfunc (m *AgentManager) CloseAgent(agent *Agent) AgentStateChange {\\n\\tif agent == nil {\\n\\t\\treturn AgentStateChange{}\\n\\t}\\n\\tresp := m.sendCmd(agentCmd{kind: \\\"close_agent\\\", agent: agent})\\n\\treturn resp.change\\n}\\n\\n// CloseAll closes all agents.\\nfunc (m *AgentManager) CloseAll() {\\n\\trespCh := make(chan agentResp, 1)\\n\\tm.cmdCh <- agentCmd{kind: \\\"close_all\\\", respCh: respCh}\\n\\t<-respCh\\n}\\n\\n// CloseWorkspaceAgents closes and removes all agents for a specific workspace.\\nfunc (m *AgentManager) CloseWorkspaceAgents(ws *data.Workspace) {\\n\\tif ws == nil {\\n\\t\\treturn\\n\\t}\\n\\trespCh := make(chan agentResp, 1)\\n\\tm.cmdCh <- agentCmd{kind: \\\"close_workspace\\\", ws: ws, respCh: respCh}\\n\\t<-respCh\\n}\\n\\n// SendInterrupt sends an interrupt to an agent.\\nfunc (m *AgentManager) SendInterrupt(agent *Agent) error {\\n\\tif agent.Terminal == nil {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Send multiple interrupts if configured (e.g., for Claude)\\n\\tfor i := 0; i < agent.Config.InterruptCount; i++ {\\n\\t\\tif err := agent.Terminal.SendInterrupt(); err != nil {\\n\\t\\t\\treturn err\\n\\t\\t}\\n\\t\\t// Add delay between interrupts if configured\\n\\t\\tif i < agent.Config.InterruptCount-1 && agent.Config.InterruptDelayMs > 0 {\\n\\t\\t\\ttime.Sleep(time.Duration(agent.Config.InterruptDelayMs) * time.Millisecond)\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\", \"file_path\": \"/home/sloth/Documents/projects/amux/polecats/rust/badmux/internal/pty/agent.go\", \"overwrite\": true}"},"filename":"crates/forge_app/src/tool_registry.rs","line_number":101}
