direction from unclamped Y before clamping\\n264:\\t\\ttab.selectionScroll.SetDirection(termY, termHeight)\\n265:\\n266:\\t\\tif termY < 0 {\\n267:\\t\\t\\ttab.Terminal.ScrollView(1)\\n268:\\t\\t\\ttermY = 0\\n269:\\t\\t} else if termY >= termHeight {\\n270:\\t\\t\\ttab.Terminal.ScrollView(-1)\\n271:\\t\\t\\ttermY = termHeight - 1\\n272:\\t\\t}\\n273:\\n274:\\t\\tabsLine := tab.Terminal.ScreenYToAbsoluteLine(termY)\\n275:\\t\\tstartX := tab.Terminal.SelStartX()\\n276:\\t\\tstartLine := tab.Terminal.SelStartLine()\\n277:\\t\\tif !tab.Terminal.HasSelection() {\\n278:\\t\\t\\tstartX = tab.Selection.StartX\\n279:\\t\\t\\tstartLine = tab.Selection.StartLine\\n280:\\t\\t}\\n281:\\t\\ttab.Selection.EndX = termX\\n282:\\t\\ttab.Selection.EndLine = absLine\\n283:\\t\\ttab.Terminal.SetSelection(startX, startLine, termX, absLine, true, false)\\n284:\\t\\ttab.Selection.StartX = startX\\n285:\\t\\ttab.Selection.StartLine = startLine\\n286:\\n287:\\t\\ttab.selectionLastTermX = termX\\n288:\\t\\tif needTick, gen := tab.selectionScroll.NeedsTick(); needTick && m.msgSink != nil {\\n289:\\t\\t\\tm.msgSink(selectionTickRequest{\\n290:\\t\\t\\t\\tworkspaceID: ev.workspaceID,\\n291:\\t\\t\\t\\ttabID:       ev.tabID,\\n292:\\t\\t\\t\\tgen:         gen,\\n293:\\t\\t\\t})\\n294:\\t\\t}\\n295:\\tcase tabEventSelectionFinish:\\n296:\\t\\ttab.mu.Lock()\\n297:\\t\\tif !tab.Selection.Active {\\n298:\\t\\t\\ttab.mu.Unlock()\\n299:\\t\\t\\treturn\\n300:\\t\\t}\\n301:\\t\\ttext := \\\"\\\"\\n302:\\t\\ttab.Selection.Active = false\\n303:\\t\\ttab.selectionScroll.Reset()\\n304:\\t\\tif tab.Terminal != nil &&\\n305:\\t\\t\\t(tab.Selection.StartX != tab.Selection.EndX ||\\n306:\\t\\t\\t\\ttab.Selection.StartLine != tab.Selection.EndLine) {\\n307:\\t\\t\\ttext = tab.Terminal.SelectedText()\\n308:\\t\\t}\\n309:\\t\\ttab.mu.Unlock()\\n310:\\t\\tif text != \\\"\\\" && m.msgSink != nil {\\n311:\\t\\t\\tm.msgSink(tabSelectionResult{workspaceID: ev.workspaceID, tabID: ev.tabID, clipboard: text})\\n312:\\t\\t}\\n313:\\tcase tabEventScrollBy:\\n314:\\t\\ttab.mu.Lock()\\n315:\\t\\tif tab.Terminal != nil && ev.delta != 0 {\\n316:\\t\\t\\ttab.Terminal.ScrollView(ev.delta)\\n317:\\t\\t}\\n318:\\t\\ttab.mu.Unlock()\\n319:\\tcase tabEventSelectionScrollTick:\\n320:\\t\\ttab.mu.Lock()\\n321:\\t\\tif !tab.Selection.Active || tab.Terminal == nil || !tab.selectionScroll.HandleTick(ev.gen) {\\n322:\\t\\t\\ttab.mu.Unlock()\\n323:\\t\\t\\treturn\\n324:\\t\\t}\\n325:\\t\\ttab.Terminal.ScrollView(tab.selectionScroll.ScrollDir)\\n326:\\n327:\\t\\t// Update selection endpoint to viewport edge\\n328:\\t\\tedgeY := 0\\n329:\\t\\tif tab.selectionScroll.ScrollDir < 0 {\\n330:\\t\\t\\tedgeY = tab.Terminal.Height - 1\\n331:\\t\\t}\\n332:\\t\\tabsLine := tab.Terminal.ScreenYToAbsoluteLine(edgeY)\\n333:\\t\\tendX := tab.selectionLastTermX\\n334:\\t\\tstartX := tab.Terminal.SelStartX()\\n335:\\t\\tstartLine := tab.Terminal.SelStartLine()\\n336:\\t\\tif !tab.Terminal.HasSelection() {\\n337:\\t\\t\\tstartX = tab.Selection.StartX\\n338:\\t\\t\\tstartLine = tab.Selection.StartLine\\n339:\\t\\t}\\n340:\\t\\ttab.Selection.EndX = endX\\n341:\\t\\ttab.Selection.EndLine = absLine\\n342:\\t\\ttab.Terminal.SetSelection(startX, startLine, endX, absLine, true, false)\\n343:\\t\\ttab.Selection.StartX = startX\\n344:\\t\\ttab.Selection.StartLine = startLine\\n345:\\n346:\\t\\ttab.mu.Unlock()\\n347:\\t\\tif m.msgSink != nil {\\n348:\\t\\t\\tm.msgSink(selectionTickRequest{\\n349:\\t\\t\\t\\tworkspaceID: ev.workspaceID,\\n350:\\t\\t\\t\\ttabID:       ev.tabID,\\n351:\\t\\t\\t\\tgen:         ev.gen,\\n352:\\t\\t\\t})\\n353:\\t\\t}\\n354:\\tcase tabEventScrollToBottom:\\n355:\\t\\ttab.mu.Lock()\\n356:\\t\\tif tab.Terminal != nil && tab.Terminal.IsScrolled() {\\n357:\\t\\t\\ttab.Terminal.ScrollViewToBottom()\\n358:\\t\\t}\\n359:\\t\\ttab.mu.Unlock()\\n360:\\tcase tabEventScrollPage:\\n361:\\t\\ttab.mu.Lock()\\n362:\\t\\tif tab.Terminal != nil && ev.scrollPage != 0 {\\n363:\\t\\t\\tdelta := tab.Terminal.Height / 4\\n3