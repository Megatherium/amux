\t\\tflushPendingSince:  time.Now().Add(-time.Second),\\n 43:\\t\\tparserResetPending: true,\\n 44:\\t\\tactorWritesPending: 1,\\n 45:\\t}\\n 46:\\tm.tabsByWorkspace[wsID] = []*Tab{tab}\\n 47:\\tm.activeTabByWorkspace[wsID] = 0\\n 48:\\tm.workspace = ws\\n 49:\\n 50:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: tab.ID})\\n 51:\\n 52:\\tif tab.parserResetPending {\\n 53:\\t\\tt.Fatal(\\\"expected stale actor flush to clear parserResetPending\\\")\\n 54:\\t}\\n 55:\\tif tab.actorWritesPending != 0 {\\n 56:\\t\\tt.Fatalf(\\\"expected stale actor flush to clear actorWritesPending, got %d\\\", tab.actorWritesPending)\\n 57:\\t}\\n 58:\\tif len(tab.pendingOutput) == 0 {\\n 59:\\t\\tt.Fatal(\\\"expected pending output to remain queued for the follow-up flush\\\")\\n 60:\\t}\\n 61:\\tif !tab.flushScheduled {\\n 62:\\t\\tt.Fatal(\\\"expected follow-up flush to be scheduled after stale actor fallback\\\")\\n 63:\\t}\\n 64:}\\n 65:\\n 66:func TestRunTabActor_SetsReadyWithoutEmittingLivenessMsgs(t *testing.T) {\\n 67:\\tm := newTestModel()\\n 68:\\tm.tabEvents = make(chan tabEvent, 1)\\n 69:\\tsinkMsgs := make(chan tea.Msg, 4)\\n 70:\\tm.msgSink = func(msg tea.Msg) {\\n 71:\\t\\tsinkMsgs <- msg\\n 72:\\t}\\n 73:\\n 74:\\tctx, cancel := context.WithCancel(context.Background())\\n 75:\\tdefer cancel()\\n 76:\\n 77:\\tdone := make(chan error, 1)\\n 78:\\tgo func() {\\n 79:\\t\\tdone <- m.RunTabActor(ctx)\\n 80:\\t}()\\n 81:\\n 82:\\tdeadline := time.Now().Add(time.Second)\\n 83:\\tfor !m.isTabActorReady() {\\n 84:\\t\\tif time.Now().After(deadline) {\\n 85:\\t\\t\\tt.Fatal(\\\"expected actor startup to set readiness directly\\\")\\n 86:\\t\\t}\\n 87:\\t\\ttime.Sleep(10 * time.Millisecond)\\n 88:\\t}\\n 89:\\n 90:\\tselect {\\n 91:\\tcase msg := <-sinkMsgs:\\n 92:\\t\\tt.Fatalf(\\\"unexpected liveness message on startup: %T\\\", msg)\\n 93:\\tcase <-time.After(100 * time.Millisecond):\\n 94:\\t}\\n 95:\\n 96:\\tcancel()\\n 97:\\tselect {\\n 98:\\tcase err := <-done:\\n