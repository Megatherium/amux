nActiveWithinFn,\\n 51:\\t\\tSessionLatestActivity:   tmux.SessionLatestActivity,\\n 52:\\t\\tSessionCreatedAt:        sessionCreatedAtFn,\\n 53:\\t\\tSessionPaneID:           sessionPaneIDFn,\\n 54:\\t\\tSessionPaneSnapshotInfo: sessionPaneSnapshotInfoFn,\\n 55:\\t\\tSessionPaneSize:         sessionPaneSizeFn,\\n 56:\\t\\tResizePaneToSize:        resizePaneToSizeFn,\\n 57:\\t\\tCapturePaneSnapshot:     capturePaneSnapshotFn,\\n 58:\\t}\\n 59:}\\n 60:\\n 61:func captureExistingSessionBootstrap(sessionName string, cols, rows int, opts tmux.Options) sessionBootstrapCapture {\\n 62:\\treturn common.CaptureExistingSessionBootstrap(sessionName, cols, rows, fullPaneCaptureQuietWindow, opts, sessionBootstrapFns())\\n 63:}\\n 64:\\n 65:func bootstrapSnapshotStillMatchesSession(sessionName string, bootstrap sessionBootstrapCapture, opts tmux.Options) bool {\\n 66:\\treturn common.BootstrapSnapshotStillMatchesSession(sessionName, bootstrap, opts, sessionBootstrapFns())\\n 67:}\\n 68:\\n 69:func rollbackExistingSessionBootstrap(sessionName string, bootstrap sessionBootstrapCapture, opts tmux.Options) {\\n 70:\\tcommon.RollbackExistingSessionBootstrap(sessionName, bootstrap, opts, sessionBootstrapFns())\\n 71:}\\n 72:\\n 73:func sessionHistoryCaptureSize(sessionName string, fallbackCols, fallbackRows int, opts tmux.Options) (int, int) {\\n 74:\\treturn common.SessionHistoryCaptureSize(sessionName, fallbackCols, fallbackRows, opts, sessionBootstrapFns())\\n 75:}\\n 76:\\n 77:func captureSessionHistory(sessionName string, fallbackCols, fallbackRows int, opts tmux.Options) ([]byte, int, int) {\\n 78:\\treturn common.CaptureSessionHistory(sessionName, fallbackCols, fallbackRows, opts, sessionBootstrapFns(), capturePaneFn)\\n 79:}\\n 80:\\n 81:func (m *Model) sessionBootstrapViewportSize() (int, int) {\\n 82:\\tif m.width <= 0 || m.height <= 0 {\\n 83:\\t\\treturn 0, 0\\n 84:\\t}\\n 85:\\ttm := m.terminalMetrics()\\n 86:\\treturn tm.Width, tm.Height\\n 87:}\\n 88:\\n 89:// ReattachActiveTab reattaches to a detached/stopped tmux session.\\n 90:func (m *Model) ReattachActiveTab() tea.Cmd {\\n 91:\\ttabs := m.getTabs()\\n 92:\\tactiveIdx := m.getActiveTabIdx()\\n 93:\\tif len(tabs) == 0 || activeIdx >= len(tabs) {\\n 94:\\t\\treturn nil\\n 95:\\t}\\n 96:\\ttab := tabs[activeIdx]\\n 97:\\tif tab == nil || tab.Workspace == nil {\\n 98:\\t\\treturn nil\\n 99:\\t}\\n100:\\ttab.mu.Lock()\\n101:\\trunning := tab.Running\\n102:\\tdetached := tab.Detached\\n103:\\treattachInFlight := tab.reattachInFlight\\n104:\\tsessionName := tab.SessionName\\n105:\\tcanReattach := detached || !running\\n106:\\tif canReattach && !reattachInFlight {\\n107:\\t\\ttab.reattachInFlight = true\\n108:\\t}\\n109:\\ttab.mu.Unlock()\\n110:\\tif !canReattach {\\n111:\\t\\treturn nil\\n112:\\t}\\n113:\\tif reattachInFlight {\\n114:\\t\\treturn nil\\n115:\\t}\\n116:\\tif m.config == nil || m.config.Assistants == nil {\\n117:\\t\\ttab.mu.Lock()\\n118:\\t\\ttab.reattachInFlight = false\\n119:\\t\\ttab.mu.Unlock()\\n120:\\t\\treturn func() tea.Msg {\\n121:\\t\\t\\treturn messages.Toast{\\n122:\\t\\t\\t\\tMessage: \\\"Tab cannot be reattached\\\",\\n123:\\t\\t\\t\\tLevel:   messages.ToastInfo,\\n124:\\t\\t\\t}\\n125:\\t\\t}\\n126:\\t}\\n127:\\tif _, ok := m.config.Assistants[tab.Assistant]; !ok {\\n128:\\t\\ttab.mu.Lock()\\n129:\\t\\ttab.reattachInFlight = false\\n130:\\t\\ttab.mu.Unlock()\\n131:\\t\\treturn func() tea.Msg {\\n132:\\t\\t\\treturn messages.Toast{\\n133:\\t\\t\\t\\tMessage: \\\"Only assistant tabs can be reattached\\\",\\n134:\\t\\t\\t\\tLevel:   messages.ToastInfo,\\n135:\\t\\t\\t}\\n136:\\t\\t}\\n137:\\t}\\n138:\\ttermWidth, termHeight := m.sessionBootstrapViewportSize()\\n139:\\ttm := m.terminalMetrics()\\n140:\\tattachWidth := tm.Width\\n141:\\tattachHeight := tm.Height\\n142:\\tif sessionName == \\\"\\\" {\\n143:\\t\\tsessionName = tmux.SessionName(\\\"amux\\\", string(tab.Workspace.ID()), string(tab.ID))\\n144:\\t}\\n145:\\tassistant := tab.Assistant\\n146:\\tws := tab.Workspace\\n147:\\ttabID := tab.ID\\n148:\\tticketID := tab.TicketID\\n149:\\tticketTitle := tab.TicketTitle\\n150:\\tmodelName := tab.Model\\n151:\\tagentMode := tab.AgentMode\\n152:\\topts := m.getTmuxOptions()\\n153:\\treturn func() tea.Msg {\\n154:\\t\\tstate, err := sessionStateForFn(sessionName, opts)\\n155:\\t\\tif err != nil {\\n156:\\t\\t\\treturn ptyTabReattachFailed{\\n157:\\t\\t\\t\\tWorkspaceID: string(ws.ID()),\\n158:\\t\\t\\t\\tTabID:       tabID,\\n159:\\t\\t\\t\\tErr:         err,\\n160:\\t\\t\\t\\tAction:      \\\"reattach\\\",\\n161:\\t\\t\\t}\\n162:\\t\\t}\\n163:\\t\\tif !state.Exists || !state.HasLivePane {\\n164:\\t\\t\\tif state.Exists && !state.HasLivePane {\\n165:\\t\\t\\t\\t_ = killSessionFn(sessionName, opts)\\n166:\\t\\t\\t}\\n167:\\t\\t\\ttags := tmux.SessionTags{\\n168:\\t\\t\\t\\tWorkspaceID:  string(ws.ID()),\\n169:\\t\\t\\t\\tTabID:        string(tabID),\\n170:\\t\\t\\t\\tType:         \\\"agent\\\",\\n171:\\t\\t\\t\\tAssistant:    assistant,\\n172:\\t\\t\\t\\tCreatedAt:    time.Now().Unix(),\\n173:\\t\\t\\t\\tInstanceID:   m.instanceID,\\n174:\\t\\t\\t\\tSessionOwner: m.instanceID,\\n175:\\t\\t\\t\\tLeaseAtMS:    time.Now().UnixMilli(),\\n176:\\t\\t\\t\\tTicketID:     ticketID,\\n177:\\t\\t\\t\\tTicketTitle:  ticketTitle,\\n178:\\t\\t\\t\\tModel:        modelName,\\n179:\\t\\t\\t\\tAgentMode:    agentMode,\\n180:\\t\\t\\t}\\n181:\\t\\t\\tagent, err := createAgentWithTagsFn(\\n182:\\t\\t\\t\\tm.agentManager,\\n183:\\t\\t\\t\\tws,\\n184:\\t\\t\\t\\tappPty.AgentType(assistant),\\n185:\\t\\t\\t\\tsessionName,\\n186:\\t\\t\\t\\tuint16(attachHeight),\\n187:\\t\\t\\t\\tuint16(attachWidth),\\n188:\\t\\t\\t\\ttags,\\n189:\\t\\t\\t)\\n190:\\t\\t\\tif err != nil {\\n191:\\t\\t\\t\\treturn ptyTabReattachFailed{\\n192:\\t\\t\\t\\t\\tWorkspaceID: string(ws.ID()),\\n193:\\t\\t\\t\\t\\tTabID:       tabID,\\n194:\\t\\t\\t\\t\\tErr:         err,\\n195:\\t\\t\\t\\t\\tStopped:     true,\\n196:\\t\\t\\t\\t\\tAction:      \\\"reattach\\\",\\n197:\\t\\t\\t\\t}\\n198:\\t\\t\\t}\\n199:\\t\\t\\tcaptureCols, captureRows := sessionHistoryCaptureSize(sessionName, attachWidth, attachHeight, opts)\\n200:\\t\\t\\tscrollback, _ := capturePaneFn(sessionName, opts)\\n201:\\t\\t\\treturn ptyTabReattachResult{\\n202:\\t\\t\\t\\tWorkspaceID:       string(ws.ID()),\\n203:\\t\\t\\t\\tTabID:             tabID,\\n204:\\t\\t\\t\\tAgent:             agent,\\n205:\\t\\t\\t\\tRows:              captureRows,\\n206:\\t\\t\\t\\tCols:              captureCols,\\n207:\\t\\t\\t\\tScrollbackCapture: scrollback,\\n208:\\t\\t\\t\\tCaptureFullPane:   false,\\n209:\\t\\t\\t\\tSnapshotCols:      attachWidth,\\n210:\\t\\t\\t\\tSnapshotRows:      attachHeight,\\n211:\\t\\t\\t}\\n212:\\t\\t}\\n213:\\t\\ttags := tmux.SessionTags{\\n214:\\t\\t\\tWorkspaceID:  string(ws.ID()),\\n215:\\t\\t\\tTabID:        string(tabID),\\n216:\\t\\t\\tType:         \\\"agent\\\",\\n217:\\t\\t\\tAssistant:    assistant,\\n218:\\t\\t\\tInstanceID:   m.instanceID,\\n219:\\t\\t\\tSessionOwner: m.instanceID,\\n220:\\t\\t\\tLeaseAtMS:    time.Now().UnixMilli(),\\n221:\\t\\t\\tTicketID:     ticketID,\\n222:\\t\\t\\tTicketTitle:  ticketTitle,\\n223:\\t\\t\\tModel:        modelName,\\n224:\\t\\t\\tAgentMode:    agentMode,\\n225:\\t\\t}\\n226:\\t\\tbootstrap := captureExistingSessionBootstrap(sessionName, termWidth, termHeight, opts)\\n227:\\t\\tsnapshot := bootstrap.Snapshot\\n228:\\t\\tcaptureFullPane := bootstrap.CaptureFullPane\\n229:\\t\\tvar scrollback []byte\\n230:\\t\\tcaptureCols := termWidth\\n231:\\t\\tcaptureRows := termHeight\\n232:\\t\\tvar postAttachScrollback []byte\\n233:\\t\\tagent, err := createAgentWithTagsFn(\\n234:\\t\\t\\tm.agentManager,\\n235:\\t\\t\\tws,\\n236:\\t\\t\\tappPty.AgentType(assistant),\\n237:\\t\\t\\tsessionName,\\n238:\\t\\t\\tuint16(attachHeight),\\n239:\\t\\t\\tuint16(attachWidth),\\n240:\\t\\t\\ttags,\\n241:\\t\\t)\\n242:\\t\\tif err != nil {\\n243:\\t\\t\\trollbackExistingSessionBootstrap(sessionName, bootstrap, opts)\\n244:\\t\\t\\treturn ptyTabReattachFailed{\\n245:\\t\\t\\t\\tWorkspaceID: string(ws.ID()),\\n246:\\t\\t\\t\\tTabID:       tabID,\\n247:\\t\\t\\t\\tErr:         err,\\n248:\\t\\t\\t\\tAction:      \\\"reattach\\\",\\n249:\\t\\t\\t}\\n250:\\t\\t}\\n251:\\t\\tif captureFullPane && bootstrapSnapshotStillMatchesSession(sessionName, bootstrap, opts) {\\n252:\\t\\t\\tscrollback = snapshot.Data\\n253:\\t\\t\\tpostAttachScrollback, _ = capturePaneFn(sessionName, opts)\\n254:\\t\\t} else {\\n255:\\t\\t\\tif captureFullPane {\\n256:\\t\\t\\t\\tcaptureFullPane = false\\n257:\\t\\t\\t\\tsnapshot = tmux.PaneSnapshot{}\\n258:\\t\\t\\t}\\n259:\\t\\t\\tscrollback, captureCols, captureRows = captureSessionHistory(sessionName, attachWidth, attachHeight, opts)\\n260:\\t\\t}\\n261:\\t\\treturn ptyTabReattachResult{\\n262:\\t\\t\\tWorkspaceID:                 string(ws.ID()),\\n263:\\t\\t\\tTabID:                       tabID,\\n264:\\t\\t\\tAgent:                       agent,\\n265:\\t\\t\\tRows:                        captureRows,\\n266:\\t\\t\\tCols:                        captureCols,\\n267:\\t\\t\\tScrollbackCapture:           scrollback,\\n268:\\t\\t\\tPostAttachScrollbackCapture: postAttachScrollback,\\n269:\\t\\t\\tCaptureFullPane:             captureFullPane,\\n270:\\t\\t\\tSnapshotCols:                snapshot.Cols,\\n271:\\t\\t\\tSnapshotRows:                snapshot.Rows,\\n272:\\t\\t\\tSnapshotCursorX:             snapshot.CursorX,\\n273:\\t\\t\\tSnapshotCursorY:             snapshot.CursorY,\\n274:\\t\\t\\tSnapshotHasCursor:           snapshot.HasCursor,\\n275:\\t\\t\\tSnapshotModeState:           snapshot.ModeState,\\n276:\\t\\t}\\n277:\\t}\\n278:}\\n279:\\n280:// RestartActiveTab restarts a stopped or detached agent tab by creating a fresh tmux client.\\n281:func (m *Model) RestartActiveTab() tea.Cmd {\\n282:\\ttabs := m.getTabs()\\n283:\\tactiveIdx := m.getActiveTabIdx()\\n284:\\tif len(tabs) == 0 || activeIdx >= len(tabs) {\\n285:\\t\\treturn nil\\n286:\\t}\\n287:\\ttab := tabs[activeIdx]\\n288:\\tif tab == nil || tab.Workspace == nil {\\n289:\\t\\treturn nil\\n290:\\t}\\n291:\\tif m.config == nil || m.config.Assistants == nil {\\n292:\\t\\treturn nil\\n293:\\t}\\n294:\\tif _, ok := m.config.Assistants[tab.Assistant]; !ok {\\n295:\\t\\treturn nil\\n296:\\t}\\n297:\\ttab.mu.Lock()\\n298:\\trunning := tab.Running\\n299:\\tsessionName := tab.SessionName\\n300:\\tif sessionName == \\\"\\\" && tab.Agent != nil {\\n301:\\t\\tsessionName = tab.Agent.Session\\n302:\\t}\\n303:\\ttab.mu.Unlock()\\n304:\\tif running {\\n305:\\t\\treturn func() tea.Msg {\\n306:\\t\\t\\treturn messages.Toast{\\n307:\\t\\t\\t\\tMessage: \\\"Tab is still running\\\",\\n308:\\t\\t\\t\\tLevel:   messages.ToastInfo,\\n309:\\t\\t\\t}\\n310:\\t\\t}\\n311:\\t}\\n312:\\tws := tab.Workspace\\n313:\\ttabID := tab.ID\\n314:\\tif sessionName == \\\"\\\" {\\n315:\\t\\tsessionName = tmux.SessionName(\\\"amux\\\", string(ws.ID()), string(tabID))\\n316:\\t}\\n317:\\tm.stopPTYReader(tab)\\n318:\\tvar existingAgent *appPty.Agent\\n319:\\ttab.mu.Lock()\\n320:\\texistingAgent = tab.Agent\\n321:\\ttab.Agent = nil\\n322:\\ttab.mu.Unlock()\\n323:\\tif existingAgent != nil {\\n324:\\t\\t_ = m.agentManager.CloseAgent(existingAgent)\\n325:\\t}\\n326:\\ttmuxOpts := m.getTmuxOptions()\\n327:\\n328:\\ttm := m.terminalMetrics()\\n329:\\ttermWidth := tm.Width\\n330:\\ttermHeight := tm.Height\\n331:\\tassistant := tab.Assistant\\n332:\\tticketID := tab.TicketID\\n333:\\tticketTitle := tab.TicketTitle\\n334:\\tmodelName := tab.Model\\n335:\\tagentMode := tab.AgentMode\\n336:\\n337:\\treturn func() tea.Msg {\\n338:\\t\\t// KillSession is synchronous: it calls cmd.Run() which blocks until the\\n339:\\t\\t// tmux server processes the kill and returns. By the time it completes,\\n340:\\t\\t// the session is fully removed from tmux's perspective.\\n341:\\t\\t// The subsequent CreateAgentWithTags uses `new-session -Ads` which is\\n342:\\t\\t// atomic (attach-if-exists, create-if-not), providing an additional\\n343:\\t\\t// safety net in the unlikely event of cleanup lag.\\n344:\\t\\t_ = killSessionFn(sessionName, tmuxOpts)\\n345:\\n346:\\t\\ttags := tmux.SessionTags{\\n347:\\t\\t\\tWorkspaceID:  string(ws.ID()),\\n348:\\t\\t\\tTabID:        string(tabID),\\n349:\\t\\t\\tType:         \\\"agent\\\",\\n350:\\t\\t\\tAssistant:    assistant,\\n351:\\t\\t\\tCreatedAt:    time.Now().Unix(),\\n352:\\t\\t\\tInstanceID:   m.instanceID,\\n353:\\t\\t\\tSessionOwner: m.instanceID,\\n354:\\t\\t\\tLeaseAtMS:    time.Now().UnixMilli(),\\n355:\\t\\t\\tTicketID:     ticketID,\\n356:\\t\\t\\tTicketTitle:  ticketTitle,\\n357:\\t\\t\\tModel:        modelName,\\n358:\\t\\t\\tAgentMode:    agentMode,\\n359:\\t\\t}\\n360:\\t\\tagent, err := createAgentWithTagsFn(\\n361:\\t\\t\\tm.agentManager,\\n362:\\t\\t\\tws,\\n363:\\t\\t\\tappPty.AgentType(assistant),\\n364:\\t\\t\\tsessionName,\\n365:\\t\\t\\tuint16(termHeight),\\n366:\\t\\t\\tuint16(termWidth),\\n367:\\t\\t\\ttags,\\n368:\\t\\t)\\n369:\\t\\tif err != nil {\\n370:\\t\\t\\treturn ptyTabReattachFailed{\\n371:\\t\\t\\t\\tWorkspaceID: string(ws.ID()),\\n372:\\t\\t\\t\\tTabID:       tabID,\\n373:\\t\\t\\t\\tErr:         err,\\n374:\\t\\t\\t\\tStopped:     true,\\n375:\\t\\t\\t\\tAction:      \\\"restart\\\",\\n376:\\t\\t\\t}\\n377:\\t\\t}\\n378:\\t\\t// Fresh restarts must avoid seeding the visible screen before the PTY\\n379:\\t\\t// reader drains unread startup bytes from the newly attached client.\\n380:\\t\\tcaptureCols, captureRows := sessionHistoryCaptureSize(sessionName, termWidth, termHeight, tmuxOpts)\\n381:\\t\\tscrollback, _ := capturePaneFn(sessionName, tmuxOpts)\\n382:\\t\\treturn ptyTabReattachResult{\\n383:\\t\\t\\tWorkspaceID:       string(ws.ID()),\\n384:\\t\\t\\tTabID:             tabID,\\n385:\\t\\t\\tAgent:             agent,\\n386:\\t\\t\\tRows:              captureRows,\\n387:\\t\\t\\tCols:              captureCols,\\n388:\\t\\t\\tScrollbackCapture: scrollback,\\n389:\\t\\t\\tCaptureFullPane:   false,\\n390:\\t\\t\\tSnapshotCols