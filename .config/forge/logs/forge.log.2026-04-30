{"timestamp":" 208.502015475s","level":"DEBUG","fields":{"message":"Adding tool results to context","results":"[ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_00_wmEcRHErvMByXTGpbicNwjuL\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/Documents/projects/amux/polecats/rust/badmux/internal/app/app_init.go\\\"\\n  display_lines=\\\"120-150\\\"\\n  total_lines=\\\"428\\\"\\n><![CDATA[120:\\t// Propagate styles to all components (they were created with default theme)\\n121:\\tapp.ui.dashboard.SetStyles(styles)\\n122:\\tapp.ui.sidebar.SetStyles(styles)\\n123:\\tapp.ui.sidebarTerminal.SetStyles(styles)\\n124:\\tapp.ui.center.SetStyles(styles)\\n125:\\tapp.ui.toast.SetStyles(styles)\\n126:\\tapp.setKeymapHintsEnabled(cfg.UI.ShowKeymapHints)\\n127:\\t// Propagate prefix key label to components for help bars\\n128:\\tapp.ui.dashboard.SetPrefixHelpLabel(app.prefixHelpLabel)\\n129:\\tapp.ui.center.SetPrefixHelpLabel(app.prefixHelpLabel)\\n130:\\tapp.ui.sidebarTerminal.SetPrefixHelpLabel(app.prefixHelpLabel)\\n131:\\t// Propagate tmux config to components\\n132:\\tapp.ui.center.SetTmuxConfig(tmuxOpts.ServerName, tmuxOpts.ConfigPath)\\n133:\\tapp.ui.sidebarTerminal.SetTmuxConfig(tmuxOpts.ServerName, tmuxOpts.ConfigPath)\\n134:\\tapp.supervisor.Start(\\\"center.tab_actor\\\", app.ui.center.RunTabActor, supervisor.WithRestartPolicy(supervisor.RestartAlways))\\n135:\\tif app.gitStatus != nil {\\n136:\\t\\tapp.supervisor.Start(\\\"git.status_manager\\\", app.gitStatus.Run)\\n137:\\t}\\n138:\\tapp.gitStatusController.startSupervisedTasks()\\n139:\\treturn app, nil\\n140:}\\n141:\\n142:// Init initializes the application.\\n143:func (a *App) Init() tea.Cmd {\\n144:\\tcmds := []tea.Cmd{\\n145:\\t\\ta.loadProjects(),\\n146:\\t\\ta.ui.dashboard.Init(),\\n147:\\t\\ta.ui.center.Init(),\\n148:\\t\\ta.ui.sidebar.Init(),\\n149:\\t\\ta.ui.sidebarTerminal.Init(),\\n150:\\t\\ta.startGitStatusTicker(),]]>\\n</file>\")] } }, ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_01_vDn2z3OEqUQVfUAHj41KszyF\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/Documents/projects/amux/polecats/rust/badmux/internal/ui/center/model_pty_config.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"85\\\"\\n><![CDATA[ 1:package center\\n 2:\\n 3:import \\\"time\\\"\\n 4:\\n 5:// PTY constants\\n 6:const (\\n 7:\\tptyFlushQuiet       = 12 * time.Millisecond\\n 8:\\tptyFlushMaxInterval = 48 * time.Millisecond\\n 9:\\tptyFlushQuietAlt    = 24 * time.Millisecond\\n10:\\tptyFlushMaxAlt      = 96 * time.Millisecond\\n11:\\t// Inactive tabs still need to advance their terminal state, but can flush less frequently.\\n12:\\tptyFlushInactiveMultiplier          = 4\\n13:\\tptyFlushInactiveHeavyMultiplier     = 8\\n14:\\tptyFlushInactiveVeryHeavyMultiplier = 12\\n15:\\tptyFlushInactiveMaxIntervalCap      = 250 * time.Millisecond\\n16:\\tptyHeavyLoadTabThreshold            = 4\\n17:\\tptyVeryHeavyLoadTabThreshold        = 8\\n18:\\tptyLoadSampleInterval               = 100 * time.Millisecond\\n19:\\tptyFlushChunkSize                   = 32 * 1024\\n20:\\t// Active tab catch-up should drain backlog quickly to avoid visible replay.\\n21:\\tptyFlushChunkSizeActive = 256 * 1024\\n22:\\t// Catch-up can exceed the steady-state active cap, but it still needs a\\n23:\\t// ceiling so a single actor write cannot monopolize input/scroll handling.\\n24:\\tptyFlushChunkSizeCatchUp = 1024 * 1024\\n25:\\tptyReadBufferSize        = 32 * 1024\\n26:\\tptyReadQueueSize         = 64\\n27:\\tptyFrameInterval         = time.Second / 24\\n28:\\tptyMaxPendingBytes       = 512 * 1024\\n29:\\tptyMaxBufferedBytes      = 8 * 1024 * 1024\\n30:\\tptyReaderStallTimeout    = 10 * time.Second\\n31:\\ttabActorStallTimeout     = 10 * time.Second\\n32:\\tptyRestartMax            = 5\\n33:\\tptyRestartWindow         = time.Minute\\n34:\\n35:\\t// Backpressure thresholds (inspired by tmux's TTY_BLOCK_START/STOP)\\n36:\\t// When pending output exceeds this, we throttle rendering frequency\\n37:\\tptyBackpressureMultiplier = 8 // threshold = multiplier * width * height\\n38:\\tptyBackpressureFlushFloor = 32 * time.Millisecond\\n39:)\\n40:\\n41:// PTYOutput is a message containing PTY output data\\n42:type PTYOutput struct {\\n43:\\tWorkspaceID string\\n44:\\tTabID       TabID\\n45:\\tData        []byte\\n46:}\\n47:\\n48:// PTYTick triggers a PTY read\\n49:type PTYTick struct {\\n50:\\tWorkspaceID string\\n51:\\tTabID       TabID\\n52:}\\n53:\\n54:// PTYFlush applies buffered PTY output for a tab.\\n55:type PTYFlush struct {\\n56:\\tWorkspaceID string\\n57:\\tTabID       TabID\\n58:\\tCatchUp     bool\\n59:}\\n60:\\n61:// PTYCursorRefresh re-renders chat cursor policy when time-based windows expire.\\n62:type PTYCursorRefresh struct {\\n63:\\tWorkspaceID string\\n64:\\tTabID       TabID\\n65:\\tGen         uint64\\n66:}\\n67:\\n68:// PTYStopped signals that the PTY read loop has stopped (terminal closed or error)\\n69:type PTYStopped struct {\\n70:\\tWorkspaceID string\\n71:\\tTabID       TabID\\n72:\\tErr         error\\n73:}\\n74:\\n75:// PTYRestart requests restarting a PTY reader for a tab.\\n76:type PTYRestart struct {\\n77:\\tWorkspaceID string\\n78:\\tTabID       TabID\\n79:}\\n80:\\n81:type selectionScrollTick struct {\\n82:\\tWorkspaceID string\\n83:\\tTabID       TabID\\n84:\\tGen         uint64\\n85:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
