ect           *data.Project\\n 34:\\tdialogWorkspace         *data.Workspace\\n 35:\\tpendingWorkspaceProject *data.Project\\n 36:\\tpendingWorkspaceName    string\\n 37:\\tpendingWorkspaceBase    string\\n 38:\\tpendingTickets          []tickets.Ticket\\n 39:\\tpreviewTicket           *tickets.Ticket\\n 40:\\tpreviewProject          *data.Project\\n 41:\\n 42:\\t// Layout dimensions and visual state (moved from App).\\n 43:\\twidth, height int\\n 44:\\tcanvas        *lipgloss.Canvas // nil initially, lazy-created\\n 45:\\tstyles        common.Styles\\n 46:\\tready         bool\\n 47:\\tquitting      bool\\n 48:\\n 49:\\t// Chrome caches for layer-based rendering (moved from App).\\n 50:\\tdashboardChrome      *compositor.ChromeCache\\n 51:\\tcenterChrome         *compositor.ChromeCache\\n 52:\\tsidebarChrome        *compositor.ChromeCache\\n 53:\\tdashboardContent     drawableCache\\n 54:\\tdashboardBorders     borderCache\\n 55:\\tsidebarTopTabBar     drawableCache\\n 56:\\tsidebarTopContent    drawableCache\\n 57:\\tsidebarBottomContent drawableCache\\n 58:\\tsidebarBottomTabBar  drawableCache\\n 59:\\tsidebarBottomStatus  drawableCache\\n 60:\\tsidebarBottomHelp    drawableCache\\n 61:\\tsidebarTopBorders    borderCache\\n 62:\\tsidebarBottomBorders borderCache\\n 63:\\tcenterTabBar         drawableCache\\n 64:\\tcenterStatus         drawableCache\\n 65:\\tcenterHelp           drawableCache\\n 66:\\tcenterBorders        borderCache\\n 67:\\n 68:\\t// Button focus state for welcome/workspace info screens (moved from App).\\n 69:\\tcenterBtnFocused bool\\n 70:\\tcenterBtnIndex   int\\n 71:\\n 72:\\t// Settings theme dialog state (moved from App).\\n 73:\\tsettingsDialogSession       int\\n 74:\\tsettingsThemePersistedTheme common.ThemeID\\n 75:\\tsettingsThemeDirty          bool\\n 76:}\\n 77:\\n 78:// newUICompositor creates a UICompositor with all non-lazy fields\\n 79:// initialized. Lazy fields (dialog, filePicker, settingsDialog) are\\n 80:// left nil and will be created on first use.\\n 81:func newUICompositor(cfg *config.Config, styles common.Styles) *UICompositor {\\n 82:\\treturn &UICompositor{\\n 83:\\t\\tlayout:          layout.NewManager(),\\n 84:\\t\\tdashboard:       dashboard.New(),\\n 85:\\t\\tcenter:          center.New(cfg),\\n 86:\\t\\tsidebar:         sidebar.NewTabbedSidebar(),\\n 87:\\t\\tsidebarTerminal: sidebar.NewTerminalModel(),\\n 88:\\t\\ttoast:           common.NewToastModel(),\\n 89:\\t\\tstyles:          styles,\\n 90:\\n 91:\\t\\tdashboardChrome: &compositor.ChromeCache{},\\n 92:\\t\\tcenterChrome:    &compositor.ChromeCache{},\\n 93:\\t\\tsidebarChrome:   &compositor.ChromeCache{},\\n 94:\\t}\\n 95:}\\n 96:\\n 97:// canvasFor returns a canvas at the given dimensions, creating or resizing\\n 98:// the cached canvas as needed. The canvas is cleared before returning.\\n 99:func (u *UICompositor) canvasFor(width, height int) *lipgloss.Canvas {\\n100:\\tif width <= 0 || height <= 0 {\\n101:\\t\\twidth = 1\\n102:\\t\\theight = 1\\n103:\\t}\\n104:\\tif u.canvas == nil {\\n105:\\t\\tu.canvas = lipgloss.NewCanvas(width, height)\\n106:\\t} else if u.canvas.Width() != width || u.canvas.Height() != height {\\n107:\\t\\tu.canvas.Resize(width, height)\\n108:\\t}\\n109:\\tu.canvas.Clear()\\n110:\\treturn u.canvas\\n111:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
