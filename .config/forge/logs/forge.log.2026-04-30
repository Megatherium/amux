{"timestamp":" 609.703120344s","level":"DEBUG","fields":{"message":"Adding tool results to context","results":"[ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_00_wERxxVmii3CrfFXfd2qgef5U\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/gt/badmux/polecats/rust/badmux/internal/ui/center/model_actor_ready_test.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"342\\\"\\n><![CDATA[  1:package center\\n  2:\\n  3:import (\\n  4:\\t\\\"context\\\"\\n  5:\\t\\\"sync/atomic\\\"\\n  6:\\t\\\"testing\\\"\\n  7:\\t\\\"time\\\"\\n  8:\\n  9:\\ttea \\\"charm.land/bubbletea/v2\\\"\\n 10:\\n 11:\\t\\\"github.com/andyrewlee/amux/internal/vterm\\\"\\n 12:)\\n 13:\\n 14:func TestIsTabActorReady_FalseWhenHeartbeatStale(t *testing.T) {\\n 15:\\tm := newTestModel()\\n 16:\\tm.setTabActorReady()\\n 17:\\tatomic.StoreInt64(&m.tabActorHeartbeat, time.Now().Add(-(tabActorStallTimeout + time.Second)).UnixNano())\\n 18:\\n 19:\\tif m.isTabActorReady() {\\n 20:\\t\\tt.Fatal(\\\"expected stale actor heartbeat to clear readiness\\\")\\n 21:\\t}\\n 22:\\tif atomic.LoadUint32(&m.tabActorReady) != 0 {\\n 23:\\t\\tt.Fatal(\\\"expected stale readiness flag to be cleared\\\")\\n 24:\\t}\\n 25:}\\n 26:\\n 27:func TestUpdatePTYFlush_StaleActorHeartbeatForcesParserResetFallback(t *testing.T) {\\n 28:\\tm := newTestModel()\\n 29:\\tm.setTabActorReady()\\n 30:\\tatomic.StoreInt64(&m.tabActorHeartbeat, time.Now().Add(-(tabActorStallTimeout + time.Second)).UnixNano())\\n 31:\\n 32:\\tws := newTestWorkspace(\\\"ws\\\", \\\"/repo/ws\\\")\\n 33:\\twsID := string(ws.ID())\\n 34:\\ttab := &Tab{\\n 35:\\t\\tID:                 TabID(\\\"tab-1\\\"),\\n 36:\\t\\tAssistant:          \\\"codex\\\",\\n 37:\\t\\tWorkspace:          ws,\\n 38:\\t\\tTerminal:           vterm.New(80, 24),\\n 39:\\t\\tRunning:            true,\\n 40:\\t\\tpendingOutput:      []byte(\\\"visible\\\"),\\n 41:\\t\\tlastOutputAt:       time.Now().Add(-time.Second),\\n 42:\\t\\tflushPendingSince:  time.Now().Add(-time.Second),\\n 43:\\t\\tparserResetPending: true,\\n 44:\\t\\tactorWritesPending: 1,\\n 45:\\t}\\n 46:\\tm.tabsByWorkspace[wsID] = []*Tab{tab}\\n 47:\\tm.activeTabByWorkspace[wsID] = 0\\n 48:\\tm.workspace = ws\\n 49:\\n 50:\\t_ = m.updatePTYFlush(PTYFlush{WorkspaceID: wsID, TabID: tab.ID})\\n 51:\\n 52:\\tif tab.parserResetPending {\\n 53:\\t\\tt.Fatal(\\\"expected stale actor flush to clear parserResetPending\\\")\\n 54:\\t}\\n 55:\\tif tab.actorWritesPending != 0 {\\n 56:\\t\\tt.Fatalf(\\\"expected stale actor flush to clear actorWritesPending, got %d\\\", tab.actorWritesPending)\\n 57:\\t}\\n 58:\\tif len(tab.pendingOutput) == 0 {\\n 59:\\t\\tt.Fatal(\\\"expected pending output to remain queued for the follow-up flush\\\")\\n 60:\\t}\\n 61:\\tif !tab.flushScheduled {\\n 62:\\t\\tt.Fatal(\\\"expected follow-up flush to be scheduled after stale actor fallback\\\")\\n 63:\\t}\\n 64:}\\n 65:\\n 66:func TestRunTabActor_SetsReadyWithoutEmittingLivenessMsgs(t *testing.T) {\\n 67:\\tm := newTestModel()\\n 68:\\tm.tabEvents = make(chan tabEvent, 1)\\n 69:\\tsinkMsgs := make(chan tea.Msg, 4)\\n 70:\\tm.msgSink = func(msg tea.Msg) {\\n 71:\\t\\tsinkMsgs <- msg\\n 72:\\t}\\n 73:\\n 74:\\tctx, cancel := context.WithCancel(context.Background())\\n 75:\\tdefer cancel()\\n 76:\\n 77:\\tdone := make(chan error, 1)\\n 78:\\tgo func() {\\n 79:\\t\\tdone <- m.RunTabActor(ctx)\\n 80:\\t}()\\n 81:\\n 82:\\tdeadline := time.Now().Add(time.Second)\\n 83:\\tfor !m.isTabActorReady() {\\n 84:\\t\\tif time.Now().After(deadline) {\\n 85:\\t\\t\\tt.Fatal(\\\"expected actor startup to set readiness directly\\\")\\n 86:\\t\\t}\\n 87:\\t\\ttime.Sleep(10 * time.Millisecond)\\n 88:\\t}\\n 89:\\n 90:\\tselect {\\n 91:\\tcase msg := <-sinkMsgs:\\n 92:\\t\\tt.Fatalf(\\\"unexpected liveness message on startup: %T\\\", msg)\\n 93:\\tcase <-time.After(100 * time.Millisecond):\\n 94:\\t}\\n 95:\\n 96:\\tcancel()\\n 97:\\tselect {\\n 98:\\tcase err := <-done:\\n 99:\\t\\tif err != nil {\\n100:\\t\\t\\tt.Fatalf(\\\"RunTabActor() error = %v\\\", err)\\n101:\\t\\t}\\n102:\\tcase <-time.After(time.Second):\\n103:\\t\\tt.Fatal(\\\"timed out waiting for actor to stop\\\")\\n104:\\t}\\n105:}\\n106:\\n107:func TestNoteTabActorHeartbeat_RefreshesReadiness(t *testing.T) {\\n108:\\tm := newTestModel()\\n109:\\tbefore := time.Now()\\n110:\\n111:\\tm.noteTabActorHeartbeat()\\n112:\\n113:\\tif !m.isTabActorReady() {\\n114:\\t\\tt.Fatal(\\\"expected direct heartbeat to refresh actor readiness\\\")\\n115:\\t}\\n116:\\tif got := atomic.LoadUint32(&m.tabActorReady); got != 1 {\\n117:\\t\\tt.Fatalf(\\\"expected ready flag to be set, got %d\\\", got)\\n118:\\t}\\n119:\\tgot := atomic.LoadInt64(&m.tabActorHeartbeat)\\n120:\\tif got < before.UnixNano() {\\n121:\\t\\tt.Fatalf(\\\"expected heartbeat timestamp to be refreshed on receipt, got %d before %d\\\", got, before.UnixNano())\\n122:\\t}\\n123:}\\n124:\\n125:func TestSetTabActorReady_SeedsHeartbeatBeforeReadiness(t *testing.T) {\\n126:\\tm := newTestModel()\\n127:\\n128:\\tm.setTabActorReady()\\n129:\\n130:\\tif got := atomic.LoadUint32(&m.tabActorReady); got != 1 {\\n131:\\t\\tt.Fatalf(\\\"expected ready flag to be set, got %d\\\", got)\\n132:\\t}\\n133:\\tif got := atomic.LoadInt64(&m.tabActorHeartbeat); got == 0 {\\n134:\\t\\tt.Fatal(\\\"expected setTabActorReady to seed heartbeat timestamp\\\")\\n135:\\t}\\n136:\\tif !m.isTabActorReady() {\\n137:\\t\\tt.Fatal(\\\"expected actor to be ready immediately after setTabActorReady\\\")\\n138:\\t}\\n139:}\\n140:\\n141:func TestRunTabActor_EmitsRedrawForActorHandledUIEvent(t *testing.T) {\\n142:\\tm := newTestModel()\\n143:\\tm.tabEvents = make(chan tabEvent, 1)\\n144:\\tsinkMsgs := make(chan tea.Msg, 4)\\n145:\\tm.msgSink = func(msg tea.Msg) {\\n146:\\t\\tsinkMsgs <- msg\\n147:\\t}\\n148:\\n149:\\tctx, cancel := context.WithCancel(context.Background())\\n150:\\tdefer cancel()\\n151:\\n152:\\tdone := make(chan error, 1)\\n153:\\tgo func() {\\n154:\\t\\tdone <- m.RunTabActor(ctx)\\n155:\\t}()\\n156:\\n157:\\tdeadline := time.Now().Add(time.Second)\\n158:\\tfor !m.isTabActorReady() {\\n159:\\t\\tif time.Now().After(deadline) {\\n160:\\t\\t\\tt.Fatal(\\\"expected actor startup to set readiness directly\\\")\\n161:\\t\\t}\\n162:\\t\\ttime.Sleep(10 * time.Millisecond)\\n163:\\t}\\n164:\\n165:\\ttab := &Tab{Terminal: vterm.New(80, 24)}\\n166:\\tm.tabEvents <- tabEvent{kind: tabEventSelectionStart, tab: tab}\\n167:\\tselect {\\n168:\\tcase msg := <-sinkMsgs:\\n169:\\t\\tif _, ok := msg.(tabActorRedraw); !ok {\\n170:\\t\\t\\tt.Fatalf(\\\"expected redraw message, got %T\\\", msg)\\n171:\\t\\t}\\n172:\\tcase <-time.After(100 * time.Millisecond):\\n173:\\t\\tt.Fatal(\\\"expected actor-handled UI event to emit redraw message\\\")\\n174:\\t}\\n175:\\n176:\\tselect {\\n177:\\tcase msg := <-sinkMsgs:\\n178:\\t\\tt.Fatalf(\\\"unexpected extra actor message %T\\\", msg)\\n179:\\tcase <-time.After(50 * time.Millisecond):\\n180:\\t}\\n181:\\n182:\\tcancel()\\n183:\\tselect {\\n184:\\tcase err := <-done:\\n185:\\t\\tif err != nil {\\n186:\\t\\t\\tt.Fatalf(\\\"RunTabActor() error = %v\\\", err)\\n187:\\t\\t}\\n188:\\tcase <-time.After(time.Second):\\n189:\\t\\tt.Fatal(\\\"timed out waiting for actor to stop\\\")\\n190:\\t}\\n191:}\\n192:\\n193:func TestRequestTabActorRedraw_CoalescesOutstandingSignals(t *testing.T) {\\n194:\\tm := newTestModel()\\n195:\\tsinkMsgs := make(chan tea.Msg, 4)\\n196:\\tm.msgSinkTry = func(msg tea.Msg) bool {\\n197:\\t\\tsinkMsgs <- msg\\n198:\\t\\treturn true\\n199:\\t}\\n200:\\tm.msgSink = func(msg tea.Msg) {\\n201:\\t\\t_ = m.msgSinkTry(msg)\\n202:\\t}\\n203:\\n204:\\tm.requestTabActorRedraw()\\n205:\\tm.requestTabActorRedraw()\\n206:\\n207:\\tselect {\\n208:\\tcase msg := <-sinkMsgs:\\n209:\\t\\tif _, ok := msg.(tabActorRedraw); !ok {\\n210:\\t\\t\\tt.Fatalf(\\\"expected redraw message, got %T\\\", msg)\\n211:\\t\\t}\\n212:\\tcase <-time.After(100 * time.Millisecond):\\n213:\\t\\tt.Fatal(\\\"expected coalesced redraw message\\\")\\n214:\\t}\\n215:\\n216:\\tselect {\\n217:\\tcase msg := <-sinkMsgs:\\n218:\\t\\tt.Fatalf(\\\"unexpected extra redraw message %T\\\", msg)\\n219:\\tcase <-time.After(50 * time.Millisecond):\\n220:\\t}\\n221:\\n222:\\t_, _ = m.Update(tabActorRedraw{})\\n223:\\tm.requestTabActorRedraw()\\n224:\\n225:\\tselect {\\n226:\\tcase msg := <-sinkMsgs:\\n227:\\t\\tif _, ok := msg.(tabActorRedraw); !ok {\\n228:\\t\\t\\tt.Fatalf(\\\"expected redraw message after clear, got %T\\\", msg)\\n229:\\t\\t}\\n230:\\tcase <-time.After(100 * time.Millisecond):\\n231:\\t\\tt.Fatal(\\\"expected redraw message after clearing pending flag\\\")\\n232:\\t}\\n233:}\\n234:\\n235:func TestRequestTabActorRedraw_MsgSinkFallbackDoesNotLatchPending(t *testing.T) {\\n236:\\tm := newTestModel()\\n237:\\tsinkMsgs := make(chan tea.Msg, 4)\\n238:\\tm.msgSink = func(msg tea.Msg) {\\n239:\\t\\tsinkMsgs <- msg\\n240:\\t}\\n241:\\n242:\\tm.requestTabActorRedraw()\\n243:\\tm.requestTabActorRedraw()\\n244:\\n245:\\tif got := atomic.LoadUint32(&m.tabActorRedrawPending); got != 0 {\\n246:\\t\\tt.Fatalf(\\\"expected msgSink-only redraw path not to latch pending flag, got %d\\\", got)\\n247:\\t}\\n248:\\n249:\\tfor i := 0; i < 2; i++ {\\n250:\\t\\tselect {\\n251:\\t\\tcase msg := <-sinkMsgs:\\n252:\\t\\t\\tif _, ok := msg.(tabActorRedraw); !ok {\\n253:\\t\\t\\t\\tt.Fatalf(\\\"expected redraw message, got %T\\\", msg)\\n254:\\t\\t\\t}\\n255:\\t\\tcase <-time.After(100 * time.Millisecond):\\n256:\\t\\t\\tt.Fatalf(\\\"expected redraw message %d from msgSink-only fallback\\\", i+1)\\n257:\\t\\t}\\n258:\\t}\\n259:}\\n260:\\n261:func TestRequestTabActorRedraw_DropDoesNotLatchPending(t *testing.T) {\\n262:\\tm := newTestModel()\\n263:\\tattempts := 0\\n264:\\tsinkMsgs := make(chan tea.Msg, 2)\\n265:\\tm.msgSinkTry = func(msg tea.Msg) bool {\\n266:\\t\\tattempts++\\n267:\\t\\tif attempts == 1 {\\n268:\\t\\t\\treturn false\\n269:\\t\\t}\\n270:\\t\\tsinkMsgs <- msg\\n271:\\t\\treturn true\\n272:\\t}\\n273:\\tm.msgSink = func(msg tea.Msg) {\\n274:\\t\\t_ = m.msgSinkTry(msg)\\n275:\\t}\\n276:\\n277:\\tm.requestTabActorRedraw()\\n278:\\tif got := atomic.LoadUint32(&m.tabActorRedrawPending); got != 0 {\\n279:\\t\\tt.Fatalf(\\\"expected dropped redraw not to latch pending flag, got %d\\\", got)\\n280:\\t}\\n281:\\n282:\\tm.requestTabActorRedraw()\\n283:\\tselect {\\n284:\\tcase msg := <-sinkMsgs:\\n285:\\t\\tif _, ok := msg.(tabActorRedraw); !ok {\\n286:\\t\\t\\tt.Fatalf(\\\"expected redraw message after retry, got %T\\\", msg)\\n287:\\t\\t}\\n288:\\tcase <-time.After(100 * time.Millisecond):\\n289:\\t\\tt.Fatal(\\\"expected redraw retry after dropped enqueue\\\")\\n290:\\t}\\n291:}\\n292:\\n293:func TestRunTabActor_EventProcessingRefreshesHeartbeat(t *testing.T) {\\n294:\\tm := newTestModel()\\n295:\\tm.tabEvents = make(chan tabEvent, 1)\\n296:\\n297:\\tctx, cancel := context.WithCancel(context.Background())\\n298:\\tdefer cancel()\\n299:\\n300:\\tdone := make(chan error, 1)\\n301:\\tgo func() {\\n302:\\t\\tdone <- m.RunTabActor(ctx)\\n303:\\t}()\\n304:\\n305:\\tdeadline := time.Now().Add(time.Second)\\n306:\\tfor !m.isTabActorReady() {\\n307:\\t\\tif time.Now().After(deadline) {\\n308:\\t\\t\\tt.Fatal(\\\"expected actor startup to set readiness directly\\\")\\n309:\\t\\t}\\n310:\\t\\ttime.Sleep(10 * time.Millisecond)\\n311:\\t}\\n312:\\n313:\\tstale := time.Now().Add(-(tabActorStallTimeout + time.Second)).UnixNano()\\n314:\\tatomic.StoreInt64(&m.tabActorHeartbeat, stale)\\n315:\\tif m.isTabActorReady() {\\n316:\\t\\tt.Fatal(\\\"expected stale heartbeat to clear readiness before event processing\\\")\\n317:\\t}\\n318:\\n319:\\tm.tabEvents <- tabEvent{kind: tabEventSelectionClear, tab: &Tab{}}\\n320:\\n321:\\tdeadline = time.Now().Add(time.Second)\\n322:\\tfor !m.isTabActorReady() {\\n323:\\t\\tif time.Now().After(deadline) {\\n324:\\t\\t\\tt.Fatal(\\\"expected processed event to refresh actor heartbeat\\\")\\n325:\\t\\t}\\n326:\\t\\ttime.Sleep(10 * time.Millisecond)\\n327:\\t}\\n328:\\n329:\\tif got := atomic.LoadInt64(&m.tabActorHeartbeat); got <= stale {\\n330:\\t\\tt.Fatalf(\\\"expected processed event to advance heartbeat, got %d <= %d\\\", got, stale)\\n331:\\t}\\n332:\\n333:\\tcancel()\\n334:\\tselect {\\n335:\\tcase err := <-done:\\n336:\\t\\tif err != nil {\\n337:\\t\\t\\tt.Fatalf(\\\"RunTabActor() error = %v\\\", err)\\n338:\\t\\t}\\n339:\\tcase <-time.After(time.Second):\\n340:\\t\\tt.Fatal(\\\"timed out waiting for actor to stop\\\")\\n341:\\t}\\n342:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
