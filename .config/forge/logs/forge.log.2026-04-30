og shows the select assistant dialog.\\n    199 |+func (u *UICompositor) ShowSelectAssistantDialog(activeWorkspace *data.Workspace) {\\n    200 |+\\tif activeWorkspace == nil && u.pendingWorkspaceProject == nil {\\n    201 |+\\t\\treturn\\n    202 |+\\t}\\n    203 |+\\tu.dialog = common.NewAgentPicker(u.config.AssistantNames())\\n    204 |+\\tu.dialog.SetSize(u.width, u.height)\\n    205 |+\\tu.dialog.SetShowKeymapHints(u.config.UI.ShowKeymapHints)\\n    206 |+\\tu.dialog.Show()\\n    207 |+}\\n    208 |+\\n    209 |+// ShowSelectTicketDialog returns a command to load tickets and show the ticket picker dialog.\\n    210 |+// If no ticket service is available for the active project, it falls back\\n    211 |+// directly to the assistant picker.\\n    212 |+func (u *UICompositor) ShowSelectTicketDialog(activeWorkspace *data.Workspace, activeProject *data.Project, svc *tickets.TicketService) tea.Cmd {\\n    213 |+\\tif activeWorkspace == nil || activeProject == nil {\\n    214 |+\\t\\treturn nil\\n    215 |+\\t}\\n    216 |+\\tif svc == nil {\\n    217 |+\\t\\treturn func() tea.Msg { return messages.ShowSelectAssistantDialog{} }\\n    218 |+\\t}\\n    219 |+\\treturn func() tea.Msg {\\n    220 |+\\t\\tt, _ := loadOpenAndInProgress(nil, svc, activeProject.Path, 50)\\n    221 |+\\t\\treturn ticketsForPickerLoaded{tickets: t}\\n    222 |+\\t}\\n    223 |+}\\n    224 |+\\n    225 |+// HandleTicketsForPickerLoaded creates and shows the ticket picker with hierarchically sorted tickets.\\n    226 |+func (u *UICompositor) HandleTicketsForPickerLoaded(msg ticketsForPickerLoaded) {\\n    227 |+\\t// Sort tickets hierarchically: parents first, children after their parent\\n    228 |+\\tsorted := sortTicketsHierarchically(msg.tickets)\\n    229 |+\\n    230 |+\\titems := make([]common.TicketPickerItem, 0, len(sorted))\\n    231 |+\\tfor _, t := range sorted {\\n    232 |+\\t\\titems = append(items, common.TicketPickerItem{\\n    233 |+\\t\\t\\tID:        t.ID,\\n    234 |+\\t\\t\\