ux/internal/data\\\"\\n 15:\\t\\\"github.com/andyrewlee/amux/internal/discovery\\\"\\n 16:\\t\\\"github.com/andyrewlee/amux/internal/git\\\"\\n 17:\\t\\\"github.com/andyrewlee/amux/internal/logging\\\"\\n 18:\\t\\\"github.com/andyrewlee/amux/internal/messages\\\"\\n 19:\\t\\\"github.com/andyrewlee/amux/internal/process\\\"\\n 20:\\t\\\"github.com/andyrewlee/amux/internal/supervisor\\\"\\n 21:\\t\\\"github.com/andyrewlee/amux/internal/tickets\\\"\\n 22:\\t\\\"github.com/andyrewlee/amux/internal/tickets/dolt\\\"\\n 23:\\t\\\"github.com/andyrewlee/amux/internal/tmux\\\"\\n 24:\\t\\\"github.com/andyrewlee/amux/internal/ui/common\\\"\\n 25:)\\n 26:\\n 27:// New creates a new App instance.\\n 28:func New(version, commit, date string) (*App, error) {\\n 29:\\tcfg, err := config.DefaultConfig()\\n 30:\\tif err != nil {\\n 31:\\t\\treturn nil, err\\n 32:\\t}\\n 33:\\tapplyTmuxEnvFromConfig(cfg, false)\\n 34:\\ttmuxOpts := tmux.DefaultOptions()\\n 35:\\n 36:\\t// Ensure directories exist\\n 37:\\tif err := cfg.Paths.EnsureDirectories(); err != nil {\\n 38:\\t\\treturn nil, err\\n 39:\\t}\\n 40:\\n 41:\\tregistry := data.NewRegistry(cfg.Paths.RegistryPath)\\n 42:\\tworkspaces := data.NewWorkspaceStore(cfg.Paths.MetadataRoot)\\n 43:\\tscripts := process.NewScriptRunner(cfg.PortStart, cfg.PortRangeSize)\\n 44:\\tworkspaceService := newWorkspaceService(registry, workspaces, scripts, cfg.Paths.WorkspacesRoot)\\n 45:\\n 46:\\tmodelReg, err := discovery.NewRegistry(cfg.Paths.Home)\\n 47:\\tif err != nil {\\n 48:\\t\\tlogging.Warn(\\\"Model discovery registry disabled: %v\\\", err)\\n 49:\\t}\\n 50:\\tticketRenderer := tickets.NewRenderer()\\n 51:\\n 52:\\t// Create status manager (callback will be nil, we use it for caching only)\\n 53:\\tstatusManager := git.NewStatusManager(nil)\\n 54:\\tgitStatus := newGitStatusService(statusManager)\\n 55:\\n 56:\\tvar tmuxSvc TmuxOps = tmuxOps{}\\n 57:\\tupdateSvc := newUpdateService(version, commit, date)\\n 58:\\n 59:\\tctx := context.Background()\\n 60:\\tkmap := buildKeymapFromEnv()\\n 61:\\t// Apply saved theme before creating styles\\n 62:\\tcommon.SetCurrentTheme(common.ThemeID(cfg.UI.Theme))\\n 63:\\tstyles := common.DefaultStyles()\\n 64:\\tapp := &App{\\n 65:\\t\\tconfig:                 cfg,\\n 66:\\t\\tworkspaceService:       workspaceService,\\n 67:\\t\\tgitStatus:              gitStatus,\\n 68:\\t\\ttmuxService:            tmuxSvc,\\n 69:\\t\\tupdateService:          updateSvc,\\n 70:\\t\\tmodelRegistry:          modelReg,\\n 71:\\t\\tticketRenderer:         ticketRenderer,\\n 72:\\t\\tui:                     newUICompositor(cfg, styles),\\n 73:\\t\\tfocusedPane:            messages.PaneDashboard,\\n 74:\\t\\tshowWelcome:            true,\\n 75:\\t\\tkeymap:                 kmap,\\n 76:\\t\\tprefixLabel:            PrefixKeyLabel(),\\n 77:\\t\\tprefixHelpLabel:        PrefixHelpLabel(),\\n 78:\\t\\tversion:                version,\\n 79:\\t\\tcommit:                 commit,\\n 80:\\t\\tbuildDate:              date,\\n 81:\\t\\texternalMsgs:           make(chan tea.Msg, externalMsgBuffer),\\n 82:\\t\\texternalCritical:       make(chan tea.Msg, externalCriticalBuffer),\\n 83:\\t\\tctx:                    ctx,\\n 84:\\t\\ttmuxOptions:            tmuxOpts,\\n 85:\\t\\ttmuxActiveWorkspaceIDs: make(map[string]bool),\\n 86:\\t\\tsessionActivityStates:  make(map[string]*activity.SessionState),\\n 87:\\t\\tworkspaceManager:       newWorkspaceManager(),\\n 88:\\t\\tmaxAttachedAgentTabs:   maxAttachedAgentTabsFromEnv(),\\n 89:\\t}\\n 90:\\tapp.instanceID = newInstanceID()\\n 91:\\tapp.supervisor = supervisor.New(ctx)\\n 92:\\tapp.installSupervisorErrorHandler()\\n 93:\\n 94:\\t// Initialize the git status controller (file + state watchers).\\n 95:\\tapp.gitStatusController = newGitStatusController(\\n 96:\\t\\tcfg.Paths.RegistryPath,\\n 97:\\t\\tcfg.Paths.MetadataRoot,\\n 98:\\t\\tapp.supervisor,\\n 99:\\t\\tGitStatusControllerConfig{\\n100:\\t\\t\\tGitStatusService: app.gitStatus,\\n101:\\t\\t\\tDashboard:        app.ui.dashboard,\\n102:\\t\\t\\tSidebar:          app.ui.sidebar,\\n103:\\t\\t\\tActiveWorkspaceRoot: func() string {\\n104:\\t\\t\\t\\tif app.activeWorkspace != nil {\\n105:\\t\\t\\t\\t\\treturn app.activeWorkspace.Root\\n106:\\t\\t\\t\\t}\\n107:\\t\\t\\t\\treturn \\\"\\\"\\n108:\\t\\t\\t},\\n109:\\t\\t\\tLoadProjects:         func() tea.Cmd { return app.loadProjects() },\\n110:\\t\\t\\tShouldSuppressReload: func(paths []string, now time.Time) bool { return app.shouldSuppressWorkspaceReload(paths, now) },\\n111:\\t\\t\\tSyncDashboard:        func() { app.syncActiveWorkspacesToDashboard() },\\n112:\\t\\t\\tStartTicker:          func() tea.Cmd { return app.startGitStatusTicker() },\\n113:\\t\\t},\\n114:\\t)\\n115:\\t// Route PTY messages through the app-level pump.\\n116:\\tapp.ui.center.SetMsgSinkTry(app.tryEnqueueExternalMsg)\\n117:\\tapp.ui.sidebarTerminal.SetMsgSink(app.enqueueExternalMsg)\\n118:\\tapp.ui.center.SetInstanceID(app.instanceID)\\n119:\\tapp.ui.sidebarTerminal.SetInstanceID(app.instanceID)\\n120:\\t// Propagate styles to all components (they were created with default theme)\\n121:\\tapp.ui.dashboard.SetStyles(styles)\\n122:\\tapp.ui.sidebar.SetStyles(styles)\\n123:\\tapp.ui.sidebarTerminal.SetStyles(styles)\\n124:\\tapp.ui.center.SetStyles(styles)\\n125:\\tapp.ui.toast.SetStyles(styles)\\n126:\\tapp.setKeymapHintsEnabled(cfg.UI.ShowKeymapHints)\\n127:\\t// Propagate prefix key label to components for help bars\\n128:\\tapp.ui.dashboard.SetPrefixHelpLabel(app.prefixHelpLabel)\\n129:\\tapp.ui.center.SetPrefixHelpLabel(app.prefixHelpLabel)\\n130:\\tapp.ui.sidebarTerminal.SetPrefixHelpLabel(app.prefixHelpLabel)\\n131:\\t// Propagate tmux config to components\\n132:\\tapp.ui.center.SetTmuxConfig(tmuxOpts.ServerName, tmuxOpts.ConfigPath)\\n133:\\tapp.ui.sidebarTerminal.SetTmuxConfig(tmuxOpts.ServerName, tmuxOpts.ConfigPath)\\n134:\\tapp.supervisor.Start(\\\"center.tab_actor\\\", app.ui.center.RunTabActor, supervisor.WithRestartPolicy(supervisor.RestartAlways))\\n135:\\tif app.gitStatus != nil {\\n136:\\t\\tapp.supervisor.Start(\\\"git.status_manager\\\", app.gitStatus.Run)\\n137:\\t}\\n138:\\tapp.gitStatusController.startSupervisedTasks()\\n139:\\treturn app, nil\\n140:}\\n141:\\n142:// Init initializes the application.\\n143:func (a *App) Init() tea.Cmd {\\n144:\\tcmds := []tea.Cmd{\\n145:\\t\\ta.loadProjects(),\\n146:\\t\\ta.ui.dashboard.Init(),\\n147:\\t\\ta.ui.center.Init(),\\n148:\\t\\ta.ui.sidebar.Init(),\\n149:\\t\\ta.ui.sidebarTerminal.Init(),\\n150:\\t\\ta.startGitStatusTicker(),\\n151:\\t\\ta.startPTYWatchdog(),\\n152:\\t\\ta.startOrphanGCTicker(),\\n153:\\t\\ta.startTmuxActivityTicker(),\\n154:\\t\\ta.triggerTmuxActivityScan(),\\n155:\\t\\ta.startTmuxSyncTicker(),\\n156:\\t\\ta.checkTmuxAvailable(),\\n157:\\t\\ta.checkForUpdates(),\\n158:\\t\\ta.loadDiscoveryRegistry(),\\n159:\\t}\\n160:\\t// Delegate watcher start commands to the controller.\\n161:\\tcmds = append(cmds, a.gitStatusController.startFileWatcher())\\n162:\\tcmds = append(cmds, a.gitStatusController.startStateWatcher())\\n163:\\tif a.gitStatusController.fileWatcherInitErr() != nil {\\n164:\\t\\tcmds = append(cmds, a.ui.toast.ShowWarning(\\\"File watching disabled; git status may be stale\\\"))\\n165:\\t}\\n166:\\tif a.gitStatusController.stateWatcherInitErr() != nil {\\n167:\\t\\tcmds = append(cmds, a.ui.toast.ShowWarning(\\\"Workspace sync disabled; other instances may be stale\\\"))\\n168:\\t}\\n169:\\treturn common.SafeBatch(cmds...)\\n170:}\\n171:\\n172:// checkForUpdates starts a background check for updates.\\n173:func (a *App) checkForUpdates() tea.Cmd {\\n174:\\treturn func() tea.Msg {\\n175:\\t\\tif a.updateService == nil {\\n176:\\t\\t\\treturn messages.UpdateCheckComplete{}\\n177:\\t\\t}\\n178:\\t\\tresult, err := a.updateService.Check()\\n179:\\t\\tif err != nil {\\n180:\\t\\t\\tlogging.Warn(\\\"Update check failed: %v\\\", err)\\n181:\\t\\t\\treturn messages.UpdateCheckComplete{Err: err}\\n182:\\t\\t}\\n183:\\t\\treturn messages.UpdateCheckComplete{\\n184:\\t\\t\\tCurrentVersion:  result.CurrentVersion,\\n185:\\t\\t\\tLatestVersion:   result.LatestVersion,\\n186:\\t\\t\\tUpdateAvailable: result.UpdateAvailable,\\n187:\\t\\t\\tReleaseNotes:    result.ReleaseNotes,\\n188:\\t\\t\\tErr:             nil,\\n189:\\t\\t}\\n190:\\t}\\n191:}\\n192:\\n193:// tmuxAvailableResult is sent after checking tmux availability.\\n194:type tmuxAvailableResult struct {\\n195:\\tavailable   bool\\n196:\\tinstallHint string\\n197:}\\n198:\\n199:func (a *App) checkTmuxAvailable() tea.Cmd {\\n200:\\treturn func() tea.Msg {\\n201:\\t\\tif a.tmuxService == nil {\\n202:\\t\\t\\treturn tmuxAvailableResult{available: false, installHint: \\\"tmux service unavailable\\\"}\\n203:\\t\\t}\\n204:\\t\\tif err := a.tmuxService.EnsureAvailable(); err != nil {\\n205:\\t\\t\\treturn tmuxAvailableResult{available: false, installHint: a.tmuxService.InstallHint()}\\n206:\\t\\t}\\n207:\\t\\treturn tmuxAvailableResult{available: true}\\n208:\\t}\\n209:}\\n210:\\n211:// startGitStatusTicker returns a command that ticks every 3 seconds for git status refresh.\\n212:func (a *App) startGitStatusTicker() tea.Cmd {\\n213:\\treturn common.SafeTick(gitStatusTickInterval, func(t time.Time) tea.Msg {\\n214:\\t\\treturn messages.GitStatusTick{}\\n215:\\t})\\n216:}\\n217:\\n218:// startOrphanGCTicker returns a command that ticks periodically to clean up orphaned tmux sessions.\\n219:func (a *App) startOrphanGCTicker() tea.Cmd {\\n220:\\treturn common.SafeTick(orphanGCInterval, func(time.Time) tea.Msg {\\n221:\\t\\treturn messages.OrphanGCTick{}\\n222:\\t})\\n223:}\\n224:\\n225:// startPTYWatchdog ticks periodically to ensure PTY readers are running.\\n226:func (a *App) startPTYWatchdog() tea.Cmd {\\n227:\\treturn common.SafeTick(ptyWatchdogInterval, func(time.Time) tea.Msg {\\n228:\\t\\treturn messages.PTYWatchdogTick{}\\n229:\\t})\\n230:}\\n231:\\n232:// startTmuxSyncTicker returns a command that ticks for tmux session reconciliation.\\n233:func (a *App) startTmuxSyncTicker() tea.Cmd {\\n234:\\ta.tmuxSyncToken++\\n235:\\ttoken := a.tmuxSyncToken\\n236:\\treturn common.SafeTick(a.tmuxSyncInterval(), func(time.Time) tea.Msg {\\n237:\\t\\treturn messages.TmuxSyncTick{Token: token}\\n238:\\t})\\n239:}\\n240:\\n241:func (a *App) tmuxSyncInterval() time.Duration {\\n242:\\tvalue := strings.TrimSpace(os.Getenv(\\\"AMUX_TMUX_SYNC_INTERVAL\\\"))\\n243:\\tif value == \\\"\\\" {\\n244:\\t\\treturn tmuxSyncDefaultInterval\\n245:\\t}\\n246:\\tinterval, err := time.ParseDuration(value)\\n247:\\tif err != nil || interval <= 0 {\\n248:\\t\\tlogging.Warn(\\\"Invalid AMUX_TMUX_SYNC_INTERVAL=%q; using %s\\\", value, tmuxSyncDefaultInterval)\\n249:\\t\\treturn tmuxSyncDefaultInterval\\n250:\\t}\\n251:\\treturn interval\\n252:}\\n253:\\n254:func applyTmuxEnvFromConfig(cfg *config.Config, force bool) {\\n255:\\tif cfg == nil {\\n256:\\t\\treturn\\n257:\\t}\\n258:\\tif force {\\n259:\\t\\tsetEnvOrUnset(\\\"AMUX_TMUX_SERVER\\\", cfg.UI.TmuxServer)\\n260:\\t\\tsetEnvOrUnset(\\\"AMUX_TMUX_CONFIG\\\", cfg.UI.TmuxConfigPath)\\n261:\\t\\tsetEnvOrUnset(\\\"AMUX_TMUX_SYNC_INTERVAL\\\", cfg.UI.TmuxSyncInterval)\\n262:\\t\\treturn\\n263:\\t}\\n264:\\tsetEnvIfNonEmpty(\\\"AMUX_TMUX_SERVER\\\", cfg.UI.TmuxServer)\\n265:\\tsetEnvIfNonEmpty(\\\"AMUX_TMUX_CONFIG\\\", cfg.UI.TmuxConfigPath)\\n266:\\tsetEnvIfNonEmpty(\\\"AMUX_TMUX_SYNC_INTERVAL\\\", cfg.UI.TmuxSyncInterval)\\n267:}\\n268:\\n269:// ticketStoreResult is sent when a per-project ticket store initialization completes.\\n270:type ticketStoreResult struct {\\n271:\\tprojectPath string\\n272:\\tstore       *dolt.ServerStore\\n273:\\tservice     *tickets.TicketService\\n274:\\terr         error\\n275:}\\n276:\\n277:// loadDiscoveryRegistry loads the models.dev cache asynchronously.\\n278:// On success it returns a DiscoveryLoadedMsg; on failure it logs a warning\\n279:// and returns nil (discovery features remain disabled).\\n280:func (a *App) loadDiscoveryRegistry() tea.Cmd {\\n281:\\tif a.modelRegistry == nil {\\n282:\\t\\treturn nil\\n283:\\t}\\n284:\\treturn func() tea.Msg {\\n285:\\t\\tif err := a.modelRegistry.Load(context.Background()); err != nil {\\n286:\\t\\t\\tlogging.Warn(\\\"Model discovery cache load failed: %v\\\", err)\\n287:\\t\\t\\treturn nil\\n288:\\t\\t}\\n289:\\t\\treturn messages.DiscoveryLoadedMsg{}\\n290:\\t}\\n291:}\\n292:\\n293:// initTicketStore attempts to connect to a beads Dolt database at beadsDir.\\n294:// If the connection fails, the per-project entry remains nil and ticket\\n295:// features are disabled for that project.\\n296:func (a *App) initTicketStore(projectPath, beadsDir string) tea.Cmd {\\n297:\\treturn func() tea.Msg {\\n298:\\t\\tstore, err := dolt.NewStore(context.Background(), beadsDir, false)\\n299:\\t\\tif err != nil {\\n300:\\t\\t\\tlogging.Debug(\\\"Ticket store not available for %s: %v\\\", projectPath, err)\\n301:\\t\\t\\treturn ticketStoreResult{projectPath: projectPath, err: err}\\n302:\\t\\t}\\n303:\\n304:\\t\\tvar svc *tickets.TicketService\\n305:\\t\\tif a.modelRegistry != nil && a.ticketRenderer != nil {\\n306:\\t\\t\\tsvc = tickets.NewTicketService(store, a.modelRegistry, a.ticketRenderer)\\n307:\\t\\t}\\n308:\\n309:\\t\\treturn ticketStoreResult{\\n310:\\t\\t\\tprojectPath: projectPath,\\n311:\\t\\t\\tstore:       store,\\n312:\\t\\t\\tservice:     svc,\\n313:\\t\\t}\\n314:\\t}\\n315:}\\n316:\\n317:// handleDiscoveryLoaded processes the discovery registry loaded message.\\n318:// Once discovery is ready, attempt to init ticket stores for any projects\\n319:// that have already been loaded.\\n320:func (a *App) handleDiscoveryLoaded(_ messages.DiscoveryLoadedMsg) []tea.Cmd {\\n321:\\tlogging.Debug(\\\"Model discovery registry loaded\\\")\\n322:\\ta.discoveryReady = true\\n323:\\treturn a.initTicketStoresForLoadedProjects()\\n324:}\\n325:\\n326:// initTicketStoresForLoadedProjects scans loaded projects for .beads/\\n327:// directories and returns init cmds for each. This is called both when\\n328:// discovery finishes (projects may already be loaded) and when projects\\n329:// load (discovery may already be finished).\\n330:func (a *App) initTicketStoresForLoadedProjects() []tea.Cmd {\\n331:\\tif !a.discoveryReady || !a.projectsLoaded {\\n332:\\t\\treturn nil\\n333:\\t}\\n334:\\tvar cmds []tea.Cmd\\n335:\\tfor i := range a.projects {\\n336:\\t\\tp := &a.projects[i]\\n337:\\t\\tbeadsDir := filepath.Join(p.Path, \\\".beads\\\")\\n338:\\t\\tif _, err := os.Stat(beadsDir); err != nil {\\n339:\\t\\t\\tcontinue\\n340:\\t\\t}\\n341:\\t\\tif _, exists := a.doltStores[p.Path]; exists {\\n342:\\t\\t\\tcontinue\\n343:\\t\\t}\\n344:\\t\\tcmds = append(cmds, a.initTicketStore(p.Path, beadsDir))\\n345:\\t}\\n346:\\treturn cmds\\n347:}\\n348:\\n349:// handleTicketStoreResult processes the async ticket store initialization result.\\n350:func (a *App) handleTicketStoreResult(msg ticketStoreResult) []tea.Cmd {\\n351:\\tif msg.err != nil {\\n352:\\t\\tlogging.Debug(\\\"Ticket service disabled for %s: %v\\\", msg.projectPath, msg.err)\\n353:\\t\\treturn nil\\n354:\\t}\\n355:\\tif a.doltStores == nil {\\n356:\\t\\ta.doltStores = make(map[string]*dolt.ServerStore)\\n357:\\t}\\n358:\\tif a.ticketServices == nil {\\n359:\\t\\ta.ticketServices = make(map[string]*tickets.TicketService)\\n360:\\t}\\n361:\\ta.doltStores[msg.projectPath] = msg.store\\n362:\\ta.ticketServices[msg.projectPath] = msg.service\\n363:\\tlogging.Debug(\\\"Ticket service initialized for %s (service=%v)\\\", msg.projectPath, msg.service != nil)\\n364:\\tvar cmds []tea.Cmd\\n365:\\tif msg.service != nil {\\n366:\\t\\tcmds = append(cmds, a.loadTicketsForProject(msg.projectPath))\\n367:\\t\\t// Ensure the background poller is running and aware of this service.\\n368:\\t\\ta.ensureTicketPoller(msg.projectPath, msg.service)\\n369:\\t}\\n370:\\treturn cmds\\n371:}\\n372:\\n373:// ensureTicketPoller lazily creates the ticket poller on first use and starts\\n374:// it as a supervisor worker. Subsequent calls add the new service to the\\n375:// existing poller.\\n376:func (a *App) ensureTicketPoller(projectPath string, svc *tickets.TicketService) {\\n377:\\tif a.supervisor == nil || svc == nil {\\n378:\\t\\treturn\\n379:\\t}\\n380:\\tif a.ticketPoller == nil {\\n381:\\t\\ta.ticketPoller = newTicketPoller(a.enqueueExternalMsg, ticketPollInterval)\\n382:\\t\\ta.supervisor.Start(\\n383:\\t\\t\\t\\\"app.ticket_poller\\\",\\n384:\\t\\t\\ta.ticketPoller.run,\\n385:\\t\\t\\tsupervisor.WithRestartPolicy(supervisor.RestartAlways),\\n386:\\t\\t\\tsupervisor.WithBackoff(supervisorBackoff),\\n387:\\t\\t)\\n388:\\t}\\n389:\\ta.ticketPoller.addService(projectPath, svc)\\n390:}\\n391:\\n392:// loadTicketsForProject loads open tickets for a project and sends TicketsLoadedMsg.\\n393:func (a *App) loadTicketsForProject(path string) tea.Cmd {\\n394:\\tsvc := a.ticketServices[path]\\n395:\\tif svc == nil {\\n396:\\t\\treturn nil\\n397:\\t}\\n398:\\treturn func() tea.Msg {\\n399:\\t\\tt, _ := loadOpenAndInProgress(context.Background(), svc, path, 20)\\n400:\\t\\treturn messages.TicketsLoadedMsg{\\n401:\\t\\t\\tProjectPath: path,\\n402:\\t\\t\\tTickets:     t,\\n403:\\t\\t}\\n404:\\t}\\n405:}\\n406:\\n407:// loadOpenAndInProgress fetches open and in_progress tickets from a TicketService.\\n408:// It returns an error if either query fails, ensuring callers never receive partial\\n409:// results without being aware of the failure.\\n410:func loadOpenAndInProgress(ctx context.Context, svc *tickets.TicketService, path string, limit int) ([]tickets.Ticket, error) {\\n411:\\tt, err := svc.ListTickets(ctx, tickets.TicketFilter{\\n412:\\t\\tStatus: \\\"open\\\",\\n413:\\t\\tLimit:  limit,\\n414:\\t})\\n415:\\tif err != nil {\\n416:\\t\\tlogging.Debug(\\\"Ticket load failed for %s (open): %v\\\", path, err)\\n417:\\t\\treturn nil, err\\n418:\\t}\\n419:\\tinProgress, err := svc.ListTickets(ctx, tickets.TicketFilter{\\n420:\\t\\tStatus: \\\"in_progress\\\",\\n421:\\t\\tLimit:  limit,\\n422:\\t})\\n423:\\tif err != nil {\\n424:\\t\\tlogging.Debug(\\\"Ticket load failed for %s (in_progress): %v\\\", path, err)\\n425:\\t\\treturn nil, err\\n426:\\t}\\n427:\\treturn append(t, inProgress...), nil\\n428:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
