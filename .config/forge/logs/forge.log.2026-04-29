{"timestamp":" 112.617681830s","level":"DEBUG","fields":{"message":"Adding tool results to context","results":"[ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_00_KNUAbkXFgL7H9lLmQ6xzTqI2\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/gt/badmux/polecats/quartz/badmux/internal/app/app_input_messages_workspace.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"264\\\"\\n><![CDATA[  1:package app\\n  2:\\n  3:import (\\n  4:\\t\\\"errors\\\"\\n  5:\\t\\\"fmt\\\"\\n  6:\\t\\\"path/filepath\\\"\\n  7:\\t\\\"strings\\\"\\n  8:\\n  9:\\ttea \\\"charm.land/bubbletea/v2\\\"\\n 10:\\n 11:\\t\\\"github.com/andyrewlee/amux/internal/data\\\"\\n 12:\\t\\\"github.com/andyrewlee/amux/internal/messages\\\"\\n 13:\\t\\\"github.com/andyrewlee/amux/internal/validation\\\"\\n 14:)\\n 15:\\n 16:// handleProjectsLoaded processes the ProjectsLoaded message.\\n 17:func (a *App) handleProjectsLoaded(msg messages.ProjectsLoaded) []tea.Cmd {\\n 18:\\ta.projects = msg.Projects\\n 19:\\ta.projectsLoaded = true\\n 20:\\tvar cmds []tea.Cmd\\n 21:\\tif a.ui.dashboard != nil {\\n 22:\\t\\ta.ui.dashboard.SetProjects(a.projects)\\n 23:\\t}\\n 24:\\tcmds = append(cmds, a.rebindActiveSelection()...)\\n 25:\\t// Request git status for all workspaces\\n 26:\\tcmds = append(cmds, a.scanTmuxActivityNow())\\n 27:\\tif gcCmd := a.gcOrphanedTmuxSessions(); gcCmd != nil {\\n 28:\\t\\tcmds = append(cmds, gcCmd)\\n 29:\\t}\\n 30:\\tif countCmd := a.logSessionCount(); countCmd != nil {\\n 31:\\t\\tcmds = append(cmds, countCmd)\\n 32:\\t}\\n 33:\\tfor i := range a.projects {\\n 34:\\t\\tfor j := range a.projects[i].Workspaces {\\n 35:\\t\\t\\tws := &a.projects[i].Workspaces[j]\\n 36:\\t\\t\\tcmds = append(cmds, a.gitStatusController.requestGitStatus(ws.Root))\\n 37:\\t\\t}\\n 38:\\t}\\n 39:\\tcmds = append(cmds, a.initTicketStoresForLoadedProjects()...)\\n 40:\\treturn cmds\\n 41:}\\n 42:\\n 43:func (a *App) rebindActiveSelection() []tea.Cmd {\\n 44:\\tvar cmds []tea.Cmd\\n 45:\\tif a.activeWorkspace != nil {\\n 46:\\t\\tprevious := a.activeWorkspace\\n 47:\\t\\twsID := string(a.activeWorkspace.ID())\\n 48:\\t\\tws, project := a.findWorkspaceAndProjectByID(wsID)\\n 49:\\t\\tif ws == nil {\\n 50:\\t\\t\\tws, project = a.findWorkspaceAndProjectByCanonicalPaths(previous.Repo, previous.Root)\\n 51:\\t\\t}\\n 52:\\t\\tif ws == nil {\\n 53:\\t\\t\\ta.goHome()\\n 54:\\t\\t\\ta.activeProject = nil\\n 55:\\t\\t\\treturn cmds\\n 56:\\t\\t}\\n 57:\\t\\toldID := string(previous.ID())\\n 58:\\t\\tnewID := string(ws.ID())\\n 59:\\t\\thadPreviousWorkspaceState := false\\n 60:\\t\\tif a.ui.center != nil {\\n 61:\\t\\t\\thadPreviousWorkspaceState = a.ui.center.HasWorkspaceState(oldID)\\n 62:\\t\\t}\\n 63:\\t\\tif oldID != newID {\\n 64:\\t\\t\\ta.migrateDirtyWorkspaceID(oldID, newID)\\n 65:\\t\\t\\tcmds = append(cmds, a.rebindActiveWorkspaceWatch(previous.Root, ws.Root)...)\\n 66:\\t\\t\\tif a.ui.center != nil {\\n 67:\\t\\t\\t\\tif cmd := a.ui.center.RebindWorkspaceID(previous, ws); cmd != nil {\\n 68:\\t\\t\\t\\t\\tcmds = append(cmds, cmd)\\n 69:\\t\\t\\t\\t}\\n 70:\\t\\t\\t}\\n 71:\\t\\t\\tif a.ui.sidebarTerminal != nil {\\n 72:\\t\\t\\t\\tif cmd := a.ui.sidebarTerminal.RebindWorkspaceID(previous, ws); cmd != nil {\\n 73:\\t\\t\\t\\t\\tcmds = append(cmds, cmd)\\n 74:\\t\\t\\t\\t}\\n 75:\\t\\t\\t}\\n 76:\\t\\t}\\n 77:\\t\\ta.activeWorkspace = ws\\n 78:\\t\\ta.activeProject = project\\n 79:\\t\\tif a.ui.center != nil {\\n 80:\\t\\t\\ta.ui.center.SetWorkspace(ws)\\n 81:\\t\\t\\twsIDCurrent := string(ws.ID())\\n 82:\\t\\t\\thasWorkspaceState := a.ui.center.HasWorkspaceState(wsIDCurrent)\\n 83:\\t\\t\\texistingTabs, _ := a.ui.center.GetTabsInfoForWorkspace(wsIDCurrent)\\n 84:\\t\\t\\thasLiveWorkspaceTabs := len(existingTabs) > 0\\n 85:\\t\\t\\tshouldHydrateTabs := !hasWorkspaceState || hasLiveWorkspaceTabs\\n 86:\\t\\t\\tif shouldHydrateTabs && oldID != newID && hadPreviousWorkspaceState {\\n 87:\\t\\t\\t\\tshouldHydrateTabs = false\\n 88:\\t\\t\\t}\\n 89:\\t\\t\\tif shouldHydrateTabs && a.wm().isWorkspaceDirty(wsIDCurrent) {\\n 90:\\t\\t\\t\\tshouldHydrateTabs = false\\n 91:\\t\\t\\t}\\n 92:\\t\\t\\tif shouldHydrateTabs {\\n 93:\\t\\t\\t\\tif cmd := a.ui.center.AddTabsFromWorkspace(ws, ws.OpenTabs); cmd != nil {\\n 94:\\t\\t\\t\\t\\tcmds = append(cmds, cmd)\\n 95:\\t\\t\\t\\t}\\n 96:\\t\\t\\t}\\n 97:\\t\\t}\\n 98:\\t\\tif a.ui.sidebar != nil {\\n 99:\\t\\t\\ta.ui.sidebar.SetWorkspace(ws)\\n100:\\t\\t}\\n101:\\t\\tif a.ui.sidebarTerminal != nil {\\n102:\\t\\t\\ta.ui.sidebarTerminal.SetWorkspacePreview(ws)\\n103:\\t\\t}\\n104:\\t\\treturn cmds\\n105:\\t}\\n106:\\tif a.activeProject != nil {\\n107:\\t\\ta.activeProject = a.findProjectByPath(a.activeProject.Path)\\n108:\\t}\\n109:\\treturn cmds\\n110:}\\n111:\\n112:func (a *App) rebindActiveWorkspaceWatch(previousRoot, currentRoot string) []tea.Cmd {\\n113:\\tvar cmds []tea.Cmd\\n114:\\toldRoot := strings.TrimSpace(previousRoot)\\n115:\\tnewRoot := strings.TrimSpace(currentRoot)\\n116:\\tif oldRoot == \\\"\\\" || newRoot == \\\"\\\" || oldRoot == newRoot {\\n117:\\t\\treturn cmds\\n118:\\t}\\n119:\\n120:\\tif a.gitStatusController != nil {\\n121:\\t\\ta.gitStatusController.unwatchRoot(oldRoot)\\n122:\\t\\tif err := a.gitStatusController.watchRoot(newRoot); err != nil {\\n123:\\t\\t\\tif a.gitStatusController.isWatchLimitReached() {\\n124:\\t\\t\\t\\tif a.ui.toast != nil {\\n125:\\t\\t\\t\\t\\tcmds = append(cmds, a.ui.toast.ShowWarning(\\\"File watching disabled (watch limit reached); git status may be stale\\\"))\\n126:\\t\\t\\t\\t}\\n127:\\t\\t\\t}\\n128:\\t\\t}\\n129:\\t}\\n130:\\n131:\\tif a.gitStatus != nil {\\n132:\\t\\ta.gitStatus.Invalidate(oldRoot)\\n133:\\t\\ta.gitStatus.Invalidate(newRoot)\\n134:\\t}\\n135:\\tif a.ui.dashboard != nil {\\n136:\\t\\ta.ui.dashboard.InvalidateStatus(oldRoot)\\n137:\\t\\ta.ui.dashboard.InvalidateStatus(newRoot)\\n138:\\t}\\n139:\\n140:\\treturn cmds\\n141:}\\n142:\\n143:func rootsReferToSameWorkspace(left, right string) bool {\\n144:\\tleftTrimmed := strings.TrimSpace(left)\\n145:\\trightTrimmed := strings.TrimSpace(right)\\n146:\\tif leftTrimmed == \\\"\\\" || rightTrimmed == \\\"\\\" {\\n147:\\t\\treturn false\\n148:\\t}\\n149:\\tif leftTrimmed == rightTrimmed {\\n150:\\t\\treturn true\\n151:\\t}\\n152:\\treturn canonicalPathForMatch(leftTrimmed) == canonicalPathForMatch(rightTrimmed)\\n153:}\\n154:\\n155:func (a *App) findWorkspaceAndProjectByID(id string) (*data.Workspace, *data.Project) {\\n156:\\tif id == \\\"\\\" {\\n157:\\t\\treturn nil, nil\\n158:\\t}\\n159:\\tfor i := range a.projects {\\n160:\\t\\tproject := &a.projects[i]\\n161:\\t\\tfor j := range project.Workspaces {\\n162:\\t\\t\\tws := &project.Workspaces[j]\\n163:\\t\\t\\tif string(ws.ID()) == id {\\n164:\\t\\t\\t\\treturn ws, project\\n165:\\t\\t\\t}\\n166:\\t\\t}\\n167:\\t}\\n168:\\treturn nil, nil\\n169:}\\n170:\\n171:func (a *App) findWorkspaceAndProjectByCanonicalPaths(repoPath, rootPath string) (*data.Workspace, *data.Project) {\\n172:\\ttargetRepo := canonicalPathForMatch(repoPath)\\n173:\\ttargetRoot := canonicalPathForMatch(rootPath)\\n174:\\tif targetRepo == \\\"\\\" && targetRoot == \\\"\\\" {\\n175:\\t\\treturn nil, nil\\n176:\\t}\\n177:\\tfor i := range a.projects {\\n178:\\t\\tproject := &a.projects[i]\\n179:\\t\\tfor j := range project.Workspaces {\\n180:\\t\\t\\tws := &project.Workspaces[j]\\n181:\\t\\t\\trepoCanonical := canonicalPathForMatch(ws.Repo)\\n182:\\t\\t\\trootCanonical := canonicalPathForMatch(ws.Root)\\n183:\\t\\t\\tif targetRoot != \\\"\\\" && rootCanonical != targetRoot {\\n184:\\t\\t\\t\\tcontinue\\n185:\\t\\t\\t}\\n186:\\t\\t\\tif targetRepo != \\\"\\\" && repoCanonical != targetRepo {\\n187:\\t\\t\\t\\tcontinue\\n188:\\t\\t\\t}\\n189:\\t\\t\\tif targetRoot == \\\"\\\" && targetRepo != \\\"\\\" && repoCanonical != targetRepo {\\n190:\\t\\t\\t\\tcontinue\\n191:\\t\\t\\t}\\n192:\\t\\t\\treturn ws, project\\n193:\\t\\t}\\n194:\\t}\\n195:\\treturn nil, nil\\n196:}\\n197:\\n198:func (a *App) findProjectByPath(path string) *data.Project {\\n199:\\tif path == \\\"\\\" {\\n200:\\t\\treturn nil\\n201:\\t}\\n202:\\ttargetCanonical := canonicalProjectPathForMatch(path)\\n203:\\tfor i := range a.projects {\\n204:\\t\\tproject := &a.projects[i]\\n205:\\t\\tif project.Path == path {\\n206:\\t\\t\\treturn project\\n207:\\t\\t}\\n208:\\t\\tif targetCanonical == \\\"\\\" {\\n209:\\t\\t\\tcontinue\\n210:\\t\\t}\\n211:\\t\\tif canonicalProjectPathForMatch(project.Path) == targetCanonical {\\n212:\\t\\t\\treturn project\\n213:\\t\\t}\\n214:\\t}\\n215:\\treturn nil\\n216:}\\n217:\\n218:func canonicalProjectPathForMatch(path string) string {\\n219:\\treturn canonicalPathForMatch(path)\\n220:}\\n221:\\n222:func canonicalPathForMatch(path string) string {\\n223:\\tvalue := strings.TrimSpace(path)\\n224:\\tif value == \\\"\\\" {\\n225:\\t\\treturn \\\"\\\"\\n226:\\t}\\n227:\\tcleaned := filepath.Clean(value)\\n228:\\tif abs, err := filepath.Abs(cleaned); err == nil {\\n229:\\t\\tcleaned = abs\\n230:\\t}\\n231:\\tif resolved, err := filepath.EvalSymlinks(cleaned); err == nil {\\n232:\\t\\tcleaned = resolved\\n233:\\t}\\n234:\\treturn filepath.Clean(cleaned)\\n235:}\\n236:\\n237:// handleWorkspaceActivated processes the WorkspaceActivated message.\\n238:func (a *App) handleWorkspaceActivated(msg messages.WorkspaceActivated) []tea.Cmd {\\n239:\\tvar cmds []tea.Cmd\\n240:\\ta.setWorkspaceActivationState(msg)\\n241:\\tcmds = append(cmds, a.discoverWorkspaceTmux(msg.Workspace)...)\\n242:\\tcenterFocusQueuedReattach := a.routeFocusOnActivation(msg, &cmds)\\n243:\\t// Sync active workspaces to dashboard (fixes spinner race condition)\\n244:\\ta.syncActiveWorkspacesToDashboard()\\n245:\\tnewDashboard, cmd := a.ui.dashboard.Update(msg)\\n246:\\ta.ui.dashboard = newDashboard\\n247:\\tcmds = append(cmds, cmd)\\n248:\\tcmds = append(cmds, a.refreshWorkspaceResources(msg.Workspace)...)\\n249:\\t// Ensure spinner starts if needed after sync\\n250:\\tif startCmd := a.ui.dashboard.StartSpinnerIfNeeded(); startCmd != nil {\\n251:\\t\\tcmds = append(cmds, startCmd)\\n252:\\t}\\n253:\\t// Seamless UX: if restored active tab is detached, auto-reattach on workspace activation.\\n254:\\tif !centerFocusQueuedReattach {\\n255:\\t\\tcmds = append(cmds, a.ui.center.ReattachActiveTabIfDetached())\\n256:\\t}\\n257:\\tcmds = append(cmds, a.enforceAttachedAgentTabLimit()...)\\n258:\\treturn cmds\\n259:}\\n260:\\n261:// handleCreateWorkspace handles the CreateWorkspace message.\\n262:func (a *App) handleCreateWorkspace(msg messages.CreateWorkspace) []tea.Cmd {\\n263:\\treturn a.wm().HandleCreateWorkspace(msg)\\n264:}]]>\\n</file>\")] } }, ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_01_k1h9oTyDYhG5k5GOcmbB8vHV\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/gt/badmux/polecats/quartz/badmux/internal/app/app_persistence.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"79\\\"\\n><![CDATA[ 1:package app\\n 2:\\n 3:import (\\n 4:\\t\\\"time\\\"\\n 5:\\n 6:\\ttea \\\"charm.land/bubbletea/v2\\\"\\n 7:\\n 8:\\t\\\"github.com/andyrewlee/amux/internal/data\\\"\\n 9:\\t\\\"github.com/andyrewlee/amux/internal/logging\\\"\\n10:\\t\\\"github.com/andyrewlee/amux/internal/ui/common\\\"\\n11:)\\n12:\\n13:// persistAllWorkspacesNow saves all workspace tab state synchronously.\\n14:// Called before shutdown to ensure tabs are persisted before they are closed.\\n15:// This intentionally includes delete-in-flight workspaces. If a delete fails or\\n16:// races with shutdown, preserving UI tab state is preferred over dropping it.\\n17:func (a *App) persistAllWorkspacesNow() {\\n18:\\tif a.workspaceService == nil || a.ui.center == nil {\\n19:\\t\\treturn\\n20:\\t}\\n21:\\twm := a.wm()\\n22:\\tfor _, project := range a.projects {\\n23:\\t\\tfor i := range project.Workspaces {\\n24:\\t\\t\\tws := &project.Workspaces[i]\\n25:\\t\\t\\twsID := string(ws.ID())\\n26:\\t\\t\\ttabs, activeIdx := a.ui.center.GetTabsInfoForWorkspace(wsID)\\n27:\\t\\t\\tif len(tabs) == 0 && !a.ui.center.HasWorkspaceState(wsID) {\\n28:\\t\\t\\t\\tcontinue\\n29:\\t\\t\\t}\\n30:\\t\\t\\tws.OpenTabs = tabs\\n31:\\t\\t\\tws.ActiveTabIndex = activeIdx\\n32:\\t\\t\\tsnap := snapshotWorkspaceForSave(ws)\\n33:\\t\\t\\tif err := a.workspaceService.Save(snap); err != nil {\\n34:\\t\\t\\t\\tlogging.Warn(\\\"Failed to persist workspace on shutdown: %v\\\", err)\\n35:\\t\\t\\t} else {\\n36:\\t\\t\\t\\ta.markLocalWorkspaceSaveForID(string(snap.ID()))\\n37:\\t\\t\\t}\\n38:\\t\\t}\\n39:\\t}\\n40:\\t// Clear dirty set since we just saved everything\\n41:\\twm.clearAllDirty()\\n42:}\\n43:\\n44:// persistDebounceMsg is sent after the debounce period to trigger actual save.\\n45:type persistDebounceMsg struct {\\n46:\\ttoken int\\n47:}\\n48:\\n49:// persistWorkspaceTabs marks a workspace dirty and schedules a debounced save.\\n50:func (a *App) persistWorkspaceTabs(wsID string) tea.Cmd {\\n51:\\tif wsID == \\\"\\\" {\\n52:\\t\\treturn nil\\n53:\\t}\\n54:\\twm := a.wm()\\n55:\\tif wm.isWorkspaceDeleteInFlight(wsID) {\\n56:\\t\\treturn nil\\n57:\\t}\\n58:\\twm.markWorkspaceDirty(wsID)\\n59:\\ttoken := wm.nextPersistToken()\\n60:\\treturn common.SafeTick(persistDebounce, func(t time.Time) tea.Msg {\\n61:\\t\\treturn persistDebounceMsg{token: token}\\n62:\\t})\\n63:}\\n64:\\n65:func (a *App) migrateDirtyWorkspaceID(oldID, newID string) {\\n66:\\ta.wm().migrateDirtyWorkspaceID(oldID, newID)\\n67:}\\n68:\\n69:// persistActiveWorkspaceTabs is a convenience that persists the active workspace's tabs.\\n70:func (a *App) persistActiveWorkspaceTabs() tea.Cmd {\\n71:\\tif a.activeWorkspace == nil {\\n72:\\t\\treturn nil\\n73:\\t}\\n74:\\treturn a.persistWorkspaceTabs(string(a.activeWorkspace.ID()))\\n75:}\\n76:\\n77:func (a *App) handlePersistDebounce(msg persistDebounceMsg) tea.Cmd {\\n78:\\treturn a.wm().HandlePersistDebounce(msg)\\n79:}]]>\\n</file>\")] } }, ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_02_tAGhvEaUcbP2zO7s3as1Lmq7\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/gt/badmux/polecats/quartz/badmux/internal/app/app_input.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"387\\\"\\n><![CDATA[  1:package app\\n  2:\\n  3:import (\\n  4:\\t\\\"fmt\\\"\\n  5:\\t\\\"runtime/debug\\\"\\n  6:\\n  7:\\ttea \\\"charm.land/bubbletea/v2\\\"\\n  8:\\n  9:\\t\\\"github.com/andyrewlee/amux/internal/logging\\\"\\n 10:\\t\\\"github.com/andyrewlee/amux/internal/messages\\\"\\n 11:\\t\\\"github.com/andyrewlee/amux/internal/perf\\\"\\n 12:\\t\\\"github.com/andyrewlee/amux/internal/ui/center\\\"\\n 13:\\t\\\"github.com/andyrewlee/amux/internal/ui/common\\\"\\n 14:\\t\\\"github.com/andyrewlee/amux/internal/ui/dashboard\\\"\\n 15:\\t\\\"github.com/andyrewlee/amux/internal/ui/sidebar\\\"\\n 16:)\\n 17:\\n 18:// Update handles all messages with panic recovery.\\n 19:func (a *App) Update(msg tea.Msg) (model tea.Model, cmd tea.Cmd) {\\n 20:\\tdefer func() {\\n 21:\\t\\tif r := recover(); r != nil {\\n 22:\\t\\t\\tlogging.Error(\\\"panic in app.Update: %v\\\\n%s\\\", r, debug.Stack())\\n 23:\\t\\t\\ta.err = fmt.Errorf(\\\"internal error: %v\\\", r)\\n 24:\\t\\t\\tmodel = a\\n 25:\\t\\t\\tcmd = nil\\n 26:\\t\\t}\\n 27:\\t}()\\n 28:\\treturn a.update(msg)\\n 29:}\\n 30:\\n 31:func (a *App) update(msg tea.Msg) (tea.Model, tea.Cmd) {\\n 32:\\tdefer perf.Time(\\\"update\\\")()\\n 33:\\tvar cmds []tea.Cmd\\n 34:\\t// Keep focus flags synchronized in Update (not View) so rendering remains\\n 35:\\t// side-effect free while still enforcing single-pane cursor ownership.\\n 36:\\ta.syncPaneFocusFlags()\\n 37:\\n 38:\\tif perf.Enabled() {\\n 39:\\t\\tswitch msg.(type) {\\n 40:\\t\\tcase tea.KeyPressMsg, tea.KeyReleaseMsg, tea.MouseClickMsg, tea.MouseWheelMsg, tea.MouseMotionMsg, tea.MouseReleaseMsg, tea.PasteMsg:\\n 41:\\t\\t\\ta.markInput()\\n 42:\\t\\t}\\n 43:\\t}\\n 44:\\n 45:\\tif handled, cmd := a.handleDialogResultMsg(msg); handled {\\n 46:\\t\\treturn a, cmd\\n 47:\\t}\\n 48:\\tif a.handleErrorOverlayDismiss(msg) {\\n 49:\\t\\treturn a, nil\\n 50:\\t}\\n 51:\\n 52:\\t// Handle toast updates\\n 53:\\tif _, ok := msg.(common.ToastDismissed); ok {\\n 54:\\t\\tnewToast, cmd := a.ui.toast.Update(msg)\\n 55:\\t\\ta.ui.toast = newToast\\n 56:\\t\\tcmds = append(cmds, cmd)\\n 57:\\t}\\n 58:\\n 59:\\tif a.handleDialogInput(msg, &cmds) {\\n 60:\\t\\treturn a, common.SafeBatch(cmds...)\\n 61:\\t}\\n 62:\\tif a.handleFilePickerInput(msg, &cmds) {\\n 63:\\t\\treturn a, common.SafeBatch(cmds...)\\n 64:\\t}\\n 65:\\tif a.handleSettingsDialogInput(msg, &cmds) {\\n 66:\\t\\treturn a, common.SafeBatch(cmds...)\\n 67:\\t}\\n 68:\\n 69:\\tswitch msg := msg.(type) {\\n 70:\\tcase tea.KeyboardEnhancementsMsg:\\n 71:\\t\\ta.handleKeyboardEnhancements(msg)\\n 72:\\n 73:\\tcase tea.WindowSizeMsg:\\n 74:\\t\\ta.handleWindowSize(msg)\\n 75:\\n 76:\\tcase tea.MouseClickMsg, tea.MouseWheelMsg, tea.MouseMotionMsg, tea.MouseReleaseMsg:\\n 77:\\t\\tif cmd := a.handleMouseMsg(msg); cmd != nil {\\n 78:\\t\\t\\tcmds = append(cmds, cmd)\\n 79:\\t\\t}\\n 80:\\n 81:\\tcase tea.PasteMsg:\\n 82:\\t\\tif cmd := a.handlePaste(msg); cmd != nil {\\n 83:\\t\\t\\tcmds = append(cmds, cmd)\\n 84:\\t\\t}\\n 85:\\n 86:\\tcase prefixTimeoutMsg:\\n 87:\\t\\ta.handlePrefixTimeout(msg)\\n 88:\\n 89:\\tcase tea.KeyPressMsg:\\n 90:\\t\\tif cmd := a.handleKeyPress(msg); cmd != nil {\\n 91:\\t\\t\\tcmds = append(cmds, cmd)\\n 92:\\t\\t}\\n 93:\\n 94:\\tcase messages.ProjectsLoaded:\\n 95:\\t\\tcmds = append(cmds, a.handleProjectsLoaded(msg)...)\\n 96:\\n 97:\\tcase messages.WorkspaceActivated:\\n 98:\\t\\tcmds = append(cmds, a.handleWorkspaceActivated(msg)...)\\n 99:\\n100:\\tcase messages.ShowWelcome:\\n101:\\t\\ta.goHome()\\n102:\\n103:\\tcase messages.ShowCommandsPalette:\\n104:\\t\\tif cmd := a.openCommandsPalette(); cmd != nil {\\n105:\\t\\t\\tcmds = append(cmds, cmd)\\n106:\\t\\t}\\n107:\\n108:\\tcase messages.ToggleKe