yncDefaultInterval = 7 * time.Second\\n19:\\n20:\\t// gitPathWaitInterval is the polling interval when waiting for a new worktree to expose .git.\\n21:\\tgitPathWaitInterval = 100 * time.Millisecond\\n22:\\n23:\\t// persistDebounce controls workspace metadata save debouncing.\\n24:\\tpersistDebounce = 500 * time.Millisecond\\n25:\\n26:\\t// stateWatcherDebounce controls filesystem event coalescing for registry/workspace updates.\\n27:\\tstateWatcherDebounce = 200 * time.Millisecond\\n28:\\n29:\\t// localWorkspaceReloadSuppressWindow suppresses watcher-driven workspace reloads\\n30:\\t// immediately after this process saves workspace metadata.\\n31:\\tlocalWorkspaceReloadSuppressWindow = 800 * time.Millisecond\\n32:\\n33:\\t// tmuxActivityPrefilter controls the activity scan window for tmux sessions.\\n34:\\ttmuxActivityPrefilter = 120 * time.Second\\n35:\\n36:\\t// tmuxActivityInterval controls how often we scan tmux sessions for activity.\\n37:\\ttmuxActivityInterval = 5 * time.Second\\n38:\\n39:\\t// tmuxActivitySettleScans is how many successful activity scans are required\\n40:\\t// before dashboard \\\"active workspace\\\" indicators are shown.\\n41:\\t// This suppresses startup blips from initial hysteresis/state warmup.\\n42:\\ttmuxActivitySettleScans = 2\\n43:\\n44:\\t// tmuxCommandTimeout caps tmux command duration for activity scans.\\n45:\\ttmuxCommandTimeout = 2 * time.Second\\n46:\\n47:\\t// tmuxActivityOwnerLeaseTTL controls how long an activity-scan owner lease\\n48:\\t// stays valid before another instance can take ownership.\\n49:\\ttmuxActivityOwnerLeaseTTL = 7 * time.Second\\n50:\\n51:\\t// tmuxActivityOwnerFutureSkewTolerance caps how far in the future a lease\\n52:\\t// heartbeat can be and still be treated as alive (clock-skew protection).\\n53:\\ttmuxActivityOwnerFutureSkewTolerance = 2 * time.Second\\n54:\\n55:\\t// tmuxActivitySnapshotStaleAfter controls how long shared activity snapshots\\n56:\\t// are trusted by follower instances.\\n57:\\ttmuxActivitySnapshotStaleAfter = 10 * time.Second\\n58:\\n59:\\t// supervisorBackoff controls restart backoff for file/state watchers.\\n60:\\tsupervisorBackoff = 500 * time.Millisecond\\n61:\\n62:\\t// externalMsgBuffer is the size of the external message channel.\\n63:\\texternalMsgBuffer = 4096\\n64:\\n65:\\t// externalCriticalBuffer is the size of the critical external message channel.\\n66:\\texternalCriticalBuffer = 512\\n67:\\n68:\\t// defaultMaxAttachedAgentTabs limits concurrently attached chat PTYs to keep\\n69:\\t// UI responsiveness predictable under heavy multi-agent workloads.\\n70:\\t// AMUX_MAX_ATTACHED_AGENT_TABS=0 disables the limit.\\n71:\\tdefaultMaxAttachedAgentTabs = 6\\n72:\\n73:\\t// orphanGCInterval controls how often the periodic tmux orphan GC runs.\\n74:\\torphanGCInterval = 60 * time.Second\\n75:\\n76:\\t// detachedAgentStaleAfter is the inactivity threshold for detached,\\n77:\\t// clientless agent sessions before they are considered stale.\\n78:\\tdetachedAgentStaleAfter = 24 * time.Hour\\n79:\\n80:\\t// detachedAgentLivePaneStaleAfter is a stricter threshold for detached\\n81:\\t// agent sessions that still have a live pane.\\n82:\\tdetachedAgentLivePaneStaleAfter = 72 * time.Hour\\n83:\\n84:\\t// ticketPollInterval controls how often the background poller checks\\n85:\\t// TicketStore.LatestUpdate() for changes. The poller runs as a supervisor\\n86:\\t// worker so this does not block the UI rendering thread.\\n87:\\tticketPollInterval = 5 * time.Second\\n88:)]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
