orkspaceCreateFailed to include error\\\")\\n172:\\t}\\n173:\\tif !removeCalled {\\n174:\\t\\tt.Fatalf(\\\"expected workspace rollback to remove worktree\\\")\\n175:\\t}\\n176:\\tif !deleteCalled {\\n177:\\t\\tt.Fatalf(\\\"expected workspace rollback to delete branch\\\")\\n178:\\t}\\n179:\\n180:\\tids, err := store.List()\\n181:\\tif err != nil {\\n182:\\t\\tt.Fatalf(\\\"List: %v\\\", err)\\n183:\\t}\\n184:\\tif len(ids) != 0 {\\n185:\\t\\tt.Fatalf(\\\"expected no persisted workspaces, got %d\\\", len(ids))\\n186:\\t}\\n187:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
