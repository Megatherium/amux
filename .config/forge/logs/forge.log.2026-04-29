{"timestamp":" 525.874812185s","level":"DEBUG","fields":{"message":"Adding tool results to context","results":"[ToolResult { name: ToolName(\"read\"), call_id: Some(ToolCallId(\"call_00_fhselswhfGfUdcsyh17Q8IMa\")), output: ToolOutput { is_error: false, values: [Text(\"<file\\n  path=\\\"/home/sloth/gt/badmux/polecats/quartz/badmux/internal/app/app_input_messages_workspace_create_test.go\\\"\\n  display_lines=\\\"1-2000\\\"\\n  total_lines=\\\"165\\\"\\n><![CDATA[  1:package app\\n  2:\\n  3:import (\\n  4:\\t\\\"errors\\\"\\n  5:\\t\\\"path/filepath\\\"\\n  6:\\t\\\"testing\\\"\\n  7:\\t\\\"time\\\"\\n  8:\\n  9:\\t\\\"github.com/andyrewlee/amux/internal/data\\\"\\n 10:\\t\\\"github.com/andyrewlee/amux/internal/messages\\\"\\n 11:\\t\\\"github.com/andyrewlee/amux/internal/ui/dashboard\\\"\\n 12:)\\n 13:\\n 14:func TestHandleCreateWorkspaceSkipsPendingTrackingWithoutService(t *testing.T) {\\n 15:\\tapp := &App{\\n 16:\\t\\tui: &UICompositor{\\n 17:\\t\\t\\tdashboard: dashboard.New(),\\n 18:\\t\\t},\\n 19:\\t\\tworkspaceManager: &WorkspaceManager{creatingWorkspaceIDs: make(map[string]bool)},\\n 20:\\t\\t// workspaceService intentionally nil\\n 21:\\t}\\n 22:\\n 23:\\tproject := data.NewProject(\\\"/tmp/repo\\\")\\n 24:\\tmsg := messages.CreateWorkspace{\\n 25:\\t\\tProject:   project,\\n 26:\\t\\tName:      \\\"feature\\\",\\n 27:\\t\\tBase:      \\\"main\\\",\\n 28:\\t\\tAssistant: \\\"claude\\\",\\n 29:\\t}\\n 30:\\n 31:\\tcmds := app.handleCreateWorkspace(msg)\\n 32:\\t// Should not panic and should not track any pending IDs\\n 33:\\tif len(app.wm().creatingWorkspaceIDs) != 0 {\\n 34:\\t\\tt.Fatalf(\\\"expected no pending IDs without workspace service, got %d\\\", len(app.wm().creatingWorkspaceIDs))\\n 35:\\t}\\n 36:\\t// Should still return the createWorkspace cmd (which will be nil since service is nil)\\n 37:\\t_ = cmds\\n 38:}\\n 39:\\n 40:func TestHandleCreateWorkspaceTracksAndClearsPendingIDOnFailure(t *testing.T) {\\n 41:\\tgitErr := errors.New(\\\"git worktree add failed\\\")\\n 42:\\n 43:\\tworkspacesRoot := \\\"/tmp/workspaces\\\"\\n 44:\\tstore := data.NewWorkspaceStore(t.TempDir())\\n 45:\\tsvc := newWorkspaceService(nil, store, nil, workspacesRoot)\\n 46:\\tsvc.gitPathWaitTimeout = 50 * time.Millisecond\\n 47:\\tsvc.gitOps = &mockGitOps{\\n 48:\\t\\tcreateWorkspace: func(repoPath, workspacePath, branch, base string) error {\\n 49:\\t\\t\\treturn gitErr\\n 50:\\t\\t},\\n 51:\\t}\\n 52:\\n 53:\\tapp := &App{\\n 54:\\t\\tui: &UICompositor{\\n 55:\\t\\t\\tdashboard: dashboard.New(),\\n 56:\\t\\t},\\n 57:\\t\\tworkspaceManager: &WorkspaceManager{creatingWorkspaceIDs: make(map[string]bool)},\\n 58:\\t\\tworkspaceService: svc,\\n 59:\\t}\\n 60:\\n 61:\\tproject := data.NewProject(\\\"/tmp/repo\\\")\\n 62:\\tmsg := messages.CreateWorkspace{\\n 63:\\t\\tProject:   project,\\n 64:\\t\\tName:      \\\"feature\\\",\\n 65:\\t\\tBase:      \\\"main\\\",\\n 66:\\t\\tAssistant: \\\"claude\\\",\\n 67:\\t}\\n 68:\\n 69:\\t// Step 1: handleCreateWorkspace should track the pending ID\\n 70:\\tcmds := app.handleCreateWorkspace(msg)\\n 71:\\tif len(app.wm().creatingWorkspaceIDs) != 1 {\\n 72:\\t\\tt.Fatalf(\\\"expected 1 pending ID after handleCreateWorkspace, got %d\\\", len(app.wm().creatingWorkspaceIDs))\\n 73:\\t}\\n 74:\\n 75:\\t// Capture the tracked ID\\n 76:\\tvar trackedID string\\n 77:\\tfor id := range app.wm().creatingWorkspaceIDs {\\n 78:\\t\\ttrackedID = id\\n 79:\\t}\\n 80:\\n 81:\\t// Verify tracked ID matches expected path\\n 82:\\texpectedPath := filepath.Join(workspacesRoot, project.Name, \\\"feature\\\")\\n 83:\\tpending := svc.pendingWorkspace(project, \\\"feature\\\", \\\"main\\\")\\n 84:\\tif pending == nil {\\n 85:\\t\\tt.Fatal(\\\"expected non-nil pending workspace\\\")\\n 86:\\t}\\n 87:\\tif pending.Root != expectedPath {\\n 88:\\t\\tt.Fatalf(\\\"expected root %q, got %q\\\", expectedPath, pending.Root)\\n 89:\\t}\\n 90:\\tif string(pending.ID()) != trackedID {\\n 91:\\t\\tt.Fatalf(\\\"tracked ID %q does not match pending workspace ID %q\\\", trackedID, string(pending.ID()))\\n 92:\\t}\\n 93:\\n 94:\\t// Step 2: Execute the create command to get the failure\\n 95:\\tvar createCmd func() interface{ String() string }\\n 96:\\t_ = createCmd\\n 97:\\t// Find the non-nil cmd (createWorkspace returns a tea.Cmd)\\n 98:\\tfor _, cmd := range cmds {\\n 99:\\t\\tif cmd == nil {\\n100:\\t\\t\\tcontinue\\n101:\\t\\t}\\n102:\\t\\tresult := cmd()\\n103:\\t\\tif failed, ok := result.(messages.WorkspaceCreateFailed); ok {\\n104:\\t\\t\\t// Step 3: handleWorkspaceCreateFailed should clear the pending ID\\n105:\\t\\t\\tapp.handleWorkspaceCreateFailed(failed)\\n106:\\t\\t\\tif len(app.wm().creatingWorkspaceIDs) != 0 {\\n107:\\t\\t\\t\\tt.Fatalf(\\\"expected 0 pending IDs after failure, got %d\\\", len(app.wm().creatingWorkspaceIDs))\\n108:\\t\\t\\t}\\n109:\\t\\t\\t// Verify the failure workspace ID matches what was tracked\\n110:\\t\\t\\tif failed.Workspace != nil && string(failed.Workspace.ID()) != trackedID {\\n111:\\t\\t\\t\\tt.Fatalf(\\\"failure workspace ID %q does not match tracked ID %q\\\",\\n112:\\t\\t\\t\\t\\tstring(failed.Workspace.ID()), trackedID)\\n113:\\t\\t\\t}\\n114:\\t\\t\\treturn\\n115:\\t\\t}\\n116:\\t}\\n117:\\tt.Fatal(\\\"expected at least one cmd to produce WorkspaceCreateFailed\\\")\\n118:}\\n119:\\n120:func TestHandleCreateWorkspaceClearsPendingIDOnValidationFailure(t *testing.T) {\\n121:\\tworkspacesRoot := \\\"/tmp/workspaces\\\"\\n122:\\tstore := data.NewWorkspaceStore(t.TempDir())\\n123:\\tsvc := newWorkspaceService(nil, store, nil, workspacesRoot)\\n124:\\n125:\\tapp := &App{\\n126:\\t\\tui: &UICompositor{\\n127:\\t\\t\\tdashboard: dashboard.New(),\\n128:\\t\\t},\\n129:\\t\\tworkspaceManager: &WorkspaceManager{creatingWorkspaceIDs: make(map[string]bool)},\\n130:\\t\\tworkspaceService: svc,\\n131:\\t}\\n132:\\n133:\\tproject := data.NewProject(\\\"/tmp/repo\\\")\\n134:\\tmsg := messages.CreateWorkspace{\\n135:\\t\\tProject:   project,\\n136:\\t\\tName:      \\\"bad/name\\\",\\n137:\\t\\tBase:      \\\"main\\\",\\n138:\\t\\tAssistant: \\\"claude\\\",\\n139:\\t}\\n140:\\n141:\\tcmds := app.handleCreateWorkspace(msg)\\n142:\\tif len(app.wm().creatingWorkspaceIDs) != 1 {\\n143:\\t\\tt.Fatalf(\\\"expected 1 pending ID after handleCreateWorkspace, got %d\\\", len(app.wm().creatingWorkspaceIDs))\\n144:\\t}\\n145:\\n146:\\tfor _, cmd := range cmds {\\n147:\\t\\tif cmd == nil {\\n148:\\t\\t\\tcontinue\\n149:\\t\\t}\\n150:\\t\\tresult := cmd()\\n151:\\t\\tfailed, ok := result.(messages.WorkspaceCreateFailed)\\n152:\\t\\tif !ok {\\n153:\\t\\t\\tcontinue\\n154:\\t\\t}\\n155:\\t\\tif failed.Workspace == nil {\\n156:\\t\\t\\tt.Fatal(\\\"expected workspace in validation failure\\\")\\n157:\\t\\t}\\n158:\\t\\tapp.handleWorkspaceCreateFailed(failed)\\n159:\\t\\tif len(app.wm().creatingWorkspaceIDs) != 0 {\\n160:\\t\\t\\tt.Fatalf(\\\"expected 0 pending IDs after validation failure, got %d\\\", len(app.wm().creatingWorkspaceIDs))\\n161:\\t\\t}\\n162:\\t\\treturn\\n163:\\t}\\n164:\\tt.Fatal(\\\"expected at least one cmd to produce WorkspaceCreateFailed\\\")\\n165:}]]>\\n</file>\")] } }]"},"filename":"crates/forge_domain/src/context.rs","line_number":515}
